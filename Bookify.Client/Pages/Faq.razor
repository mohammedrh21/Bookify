@page "/faq"

<PageTitle>Frequently Asked Questions — Bookify</PageTitle>

<div class="bg-gradient-to-br from-primary-50 via-white to-blue-50 py-16 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary-100 text-primary-600 mb-6 shadow-inner text-3xl">
                <i class="fa-solid fa-circle-question"></i>
            </div>
            <h1 class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight mb-4">
                Frequently Asked <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-indigo-600">Questions</span>
            </h1>
            <p class="text-lg text-gray-500 mb-8">
                Find answers to common questions about our services and booking process.
            </p>

            <!-- FAQ Search Bar -->
            <div class="relative max-w-2xl mx-auto group">
                <i class="fa-solid fa-magnifying-glass absolute left-5 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary-500 transition-colors"></i>
                <input value="@_searchQuery" @oninput="OnSearchChanged"
                       placeholder="Search questions or keywords..."
                       class="w-full pl-14 pr-6 py-4 rounded-2xl border border-gray-100 shadow-xl shadow-gray-200/40 focus:outline-none focus:ring-2 focus:ring-primary-300 transition-all text-lg" />
            </div>
        </div>

        <div class="bg-white rounded-3xl p-8 md:p-12 shadow-xl shadow-gray-200/50 border border-gray-100">
            @if (_loadingFaqs)
            {
                <LoadingSpinner Message="Loading FAQs..." />
            }
            else if (!FilteredFaqs.Any())
            {
                <EmptyState Icon="🔍" Title="No matches found" Message="Try adjusting your search terms or keywords." />
            }
            else
            {
                <div class="space-y-4">
                    @foreach (var faq in FilteredFaqs)
                    {
                        var isExpanded = IsExpanded(faq.Id);
                        <div class="border @(isExpanded ? "border-primary-300 ring-2 ring-primary-100/50" : "border-gray-100") rounded-2xl overflow-hidden shadow-sm transition-all duration-300 hover:border-primary-200">
                            <button class="w-full text-left px-6 py-5 flex items-center justify-between transition-colors focus:outline-none @(isExpanded ? "bg-primary-50/50" : "bg-gray-50 hover:bg-white")"
                                    @onclick="() => ToggleFaq(faq.Id)">
                                <span class="font-semibold @(isExpanded ? "text-primary-800" : "text-gray-800") text-lg pr-8">@faq.Question</span>
                                <div class="w-10 h-10 rounded-full @(isExpanded ? "bg-primary-100 text-primary-700" : "bg-white text-gray-400") flex items-center justify-center shadow-sm group-hover:text-primary-600 transition-colors shrink-0">
                                    <i class="fa-solid fa-chevron-down transform transition-transform duration-300 @(isExpanded ? "rotate-180" : "")"></i>
                                </div>
                            </button>
                            
                            <div class="transition-all duration-300 ease-in-out border-t border-gray-100 @(isExpanded ? "max-h-96 opacity-100 py-6 px-6" : "max-h-0 opacity-0 overflow-hidden") bg-white text-gray-600 leading-relaxed text-base">
                                <p class="break-words break-all whitespace-normal">@faq.Answer</p>
                            </div>
                        </div>
                    }
                </div>

                @* Only show pagination if no search query or if result is large *@
                @if (_pagedResult.TotalPages > 1)

                {
                    <div class="mt-12 pt-8 border-t border-gray-100 flex flex-col sm:flex-row justify-between items-center gap-6">
                        <div class="text-sm text-gray-400 font-medium">
                            Showing <span class="text-gray-900">@((_pagedResult.PageNumber - 1) * _pagedResult.PageSize + 1)</span> 
                            - <span class="text-gray-900">@(Math.Min(_pagedResult.PageNumber * _pagedResult.PageSize, _pagedResult.TotalCount))</span> 
                            of <span class="text-gray-900">@_pagedResult.TotalCount</span>
                        </div>
                        
                        <div class="flex items-center gap-3">
                            <button @onclick="PreviousPage" 
                                    disabled="@(!_pagedResult.HasPreviousPage || _loadingFaqs)"
                                    class="p-3 rounded-2xl border border-gray-100 bg-gray-50 text-gray-600 hover:border-primary-200 hover:text-primary-600 disabled:opacity-40 disabled:cursor-not-allowed transition-all shadow-sm">
                                <i class="fa-solid fa-chevron-left"></i>
                            </button>
                            
                            <div class="px-5 py-2 rounded-2xl bg-primary-50 text-primary-700 font-bold text-sm shadow-inner">
                                Page @_pagedResult.PageNumber / @_pagedResult.TotalPages
                            </div>
                            
                            <button @onclick="NextPage" 
                                    disabled="@(!_pagedResult.HasNextPage || _loadingFaqs)"
                                    class="p-3 rounded-2xl border border-gray-100 bg-gray-50 text-gray-600 hover:border-primary-200 hover:text-primary-600 disabled:opacity-40 disabled:cursor-not-allowed transition-all shadow-sm">
                                <i class="fa-solid fa-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
        
        <div class="mt-12 text-center">
            <p class="text-gray-600 mb-4 font-medium">Still have questions?</p>
            <a href="/support" class="inline-flex items-center gap-2 px-6 py-3 bg-white border border-gray-200 text-gray-800 rounded-xl hover:border-primary-300 hover:text-primary-600 hover:shadow-md transition-all font-semibold">
                Submit a Support Ticket
                <i class="fa-solid fa-arrow-right ml-1"></i>
            </a>
        </div>
    </div>
</div>

