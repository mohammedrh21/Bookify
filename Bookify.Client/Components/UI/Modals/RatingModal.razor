@using Bookify.Client.Models.Booking

<div class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50 p-4 animate-in fade-in duration-300">
    <div class="bg-white rounded-3xl shadow-2xl max-w-md w-full p-8 relative animate-in zoom-in duration-300">
        <div class="text-center mb-6">
            <div class="w-16 h-16 bg-amber-50 text-amber-500 rounded-2xl flex items-center justify-center text-2xl mx-auto mb-4">
                <i class="fas fa-star"></i>
            </div>
            <h2 class="text-2xl font-bold text-gray-900">Rate Your Experience</h2>
            <p class="text-gray-500 mt-1">How was your service with @StaffName?</p>
        </div>

        <div class="space-y-6">
            <!-- Stars -->
            <div class="flex justify-center gap-3">
                @for (int i = 1; i <= 5; i++)
                {
                    int starIndex = i;
                    <button @onclick="() => _rating = starIndex" 
                            class="text-3xl transition-transform hover:scale-110 @(_rating >= starIndex ? "text-amber-400" : "text-gray-200")">
                        <i class="fas fa-star"></i>
                    </button>
                }
            </div>

            <!-- Comment -->
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">Your Feedback</label>
                <textarea @bind="_comment" rows="4"
                          class="w-full px-4 py-3 rounded-2xl border border-gray-100 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all resize-none text-sm"
                          placeholder="What did you think of the service?"></textarea>
            </div>

            <div class="flex gap-3">
                <button @onclick="HandleSubmit" disabled="@(_rating == 0 || IsSubmitting)"
                        class="flex-1 py-3.5 bg-gradient-to-r from-primary-600 to-indigo-600 text-white font-bold rounded-2xl text-sm transition-all shadow-lg hover:shadow-primary-500/40 disabled:opacity-50">
                    @if (IsSubmitting)
                    {
                        <i class="fas fa-spinner fa-spin mr-2"></i>
                        <span>Submitting...</span>
                    }
                    else
                    {
                        <span>Post Review</span>
                    }
                </button>
                <button @onclick="() => OnClose.InvokeAsync()"
                        class="px-6 py-3.5 bg-gray-50 text-gray-700 font-bold rounded-2xl text-sm hover:bg-gray-100 transition-all">
                    Cancel
                </button>
            </div>
        </div>

        <button @onclick="() => OnClose.InvokeAsync()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors">
            <i class="fas fa-times"></i>
        </button>
    </div>
</div>

@code {
    [Parameter] public string StaffName { get; set; } = "";
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public EventCallback<(int Rating, string Comment)> OnSubmit { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private int _rating = 0;
    private string _comment = "";

    private async Task HandleSubmit()
    {
        await OnSubmit.InvokeAsync((_rating, _comment));
    }
}
