@using Bookify.Client.Services
@inject NotificationToastService ToastService
@implements IDisposable

<div class="fixed bottom-6 right-6 z-[2000] flex flex-col gap-3 pointer-events-none w-[300px]">
    @foreach (var toast in ToastService.ActiveToasts)
    {
        <div @key="toast.Id" 
             class="pointer-events-auto group relative flex items-start gap-3 p-3.5 
                    bg-white/90 backdrop-blur-xl border border-gray-100 shadow-[0_8px_30px_rgb(0,0,0,0.08)]
                    rounded-2xl overflow-hidden animate-toast-in">
            
            <!-- Progress Bar -->
            <div class="absolute bottom-0 left-0 h-0.5 bg-primary-600/30 animate-toast-progress"></div>

            <!-- Icon -->
            <div class="w-8 h-8 rounded-xl flex items-center justify-center shrink-0 @GetTypeStyle(toast.NotificationType)">
                <i class="@GetTypeIcon(toast.NotificationType) text-xs"></i>
            </div>

            <!-- Content -->
            <div class="flex-1 min-w-0 pt-0.5">
                <div class="flex items-center justify-between mb-0.5">
                    <h4 class="text-[12px] font-extrabold text-gray-900 tracking-tight truncate">@toast.Title</h4>
                    <button @onclick="() => ToastService.Dismiss(toast.Id)" 
                            class="text-gray-300 hover:text-gray-500 transition-colors p-0.5">
                        <i class="fas fa-times text-[10px]"></i>
                    </button>
                </div>
                <p class="text-[11px] font-medium text-gray-500 leading-snug line-clamp-2">@toast.Message</p>
            </div>
        </div>
    }
</div>

<style>
    .animate-toast-in {
        animation: toastIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .animate-toast-progress {
        animation: toastProgress 5s linear forwards;
    }

    @@keyframes toastIn {
        from { transform: translateX(20px); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }

    @@keyframes toastProgress {
        from { width: 100%; }
        to { width: 0%; }
    }
</style>

@code {
    protected override void OnInitialized()
    {
        ToastService.OnChange += StateHasChanged;
    }

    private string GetTypeIcon(string type) => type switch
    {
        "NewBooking" => "fas fa-calendar-plus",
        "BookingStatusChanged" => "fas fa-sync-alt",
        "ServiceDeleted" => "fas fa-exclamation-triangle",
        "ServiceApproved" => "fas fa-check-double",
        "NewReview" => "fas fa-comment-dots",
        _ => "fas fa-bell"
    };

    private string GetTypeStyle(string type) => type switch
    {
        "NewBooking" => "bg-blue-50 text-blue-600",
        "BookingStatusChanged" => "bg-amber-50 text-amber-600",
        "ServiceDeleted" => "bg-rose-50 text-rose-600",
        "ServiceApproved" => "bg-emerald-50 text-emerald-600",
        "NewReview" => "bg-indigo-50 text-indigo-600",
        _ => "bg-gray-50 text-gray-400"
    };

    public void Dispose()
    {
        ToastService.OnChange -= StateHasChanged;
    }
}
