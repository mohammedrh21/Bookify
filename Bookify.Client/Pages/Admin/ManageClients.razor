@page "/admin/clients"
@attribute [Authorize(Roles = "Admin")]


<PageTitle>Manage Clients — Bookify Admin</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Client Management</h1>
        <p class="text-gray-500 mt-1">Supervise client activity and view engagement reports</p>
    </div>

    @if (_loading)
    {
        <LoadingSpinner Message="Fetching client data..." />
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Client List -->
            <div class="lg:col-span-2 bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
                <table class="w-full text-left">
                    <thead class="bg-gray-50 border-b border-gray-100">
                        <tr>
                            <th class="px-8 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Client</th>
                            <th class="px-8 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider text-center">Bookings</th>
                            <th class="px-8 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        @foreach (var client in _clients)
                        {
                            <tr class="hover:bg-gray-50 transition-colors @(_selectedClientId == client.Id ? "bg-primary-50" : "")">
                                <td class="px-8 py-6">
                                    <div class="flex items-center gap-3">
                                        @if (!string.IsNullOrEmpty(client.ImagePath))
                                        {
                                            <img src="@client.ImagePath" class="w-10 h-10 rounded-full object-cover shadow-sm border border-gray-100" alt="@client.FullName" />
                                        }
                                        else
                                        {
                                            <div class="w-10 h-10 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center font-bold">
                                                @client.FullName[0]
                                            </div>
                                        }
                                        <div>
                                            <p class="font-bold text-gray-900">@client.FullName</p>
                                            <p class="text-xs text-gray-400">@client.Phone</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-8 py-6 text-center">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-gray-100 text-gray-600">
                                        @client.BookingCount
                                    </span>
                                </td>
                                <td class="px-8 py-6 text-right">
                                    <button @onclick="() => LoadReport(client.Id)" 
                                            class="px-4 py-2 text-xs font-bold text-primary-600 bg-primary-50 hover:bg-primary-100 rounded-xl transition-all">
                                        View Report
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <Pagination CurrentPage="_clientPage" TotalPages="_totalClientPages" TotalCount="_totalClientCount" OnPageChanged="OnClientPageChanged" />
            </div>

            <!-- Client Report Sidebar -->
            <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm h-fit sticky top-24">
                @if (_reportLoading)
                {
                    <div class="text-center py-20">
                        <div class="w-8 h-8 border-4 border-primary-200 border-t-primary-600 rounded-full animate-spin mx-auto mb-4"></div>
                        <p class="text-sm text-gray-400">Generating report...</p>
                    </div>
                }
                else if (_report != null)
                {
                    <div class="text-center mb-8">
                        @if (!string.IsNullOrEmpty(_report.ImagePath))
                        {
                            <img src="@_report.ImagePath" class="w-20 h-20 rounded-full object-cover shadow-md mx-auto mb-4 border-2 border-white ring-2 ring-purple-100" alt="@_report.FullName" />
                        }
                        else
                        {
                            <div class="w-20 h-20 bg-purple-50 text-purple-600 rounded-full flex items-center justify-center text-3xl font-bold mx-auto mb-4">
                                @_report.FullName[0]
                            </div>
                        }
                        <h2 class="text-2xl font-bold text-gray-900">@_report.FullName</h2>
                        <p class="text-sm text-gray-500">@_report.Phone</p>
                    </div>

                    <div class="grid grid-cols-2 gap-4 mb-8">
                        <div class="bg-gray-50 p-4 rounded-2xl text-center">
                            <p class="text-[10px] font-bold text-gray-400 uppercase">Bookings</p>
                            <p class="text-xl font-bold text-gray-900">@_report.TotalBookings</p>
                        </div>
                        <div class="bg-gray-50 p-4 rounded-2xl text-center">
                            <p class="text-[10px] font-bold text-gray-400 uppercase">Status</p>
                            <p class="text-sm font-bold @(_report.IsActive ? "text-green-600" : "text-red-600")">@(_report.IsActive ? "Active" : "Inactive")</p>
                        </div>
                    </div>

                    <div class="mb-8">
                        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Recent Appointments</h3>
                        <div class="space-y-3">
                            @foreach (var booking in _report.RecentBookings)
                            {
                                <div class="flex items-center justify-between p-3 bg-white border border-gray-100 rounded-2xl text-sm">
                                    <span class="font-medium text-gray-900">@booking.ServiceName</span>
                                    <span class="text-xs text-gray-400">@booking.Date.ToString("MMM dd")</span>
                                </div>
                            }
                        </div>
                    </div>

                    <button @onclick="ToggleActive" 
                            class="w-full py-4 text-sm font-bold rounded-2xl transition-all @(_report.IsActive ? "bg-red-50 text-red-600 hover:bg-red-100" : "bg-green-50 text-green-600 hover:bg-green-100")">
                        @(_report.IsActive ? "Suspend Client Account" : "Activate Client Account")
                    </button>
                }
                else
                {
                    <div class="text-center py-20">
                        <div class="text-4xl mb-4">👤</div>
                        <p class="text-sm text-gray-400">Select a client to view their detailed activity report.</p>
                    </div>
                }
            </div>
        </div>
    }
</div>



