@page "/my-bookings"
@attribute [Authorize]

@using Bookify.Client.Models.Common

<PageTitle>My Bookings — Bookify</PageTitle>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">My Bookings</h1>
            <p class="text-gray-400 mt-1">Track and manage your appointments</p>
        </div>
        <a href="/services"
           class="inline-flex items-center px-5 py-2.5 bg-primary-600 text-white font-semibold rounded-xl text-sm hover:bg-primary-700 transition-colors gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            New Booking
        </a>
    </div>

    <!-- Status Tabs -->
    <div class="flex gap-1 mb-6 bg-gray-100 p-1 rounded-xl w-fit flex-wrap">
        @foreach (var tab in _tabs)
        {
            <button @onclick="() => _activeTab = tab"
                    class="px-4 py-2 rounded-lg text-sm font-medium transition-all whitespace-nowrap
                                   @(_activeTab == tab ? "bg-white text-gray-900 shadow-sm" : "text-gray-500 hover:text-gray-700")">
                @tab
                @if (tab != "All")
                {
                    var count = _bookings.Count(b => b.Status.Equals(tab, StringComparison.OrdinalIgnoreCase));
                    if (count > 0)
                    {
                        <span class="ml-1.5 text-xs bg-primary-100 text-primary-700 px-1.5 py-0.5 rounded-full">@count</span>
                    }
                }
            </button>
        }
    </div>

    @if (_loading)
    {
        <LoadingSpinner Message="Loading bookings..." />
    }
    else if (FilteredBookings.Count == 0)
    {
        <EmptyState Icon="📅" Title="No bookings found"
                    Message="@(_activeTab == "All" ? "You haven't made any bookings yet." : $"No {_activeTab.ToLower()} bookings.")"
                    ActionHref="/services" ActionLabel="Browse Services" />
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            @foreach (var b in FilteredBookings.OrderByDescending(x => x.Date))
            {
                <BookingCard Booking="b" OnCancel="() => ShowCancelModal(b.Id)" OnRate="ShowRatingModal" />
            }
        </div>
    }
</div>

<!-- Cancel Confirmation Modal -->
@if (_cancelModalVisible)
{
    <div class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50">
        <div class="bg-white rounded-2xl shadow-xl max-w-sm w-full p-6 relative">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Cancel Booking</h2>
            <p class="text-gray-500 mb-6">Are you sure you want to cancel this booking? This action cannot be undone.</p>
            <div class="flex justify-end gap-3">
                <button @onclick="ConfirmCancel"
                        class="px-4 py-2 rounded-xl text-white bg-red-600 hover:bg-red-700 transition-colors">
                    Yes, Cancel
                </button>
                <button @onclick="CloseCancelModal"
                        class="px-4 py-2 rounded-xl text-gray-700 bg-gray-100 hover:bg-gray-200 transition-colors">
                    No
                </button>
            </div>
            <button @onclick="CloseCancelModal" class="absolute top-3 right-3 text-gray-400 hover:text-gray-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </button>
        </div>
    </div>
}

<!-- Rating Modal -->
@if (_ratingModalVisible && _bookingToRate != null)
{
    <div class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50 p-4">
        <div class="bg-white rounded-3xl shadow-2xl max-w-md w-full p-8 relative animate-in fade-in zoom-in duration-300">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-amber-50 text-amber-500 rounded-2xl flex items-center justify-center text-2xl mx-auto mb-4">
                    <i class="fas fa-star"></i>
                </div>
                <h2 class="text-2xl font-bold text-gray-900">Rate Service</h2>
                <p class="text-gray-500 mt-1">How was your experience with @_bookingToRate.ServiceName?</p>
            </div>

            <div class="space-y-6">
                <!-- Stars -->
                <div class="flex justify-center gap-3">
                    @for (int i = 1; i <= 5; i++)
                    {
                        int starIndex = i;
                        <button @onclick="() => _rating = starIndex" 
                                class="text-3xl transition-transform hover:scale-110 @(_rating >= starIndex ? "text-amber-400" : "text-gray-200")">
                            <i class="fas fa-star"></i>
                        </button>
                    }
                </div>

                <!-- Comment -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Your Feedback (Optional)</label>
                    <textarea @bind="_reviewComment" rows="3"
                              class="w-full px-4 py-3 rounded-2xl border border-gray-100 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all resize-none text-sm"
                              placeholder="Tell us what you liked or how we can improve..."></textarea>
                </div>

                <div class="flex gap-3">
                    <button @onclick="SubmitReview" disabled="@(_rating == 0 || _submittingReview)"
                            class="flex-1 py-3.5 bg-gradient-to-r from-primary-600 to-indigo-600 text-white font-bold rounded-2xl text-sm transition-all shadow-lg shadow-primary-500/20 hover:shadow-primary-500/40 disabled:opacity-50 disabled:shadow-none">
                        @if (_submittingReview)
                        {
                            <i class="fas fa-spinner fa-spin mr-2"></i>
                            <span>Submitting...</span>
                        }
                        else
                        {
                            <span>Submit Review</span>
                        }
                    </button>
                    <button @onclick="CloseRatingModal"
                            class="px-6 py-3.5 bg-gray-50 text-gray-700 font-bold rounded-2xl text-sm hover:bg-gray-100 transition-all">
                        Cancel
                    </button>
                </div>
            </div>

            <button @onclick="CloseRatingModal" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors">
                <i class="fas fa-times"></i>
            </button>
        </div>
    </div>
}
