@inject IAuthService AuthService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject ILocalStorageService localStorage

<!-- Mobile Backdrop -->
@if (IsOpen)
{
    <div class="fixed inset-0 bg-gray-900/80 z-40 lg:hidden transition-opacity backdrop-blur-sm" @onclick="Close"></div>
}

<!-- Sidebar -->
<aside class="fixed inset-y-0 left-0 z-50 w-72 bg-gray-900 text-white shadow-2xl flex flex-col pt-5 pb-4 overflow-y-auto transform transition-transform duration-300 ease-in-out lg:translate-x-0 @(IsOpen ? "translate-x-0" : "-translate-x-full")">
    
    <!-- Close button (Mobile only) -->
    <button @onclick="Close" class="lg:hidden absolute top-4 right-4 p-2 text-gray-400 hover:text-white hover:bg-gray-800 rounded-full transition-colors">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
    </button>

    <!-- Logo and Notifications -->
    <div class="flex items-center justify-between px-6 mb-10 mt-2">
        <a href="/" class="flex items-center gap-4 group">
            <div class="w-11 h-11 bg-gradient-to-br from-primary-500 to-primary-600 rounded-xl flex items-center justify-center shadow-lg group-hover:shadow-primary-500/30 group-hover:scale-105 transition-all">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
            </div>
            <span class="text-2xl font-bold tracking-tight text-white group-hover:text-primary-400 transition-colors">Bookify</span>
        </a>
        <Bookify.Client.Components.Shared.NotificationBell IsSidebarMode="true" />
    </div>

    <!-- Navigation Area -->
    <nav class="flex-1 px-4 space-y-1">
        <AuthorizeView Roles="Admin" Context="adminContext">
            <Authorized>
                <div class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3 px-3 mt-6">Administration</div>
                <div class="space-y-1">
                    <NavLink href="/admin/dashboard" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                       <i class="fas fa-chart-line w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>Dashboard</span>
                    </NavLink>
                    <NavLink href="/admin/categories" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                        <i class="fas fa-tags w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>Categories</span>
                    </NavLink>
                    <NavLink href="/admin/bookings" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                        <i class="fas fa-calendar-check w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>Bookings</span>
                    </NavLink>
                    <NavLink href="/admin/staff-members" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                        <i class="fas fa-users w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>Manage Staff</span>
                    </NavLink>
                    <NavLink href="/admin/clients" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                        <i class="fas fa-user-friends w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>Clients</span>
                    </NavLink>
                    <NavLink href="/admin/services" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                        <i class="fas fa-concierge-bell w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>Services</span>
                    </NavLink>
                    <NavLink href="/admin/service-approvals" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                        <i class="fas fa-clipboard-check w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>Approvals</span>
                    </NavLink>
                    <NavLink href="/admin/tickets" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                        <i class="fas fa-ticket-alt w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>Tickets</span>
                    </NavLink>
                    <NavLink href="/admin/faqs" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                        <i class="fas fa-question-circle w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>FAQs</span>
                    </NavLink>
                    <NavLink href="/admin/contact-info" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                        <i class="fas fa-address-book w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>Contact Info</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Staff" Context="staffContext">
            <Authorized>
                <div class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3 px-3 mt-6">Workspace</div>
                <div class="space-y-1">
                    <NavLink href="/staff/dashboard" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                        <i class="fas fa-chart-pie w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>My Dashboard</span>
                    </NavLink>
                    <NavLink href="/booking/service-bookings" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                        <i class="fas fa-history w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>Bookings History</span>
                    </NavLink>
                    <NavLink href="/services/my-service" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                        <i class="fas fa-box-open w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>My Service</span>
                    </NavLink>
                    <NavLink href="/staff/clients" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                        <i class="fas fa-users w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>My Clients</span>
                    </NavLink>
                    <NavLink href="/staff/reviews" @onclick="CloseOnMobile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-all group" ActiveClass="bg-primary-500/10 text-primary-400 font-semibold ring-1 ring-primary-500/20">
                        <i class="fas fa-star w-5 text-center text-lg opacity-70 group-hover:opacity-100 group-[.active]:text-primary-400 transition-opacity"></i> <span>Service Reviews</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>

    <!-- User Profile Snippet (Bottom) -->
    <div class="mt-8 px-5 pt-5 pb-5 border-t border-gray-800/80 relative">
        <button @onclick="ToggleDropdown" class="w-full flex items-center justify-between gap-3 p-2.5 rounded-2xl bg-gray-800/50 border border-gray-700/50 hover:bg-gray-800 hover:border-gray-700 transition-all group cursor-pointer focus:outline-none">
            <div class="flex items-center gap-3 overflow-hidden">
                <div class="w-10 h-10 bg-gradient-to-br from-gray-700 to-gray-800 rounded-full flex items-center justify-center shrink-0 shadow-inner">
                    <span class="text-gray-300 text-sm font-black tracking-wider group-hover:text-white transition-colors">@GetInitial()</span>
                </div>
                <div class="flex flex-col truncate text-left flex-1">
                    <span class="text-sm font-semibold text-gray-300 truncate group-hover:text-white transition-colors">@_userName</span>
                    <span class="text-[11px] font-medium text-gray-500 uppercase tracking-wider mt-0.5">Settings</span>
                </div>
            </div>
            <i class="fas fa-chevron-down text-gray-500 text-xs transition-transform duration-300 pr-2 @(_isDropdownOpen ? "rotate-180" : "rotate-0")"></i>
        </button>

        <!-- Dropdown Menu -->
        <div class="grid transition-[grid-template-rows,opacity,margin] duration-300 ease-in-out @(_isDropdownOpen ? "grid-rows-[1fr] opacity-100 mt-2" : "grid-rows-[0fr] opacity-0 mt-0 pointer-events-none")">
            <div class="overflow-hidden">
                <div class="bg-gray-800/60 backdrop-blur-md border border-gray-700/50 rounded-2xl shadow-inner py-1.5 flex flex-col gap-0.5">
                    <a href="@_profileRoute" @onclick="CloseDropdown" tabindex="@(_isDropdownOpen ? "0" : "-1")" class="flex items-center gap-3 px-4 py-2 text-gray-400 hover:bg-gray-700/60 hover:text-white rounded-xl mx-1.5 transition-all">
                        <i class="fas fa-user text-primary-400 w-4 text-center"></i>
                        <span class="text-sm font-medium tracking-wide">My Profile</span>
                    </a>
                    <a href="/profile/change-password" @onclick="CloseDropdown" tabindex="@(_isDropdownOpen ? "0" : "-1")" class="flex items-center gap-3 px-4 py-2 text-gray-400 hover:bg-gray-700/60 hover:text-white rounded-xl mx-1.5 transition-all">
                        <i class="fas fa-shield-alt text-amber-500 w-4 text-center"></i>
                        <span class="text-sm font-medium tracking-wide">Security</span>
                    </a>
                    <div class="h-px bg-gray-700/50 my-1 mx-3 flex-shrink-0"></div>
                    <button @onclick="Logout" tabindex="@(_isDropdownOpen ? "0" : "-1")" class="w-full flex items-center gap-3 px-4 py-2 text-red-400 hover:bg-red-500/10 hover:text-red-300 rounded-xl mx-1.5 transition-all text-left">
                        <i class="fas fa-sign-out-alt w-4 text-center"></i>
                        <span class="text-sm font-bold tracking-wide">Sign Out</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</aside>

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    private string _userName = string.Empty;
    private string _profileRoute = "/";
    private bool _isDropdownOpen = false;

    protected override async Task OnInitializedAsync()
    {
        await UpdateUserInfo();
    }

    private async Task UpdateUserInfo()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            _userName = await localStorage.GetItemAsync<string>("user_name") ?? "User";
            var role = await AuthService.GetUserRoleAsync();
            _profileRoute = role switch
            {
                "Admin"  => "/admin/profile",
                "Staff"  => "/staff/profile",
                _        => "/"
            };
        }
    }

    private string GetInitial() => _userName.Length > 0 ? _userName[0].ToString().ToUpper() : "U";

    private async Task Close()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }
    
    private async Task CloseOnMobile()
    {
        if (IsOpen)
        {
            await Close();
        }
    }

    private void ToggleDropdown()
    {
        _isDropdownOpen = !_isDropdownOpen;
    }

    private async Task CloseDropdown()
    {
        _isDropdownOpen = false;
        await CloseOnMobile();
    }

    private async Task Logout()
    {
        await Close();
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/", forceLoad: true);
    }
}
