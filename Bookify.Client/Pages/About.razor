@page "/about"

<PageTitle>About Us — Bookify</PageTitle>

<div class="bg-gradient-to-br from-primary-50 via-white to-blue-50 py-16 min-h-screen">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h1 class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight mb-4 animate-fade-in-up">
                About <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-indigo-600">Bookify</span>
            </h1>
            <p class="text-lg text-gray-500 animate-fade-in-up" style="animation-delay: 0.1s;">
                Simplifying the way you find, book, and offer professional services.
            </p>
        </div>

        <div class="bg-white rounded-3xl p-8 md:p-12 shadow-xl shadow-gray-200/50 border border-gray-100 mb-12 animate-fade-in-up" style="animation-delay: 0.2s;">
            <div class="grid md:grid-cols-2 gap-12 items-center">
                <div class="space-y-6">
                    <h2 class="text-3xl font-bold text-gray-900">Our Mission</h2>
                    <p class="text-gray-600 leading-relaxed">
                        At Bookify, we believe that accessing quality services should be effortless. Our mission is to bridge the gap between skilled professionals and those who need them, creating a seamless platform that empowers both clients and service providers.
                    </p>
                    <p class="text-gray-600 leading-relaxed">
                        Whether you're looking for an expert consultation, a regular service, or you're a professional looking to grow your clientele, Bookify provides the tailored tools to make booking straightforward and stress-free.
                    </p>
                    <div class="pt-4 border-t border-gray-100 flex gap-4">
                        <div class="flex-1 text-center p-4 bg-primary-50 rounded-2xl">
                            <h4 class="text-2xl font-black text-primary-700">10k+</h4>
                            <p class="text-xs font-semibold text-primary-600/80 uppercase tracking-wider mt-1">Bookings</p>
                        </div>
                        <div class="flex-1 text-center p-4 bg-indigo-50 rounded-2xl">
                            <h4 class="text-2xl font-black text-indigo-700">5k+</h4>
                            <p class="text-xs font-semibold text-indigo-600/80 uppercase tracking-wider mt-1">Professionals</p>
                        </div>
                    </div>
                </div>
                
                <div class="relative pl-6 pb-6">
                    <!-- Decorative background patterns -->
                    <div class="absolute top-0 right-0 w-64 h-64 bg-primary-100 rounded-full mix-blend-multiply filter blur-3xl opacity-60"></div>
                    <div class="absolute bottom-0 left-0 w-full h-full bg-[radial-gradient(#6366f1_1px,transparent_1px)] [background-size:20px_20px] opacity-20 transform translate-x-6 translate-y-6 rounded-[2.5rem]"></div>
                    
                    <div class="relative rounded-[2.5rem] overflow-hidden shadow-2xl group w-full aspect-square border-8 border-white bg-white">
                        <div class="absolute inset-0 bg-gradient-to-tr from-primary-600/20 via-transparent to-indigo-600/10 mix-blend-screen rounded-[2.5rem] z-10 transition-opacity duration-500 group-hover:opacity-100 opacity-50"></div>
                        
                        <!-- Actual App Image from Cloudinary (1:1 Ratio) -->
                        <img src="https://res.cloudinary.com/dfbwauiu1/image/upload/v1773945569/about-us-2_cbjvz7.png"
                             alt="About Bookify Team" 
                             class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-in-out" />
                        
                        <!-- Decorative Floating Element -->
                        <div class="absolute bottom-8 left-8 z-20 bg-white/95 backdrop-blur-xl px-5 py-3.5 rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] flex items-center gap-3.5 transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 delay-100 border border-gray-100/50">
                            <div class="w-10 h-10 bg-gradient-to-br from-primary-100 to-indigo-50 rounded-xl flex items-center justify-center text-primary-600 text-lg shadow-inner">
                                💼
                            </div>
                            <div>
                                <p class="text-sm font-extrabold text-slate-800 leading-tight">Verified</p>
                                <p class="text-xs font-semibold text-slate-500">Professionals</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Core Values -->
        <div class="grid md:grid-cols-3 gap-6 animate-fade-in-up" style="animation-delay: 0.3s;">
            <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 hover:border-primary-200 hover:shadow-lg transition-all">
                <div class="w-12 h-12 bg-primary-100 text-primary-600 rounded-2xl flex items-center justify-center text-xl mb-6 shadow-inner">
                    🚀
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-3">Innovation</h3>
                <p class="text-gray-500 text-sm leading-relaxed">
                    We constantly strive to build features that simplify the booking experience and bring value to businesses.
                </p>
            </div>
            
            <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 hover:border-indigo-200 hover:shadow-lg transition-all">
                <div class="w-12 h-12 bg-indigo-100 text-indigo-600 rounded-2xl flex items-center justify-center text-xl mb-6 shadow-inner">
                    🤝
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-3">Trust</h3>
                <p class="text-gray-500 text-sm leading-relaxed">
                    Reliability is at our core. We ensure a secure environment for all transactions and communications.
                </p>
            </div>
            
            <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 hover:border-blue-200 hover:shadow-lg transition-all">
                <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center text-xl mb-6 shadow-inner">
                    ⭐
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-3">Excellence</h3>
                <p class="text-gray-500 text-sm leading-relaxed">
                    We measure our success by the satisfaction of our users and the growth of the businesses on our platform.
                </p>
            </div>
        </div>
        
    </div>
</div>

