@page "/admin/contact-info"
@attribute [Authorize(Roles = "Admin")]
@using Bookify.Client.Models.ContactInfo
@using Bookify.Client.Models
@using Bookify.Client.Services
@inject IContactInfoApiService ContactInfoService

<PageTitle>Manage Contact Info — Bookify Admin</PageTitle>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Contact Information</h1>
        <p class="text-gray-500 mt-1">Configure your business address and contact reachability</p>
    </div>

    @if (_loading)
    {
        <LoadingSpinner Message="Loading contact details..." />
    }
    else
    {
        <!-- Wizard Progress Steps -->
        <div class="mb-10">
            <div class="flex items-center justify-between max-w-2xl mx-auto">
                @for (int i = 1; i <= 3; i++)
                {
                    var step = i;
                    <div class="flex flex-col items-center">
                        <div class="flex items-center">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold transition-all duration-300
                                                @(step == _currentStep ? "bg-primary-600 text-white shadow-lg shadow-primary-200 scale-110" :
                                                                                                    step < _currentStep ? "bg-green-500 text-white" : "bg-gray-200 text-gray-500")">
                                @if (step < _currentStep)
                                {
                                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                    </svg>
                                }
                                else
                                {
                                    @step
                                }
                            </div>
                            @if (step < 3)
                            {
                                <div class="w-20 sm:w-32 h-1 mx-2 rounded @(step < _currentStep ? "bg-green-500" : "bg-gray-200")"></div>
                            }
                        </div>
                        <span class="mt-2 text-xs font-semibold @(step == _currentStep ? "text-primary-600" : "text-gray-400")">
                            @GetStepLabel(step)
                        </span>
                    </div>
                }
            </div>
        </div>

        <div class="bg-white rounded-3xl border border-gray-100 shadow-xl shadow-gray-100/50 overflow-hidden animate-fade-in">
            <div class="p-8">
                @if (_currentStep == 1)
                {
                    <div class="space-y-6">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="text-2xl">🌍</span>
                            <h2 class="text-xl font-bold text-gray-800">Location & Address</h2>
                        </div>
                        <div class="grid grid-cols-1 gap-6">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Country</label>
                                <input @bind="_model.Country" placeholder="e.g. United States"
                                       class="w-full px-5 py-3 rounded-2xl border border-gray-200 focus:ring-4 focus:ring-primary-100 focus:border-primary-400 outline-none transition-all" />
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Address Line 1</label>
                                <input @bind="_model.AddressLine_1" placeholder="e.g. 123 Business Ave"
                                       class="w-full px-5 py-3 rounded-2xl border border-gray-200 focus:ring-4 focus:ring-primary-100 focus:border-primary-400 outline-none transition-all" />
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Address Line 2 (Optional)</label>
                                <input @bind="_model.AddressLine_2" placeholder="e.g. Suite 400"
                                       class="w-full px-5 py-3 rounded-2xl border border-gray-200 focus:ring-4 focus:ring-primary-100 focus:border-primary-400 outline-none transition-all" />
                            </div>
                        </div>
                    </div>
                }
                else if (_currentStep == 2)
                {
                    <div class="space-y-6">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="text-2xl">📱</span>
                            <h2 class="text-xl font-bold text-gray-800">Digital Reach</h2>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Email Address</label>
                                <input @bind="_model.Email" type="email" placeholder="contact@bookify.com"
                                       class="w-full px-5 py-3 rounded-2xl border border-gray-200 focus:ring-4 focus:ring-primary-100 focus:border-primary-400 outline-none transition-all" />
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Phone Number</label>
                                <input @bind="_model.PhoneNumber" type="tel" placeholder="+1 (555) 000-0000"
                                       class="w-full px-5 py-3 rounded-2xl border border-gray-200 focus:ring-4 focus:ring-primary-100 focus:border-primary-400 outline-none transition-all" />
                            </div>
                        </div>
                    </div>
                }
                else if (_currentStep == 3)
                {
                    <div class="space-y-6">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="text-2xl">⏰</span>
                            <h2 class="text-xl font-bold text-gray-800">Support Availability</h2>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="space-y-4">
                                <h3 class="text-sm font-bold text-primary-600 uppercase tracking-wider">Days</h3>
                                <div>
                                    <label class="block text-xs font-medium text-gray-400 mb-1">From</label>
                                    <select @bind="_model.CallDayFrom" class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none">
                                        @foreach (DayOfWeek day in Enum.GetValues(typeof(DayOfWeek)))
                                        {
                                            <option value="@day">@day</option>
                                        }
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-xs font-medium text-gray-400 mb-1">To</label>
                                    <select @bind="_model.CallDayTo" class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none">
                                        @foreach (DayOfWeek day in Enum.GetValues(typeof(DayOfWeek)))
                                        {
                                            <option value="@day">@day</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="space-y-4">
                                <h3 class="text-sm font-bold text-primary-600 uppercase tracking-wider">Hours</h3>
                                <div>
                                    <label class="block text-xs font-medium text-gray-400 mb-1">From</label>
                                    <InputTimeSpan @bind-Value="_model.CallHourFrom" CssClass="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none" />
                                </div>
                                <div>
                                    <label class="block text-xs font-medium text-gray-400 mb-1">To</label>
                                    <InputTimeSpan @bind-Value="_model.CallHourTo" CssClass="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none" />
                                </div>
                            </div>
                        </div>
                    </div>
                }
        </div>

        <!-- Footer / Navigation -->
        <div class="px-8 py-6 bg-gray-50/50 border-t border-gray-50 flex items-center justify-between">
            <button @onclick="PreviousStep" @attributes=@((_currentStep > 0 || _saving
                                                                ? new Dictionary<string, object> { { "disabled", "disabled" } } : null))
                    class="px-6 py-3 rounded-2xl font-bold text-gray-600 hover:bg-white border border-transparent hover:border-gray-200 transition-all disabled:opacity-0">
                Back
            </button>

                <div class="flex gap-3">
                @if (_currentStep < 3)
                    {
                        <button @onclick="NextStep"
                                class="px-8 py-3 bg-primary-600 text-white font-bold rounded-2xl hover:bg-primary-700 shadow-lg shadow-primary-200 transition-all">
                            Continue
                        </button>
                    }
                    else
                    {
                        <button @onclick="SaveAsync" disabled="@_saving"
                                class="px-10 py-3 bg-green-600 text-white font-bold rounded-2xl hover:bg-green-700 shadow-lg shadow-green-200 transition-all flex items-center gap-2">
                            @if (_saving)
                            {
                                <span class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                                <span>Saving...</span>
                            }
                            else
                            {
                                <span>Finish & Save</span>
                            }
                        </button>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private ContactInfoModel _model = new();
    private bool _loading = true;
    private bool _saving = false;
    private bool _isNew = false;
    private int _currentStep = 1;

    protected override async Task OnInitializedAsync()
    {
        var result = await ContactInfoService.GetAsync();
        if (result.Success && result.Data != null)
        {
            _model = result.Data;
            _isNew = false;
        }
        else
        {
            _isNew = true;
            _model = new ContactInfoModel
            {
                CallDayFrom = DayOfWeek.Monday,
                CallDayTo = DayOfWeek.Friday,
                CallHourFrom = new TimeSpan(9, 0, 0),
                CallHourTo = new TimeSpan(17, 0, 0)
            };
        }
        _loading = false;
    }

    private string GetStepLabel(int step) => step switch
    {
        1 => "Location",
        2 => "Contact",
        3 => "Availability",
        _ => ""
    };

    private void NextStep()
    {
        if (_currentStep < 3) _currentStep++;
    }

    private void PreviousStep()
    {
        if (_currentStep > 1) _currentStep--;
    }

    private async Task SaveAsync()
    {
        _saving = true;

        ApiResult<Guid> result;
        if (_isNew)
        {
            result = await ContactInfoService.CreateAsync(_model);
        }
        else
        {
            result = await ContactInfoService.UpdateAsync(_model);
        }

        if (result.Success)
        {
            _isNew = false;
            _currentStep = 1; // Reset to start or stay on last? Usually reset or redirect.
        }

        _saving = false;
    }
}
