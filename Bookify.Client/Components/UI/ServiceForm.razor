@using System.ComponentModel.DataAnnotations

<div class="grid md:grid-cols-2 gap-8">

    <!-- Left Column: Basic Information -->
    @if (Step == 0 || Step == 1)
    {
        <div class="bg-white @(Step == 0 ? "border-r-2" : "") p-8 space-y-6 @(Step != 0 ? "col-span-2 md:col-span-1 md:col-start-1 md:col-end-3" : "")">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 flex items-center justify-center bg-blue-100 text-blue-600 rounded-lg">
                    <i class="fas fa-briefcase"></i>
                </div>
                <h2 class="text-xl font-semibold text-gray-800">Basic Information</h2>
            </div>

            <!-- Service Name -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    <i class="fas fa-tag mr-2 text-gray-400"></i> Service Name
                </label>
                <InputText @bind-Value="Model.Name"
                           class="w-full px-4 py-3 border border-gray-300 rounded-xl
                                  focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                                  transition shadow-sm" />
                <ValidationMessage For="@(() => Model.Name)" class="text-red-500 text-sm mt-1" />
            </div>

            <!-- Category -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    <i class="fas fa-layer-group mr-2 text-gray-400"></i> Category
                </label>
                <InputSelect @bind-Value="Model.CategoryId"
                             class="w-full px-4 py-3 border border-gray-300 rounded-xl
                                    focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                                    transition shadow-sm">
                    <option value="">Select a category</option>
                    @foreach (var c in Categories)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => Model.CategoryId)" class="text-red-500 text-sm mt-1" />
            </div>

            <!-- Description -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    <i class="fas fa-align-left mr-2 text-gray-400"></i> Description
                </label>
                <InputTextArea @bind-Value="Model.Description"
                               rows="4"
                               class="w-full px-4 py-3 border border-gray-300 rounded-xl
                                      focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                                      transition shadow-sm resize-none" />
                <ValidationMessage For="@(() => Model.Description)" class="text-red-500 text-sm mt-1" />
            </div>
        </div>
    }

    <!-- Right Column: Pricing & Duration + Availability -->
    @if (Step == 0 || Step == 2)
    {
        <div class="space-y-6 @(Step != 0 ? "col-span-2 md:col-span-1 md:col-start-1 md:col-end-3" : "")">

            <!-- Pricing & Duration -->
            <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-8 space-y-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 flex items-center justify-center bg-green-100 text-green-600 rounded-lg">
                        <i class="fas fa-dollar-sign"></i>
                    </div>
                    <h2 class="text-xl font-semibold text-gray-800">Pricing & Duration</h2>
                </div>

                <div class="grid md:grid-cols-2 gap-6">
                    <!-- Price -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Price</label>
                        <div class="relative">
                            <span class="absolute left-4 top-3.5 text-gray-400">$</span>
                            <InputNumber @bind-Value="Model.Price"
                                         class="w-full pl-8 pr-4 py-3 border border-gray-300 rounded-xl
                                                focus:ring-2 focus:ring-green-500 focus:border-green-500
                                                transition shadow-sm" />
                        </div>
                        <ValidationMessage For="@(() => Model.Price)" class="text-red-500 text-sm mt-1" />
                    </div>

                    <!-- Duration -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Duration (minutes)</label>
                        <div class="relative">
                            <span class="absolute left-4 top-3.5 text-gray-400">
                                <i class="fas fa-clock"></i>
                            </span>
                            <InputNumber @bind-Value="Model.Duration"
                                         class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-xl
                                                focus:ring-2 focus:ring-green-500 focus:border-green-500
                                                transition shadow-sm" />
                        </div>
                        <ValidationMessage For="@(() => Model.Duration)" class="text-red-500 text-sm mt-1" />
                    </div>
                </div>
            </div>

            <!-- Availability -->
            <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-8 space-y-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 flex items-center justify-center bg-purple-100 text-purple-600 rounded-lg">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <h2 class="text-xl font-semibold text-gray-800">Availability</h2>
                </div>

                <div class="grid md:grid-cols-2 gap-6">
                    <!-- Start Time -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Start Time</label>
                        <InputTimeSpan @bind-Value="Model.TimeStart"
                                       CssClass="w-full px-4 py-3 border border-gray-300 rounded-xl
                                                 focus:ring-2 focus:ring-purple-500 focus:border-purple-500
                                                 transition shadow-sm" />
                        <ValidationMessage For="@(() => Model.TimeStart)" class="text-red-500 text-sm mt-1" />
                    </div>

                    <!-- End Time -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">End Time</label>
                        <InputTimeSpan @bind-Value="Model.TimeEnd"
                                       CssClass="w-full px-4 py-3 border border-gray-300 rounded-xl
                                                 focus:ring-2 focus:ring-purple-500 focus:border-purple-500
                                                 transition shadow-sm" />
                        <ValidationMessage For="@(() => Model.TimeEnd)" class="text-red-500 text-sm mt-1" />
                    </div>
                </div>
            </div>

        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public ServiceModel Model { get; set; } = default!;
    [Parameter, EditorRequired] public List<CategoryModel> Categories { get; set; } = new();
    
    /// <summary>
    /// Step 0: Render all fields (e.g. Update Service).
    /// Step 1: Render Basic Information.
    /// Step 2: Render Pricing & Availability.
    /// </summary>
    [Parameter] public int Step { get; set; } = 0;
}