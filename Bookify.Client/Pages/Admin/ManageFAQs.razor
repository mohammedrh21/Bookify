@page "/admin/faqs"
@attribute [Authorize(Roles = "Admin")]
@inject Bookify.Client.Services.IFAQApiService FAQService

<PageTitle>Manage FAQs — Bookify Admin</PageTitle>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Manage FAQs</h1>
            <p class="text-gray-400 mt-1">Create, update, and remove frequently asked questions</p>
        </div>
        <button @onclick="OpenAddForm"
                class="inline-flex items-center px-5 py-2.5 bg-primary-600 text-white font-semibold rounded-xl text-sm hover:bg-primary-700 transition-colors gap-2 shadow-sm">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Add FAQ
        </button>
    </div>

    @if (_showForm)
    {
        <div class="bg-white rounded-2xl border border-primary-200 p-6 mb-8 shadow-sm animate-fade-in relative">
            <h2 class="font-semibold text-gray-900 mb-4">
                @(_isEditing ? "✏️ Edit FAQ" : "➕ New FAQ")
            </h2>
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Question</label>
                    <input @bind="_currentFaq.Question" placeholder="e.g. Do you offer refunds?"
                           class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-300 transition-all font-medium text-gray-900" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Answer</label>
                    <textarea @bind="_currentFaq.Answer" rows="4" placeholder="e.g. Yes, we offer full refunds within 30 days."
                              class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-300 transition-all text-gray-700 resize-none"></textarea>
                </div>
            </div>
            <div class="flex gap-3 mt-6">
                <button @onclick="SaveFaq" disabled="@_saving"
                        class="px-6 py-2.5 bg-primary-600 text-white font-semibold rounded-xl text-sm hover:bg-primary-700 disabled:opacity-60 transition-colors shadow-sm">
                    @(_saving ? "Saving..." : "Save FAQ")
                </button>
                <button @onclick="CancelEdit"
                        class="px-6 py-2.5 text-gray-600 font-semibold rounded-xl text-sm hover:bg-gray-100 transition-colors">
                    Cancel
                </button>
            </div>
        </div>
    }

    @if (_loading)
    {
        <LoadingSpinner Message="Loading FAQs..." />
    }
    else if (_faqs.Count == 0 && !_showForm)
    {
        <EmptyState Icon="📭" Title="No FAQs found" Message="Add your first FAQ to get started." />
    }
    else
    {
        <div class="space-y-4">
            @foreach (var faq in _faqs)
            {
                <div class="bg-white rounded-2xl border border-gray-100 p-6 hover:border-primary-200 hover:shadow-sm transition-all group relative overflow-hidden">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex-1">
                            <h3 class="font-semibold text-gray-900 text-lg mb-2">@faq.Question</h3>
                            <p class="text-gray-600 text-sm leading-relaxed">@faq.Answer</p>
                        </div>
                        
                        <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button @onclick="() => EditFaq(faq)" title="Edit"
                                    class="p-2 text-primary-600 hover:bg-primary-50 rounded-lg transition-colors">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                            </button>
                            <button @onclick="() => DeleteFaq(faq.Id)" title="Delete"
                                    class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition-colors">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Bookify.Client.Models.FAQ.FaqModel> _faqs = [];
    private Bookify.Client.Models.FAQ.FaqModel _currentFaq = new();
    
    private bool _loading = true;
    private bool _showForm = false;
    private bool _saving = false;
    private bool _isEditing = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadFaqsAsync();
    }

    private async Task LoadFaqsAsync()
    {
        _loading = true;
        var result = await FAQService.GetAllAsync();
        _faqs = result.Data ?? [];
        _loading = false;
    }

    private void OpenAddForm()
    {
        _currentFaq = new();
        _isEditing = false;
        _showForm = true;
    }

    private void EditFaq(Bookify.Client.Models.FAQ.FaqModel faq)
    {
        _currentFaq = new Bookify.Client.Models.FAQ.FaqModel
        {
            Id = faq.Id,
            Question = faq.Question,
            Answer = faq.Answer
        };
        _isEditing = true;
        _showForm = true;
        
        // Scroll to top (optional UX improvement)
    }

    private void CancelEdit()
    {
        _showForm = false;
        _currentFaq = new();
    }

    private async Task SaveFaq()
    {
        if (string.IsNullOrWhiteSpace(_currentFaq.Question) || string.IsNullOrWhiteSpace(_currentFaq.Answer)) return;

        _saving = true;
        
        Bookify.Client.Models.ApiResult<bool> result;
        if (_isEditing)
        {
            result = await FAQService.UpdateAsync(_currentFaq);
        }
        else
        {
            result = await FAQService.CreateAsync(_currentFaq);
        }

        if (result.Success)
        {
            await LoadFaqsAsync();
            _showForm = false;
        }

        _saving = false;
    }

    private async Task DeleteFaq(Guid id)
    {
        // Simple confirmation could be added here
        var result = await FAQService.DeleteAsync(id);
        if (result.Success)
        {
            await LoadFaqsAsync();
        }
    }
}
