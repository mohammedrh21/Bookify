@page "/admin/tickets"
@attribute [Authorize(Roles = "Admin")]


<PageTitle>Support Tickets — Bookify Admin</PageTitle>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Support Tickets</h1>
        <p class="text-gray-400 mt-1">View incoming customer support requests</p>
    </div>

    @if (_loading)
    {
        <LoadingSpinner Message="Loading tickets..." />
    }
    else if (_pagedResult.Items.Count() == 0)
    {
        <EmptyState Icon="🎉" Title="No support tickets" Message="Your support queue is empty!" />
    }
    else
    {
        <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-sm">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 border-b border-gray-100">
                        <tr>
                            <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider whitespace-nowrap">Date</th>
                            <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider whitespace-nowrap">Customer Email</th>
                            <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider whitespace-nowrap">Subject</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        @foreach (var ticket in _pagedResult.Items)
                        {
                            var isUnread = !ticket.IsRead;
                            var isExpanded = _expandedTicketId == ticket.Id;
                            
                            <tr class="hover:bg-gray-50/50 transition-colors @(isUnread ? "bg-primary-50/30" : "")">
                                <td class="px-6 py-5 text-sm @(isUnread ? "font-bold text-gray-900" : "font-medium text-gray-600") whitespace-nowrap align-top">
                                    <div class="flex flex-col">
                                        <span>@ticket.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</span>
                                        <span class="text-xs text-gray-400">@ticket.CreatedAt.ToLocalTime().ToString("hh:mm tt")</span>
                                    </div>
                                </td>
                                <td class="px-6 py-5 text-sm @(isUnread ? "font-bold text-gray-900" : "text-gray-600") whitespace-nowrap align-top">
                                    <a href="mailto:@ticket.Email" class="text-primary-600 hover:text-primary-800 hover:underline">
                                        @ticket.Email
                                    </a>
                                </td>
                                <td class="px-6 py-5 text-sm align-top">
                                    <button @onclick="() => ToggleTicket(ticket)" 
                                            class="text-left focus:outline-none group">
                                        <span class="@(isUnread ? "font-bold text-gray-900" : "text-gray-600") @(isExpanded ? "text-primary-600" : "group-hover:text-primary-600") transition-colors max-w-xs truncate block">
                                            @ticket.Subject
                                        </span>
                                        @if (isUnread)
                                        {
                                            <span class="inline-flex items-center mt-1 px-2 py-0.5 rounded text-xs font-medium bg-primary-100 text-primary-800">New</span>
                                        }
                                    </button>
                                </td>
                            </tr>
                            @if (isExpanded)
                            {
                                <tr class="bg-gray-50">
                                    <td colspan="3" class="px-6 py-6 text-sm text-gray-700">
                                        <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm">
                                            <div class="flex justify-between items-start mb-4">
                                                <h3 class="text-lg font-bold text-gray-900">@ticket.Subject</h3>
                                                <button @onclick="() => _expandedTicketId = null" class="text-gray-400 hover:text-gray-600">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </div>
                                            <div class="prose prose-sm max-w-none text-gray-600 whitespace-pre-wrap leading-relaxed">
                                                @ticket.Description
                                            </div>
                                            <div class="mt-6 pt-6 border-t border-gray-100 flex justify-end">
                                                <a href="mailto:@ticket.Email?subject=Re: @ticket.Subject" 
                                                   class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-primary-600 hover:bg-primary-700 transition-colors">
                                                    <i class="fas fa-reply mr-2"></i> Reply to Customer
                                                </a>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            
            @* Pagination Controls *@
            <div class="px-6 py-4 border-t border-gray-50 bg-gray-50/50 flex flex-col sm:flex-row justify-between items-center gap-4">
                <div class="text-sm text-gray-500">
                    Showing <span class="font-medium text-gray-900">@((_pagedResult.PageNumber - 1) * _pagedResult.PageSize + 1)</span> 
                    to <span class="font-medium text-gray-900">@(Math.Min(_pagedResult.PageNumber * _pagedResult.PageSize, _pagedResult.TotalCount))</span> 
                    of <span class="font-medium text-gray-900">@_pagedResult.TotalCount</span> tickets
                </div>
                
                <div class="flex items-center space-x-2">
                    <button @onclick="PreviousPage" 
                            disabled="@(!_pagedResult.HasPreviousPage || _loading)"
                            class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors shadow-sm">
                        <i class="fas fa-chevron-left mr-2"></i> Previous
                    </button>
                    
                    <div class="hidden sm:flex items-center px-4 text-sm font-medium text-gray-600">
                        Page @_pagedResult.PageNumber of @_pagedResult.TotalPages
                    </div>
                    
                    <button @onclick="NextPage" 
                            disabled="@(!_pagedResult.HasNextPage || _loading)"
                            class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors shadow-sm">
                        Next <i class="fas fa-chevron-right ml-2"></i>
                    </button>
                </div>
            </div>
        </div>
    }
</div>



