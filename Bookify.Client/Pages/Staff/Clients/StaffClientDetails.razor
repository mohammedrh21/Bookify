@page "/staff/clients/{ClientId:guid}"
@attribute [Authorize(Policy = "StaffOnly")]

<PageTitle>Client Profile — Bookify Staff</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <button @onclick="NavigateBack" class="mb-6 inline-flex items-center text-sm font-medium text-gray-500 hover:text-primary-600 transition-colors">
        <i class="fa-solid fa-arrow-left mr-2"></i>
        Back to Clients
    </button>

    @if (_loading)
    {
        <LoadingSpinner Message="Loading client details..." />
    }
    else if (_details == null)
    {
        <EmptyState Icon="⚠️" Title="Client Not Found"
                    Message="This client could not be found or you don't have permission to view them." />
    }
    else
    {
        @* ── Header Profile ──────────────────────────────────────────── *@
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 sm:p-8 mb-8 flex flex-col sm:flex-row items-center gap-6">
            @if (!string.IsNullOrEmpty(_details.ImagePath))
            {
                <img src="@_details.ImagePath" class="w-24 h-24 rounded-full object-cover border-4 border-white shadow-md ring-1 ring-gray-100" alt="@_details.FullName" />
            }
            else
            {
                <div class="w-24 h-24 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center font-bold text-3xl shadow-md border-4 border-white ring-1 ring-gray-100">
                    @GetInitials(_details.FullName)
                </div>
            }

            <div class="flex-1 text-center sm:text-left">
                <h1 class="text-3xl font-bold text-gray-900 mb-2">@_details.FullName</h1>
                <div class="flex flex-col sm:flex-row gap-4 justify-center sm:justify-start text-gray-600">
                    <div class="flex items-center gap-2">
                        <i class="fa-solid fa-envelope text-gray-400"></i>
                        <span>@_details.Email</span>
                    </div>
                    @if (!string.IsNullOrEmpty(_details.Phone))
                    {
                        <div class="flex items-center gap-2">
                            <i class="fa-solid fa-phone text-gray-400"></i>
                            <span>@_details.Phone</span>
                        </div>
                    }
                </div>
            </div>
            
            <button @onclick="() => ContactClient(_details.Email)" class="px-5 py-2.5 bg-primary-600 text-white rounded-xl shadow-md font-semibold hover:bg-primary-700 transition-transform active:scale-95 flex items-center gap-2">
                <i class="fa-solid fa-paper-plane"></i>
                Message Client
            </button>
        </div>

        @* ── Statistics Grid ──────────────────────────────────────────── *@
        <h2 class="text-xl font-bold text-gray-900 mb-4">Overall Performance</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
            <div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm flex flex-col items-center justify-center text-center">
                <div class="w-10 h-10 rounded-full bg-blue-50 text-blue-500 flex items-center justify-center mb-3">
                    <i class="fa-solid fa-calendar-check text-lg"></i>
                </div>
                <p class="text-3xl font-bold text-gray-900">@_details.TotalBookings</p>
                <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mt-1">Total</p>
            </div>
            
            <div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm flex flex-col items-center justify-center text-center">
                <div class="w-10 h-10 rounded-full bg-green-50 text-green-500 flex items-center justify-center mb-3">
                    <i class="fa-solid fa-check-double text-lg"></i>
                </div>
                <p class="text-3xl font-bold text-gray-900">@_details.CompletedBookings</p>
                <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mt-1">Completed</p>
            </div>

            <div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm flex flex-col items-center justify-center text-center">
                <div class="w-10 h-10 rounded-full bg-orange-50 text-orange-500 flex items-center justify-center mb-3">
                    <i class="fa-solid fa-clock-rotate-left text-lg"></i>
                </div>
                <p class="text-3xl font-bold text-gray-900">@_details.UpcomingBookings</p>
                <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mt-1">Upcoming</p>
            </div>
            
            <div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm flex flex-col items-center justify-center text-center">
                <div class="w-10 h-10 rounded-full bg-red-50 text-red-500 flex items-center justify-center mb-3">
                    <i class="fa-solid fa-ban text-lg"></i>
                </div>
                <p class="text-3xl font-bold text-gray-900">@_details.CancelledBookings</p>
                <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mt-1">Cancelled</p>
            </div>

            <div class="bg-gradient-to-br from-gray-900 to-gray-800 p-5 rounded-2xl shadow-lg flex flex-col items-center justify-center text-center">
                <div class="w-10 h-10 rounded-full bg-white/10 text-emerald-400 flex items-center justify-center mb-3">
                    <i class="fa-solid fa-dollar-sign text-lg"></i>
                </div>
                <p class="text-3xl font-bold text-white">$@_details.TotalRevenue.ToString("F0")</p>
                <p class="text-xs text-gray-300 uppercase tracking-wider font-semibold mt-1">LTV (Revenue)</p>
            </div>
        </div>

        @* ── Booking History ──────────────────────────────────────────── *@
        <h2 class="text-xl font-bold text-gray-900 mb-4">Service History</h2>
        @if (!_details.Bookings.Any())
        {
            <div class="bg-white rounded-2xl p-8 text-center text-gray-500 border border-gray-100 shadow-sm">
                No booking history found for this client.
            </div>
        }
        else
        {
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-50 border-b border-gray-100 text-gray-500 text-sm font-medium uppercase tracking-wider">
                                <th class="px-6 py-4">Date</th>
                                <th class="px-6 py-4">Price</th>
                                <th class="px-6 py-4">Payment</th>
                                <th class="px-6 py-4">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var booking in _details.Bookings)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="font-medium text-gray-900">@booking.Date.ToString("MMM dd, yyyy")</div>
                                        <div class="text-xs text-gray-500">@booking.Date.ToString("hh:mm tt")</div>
                                    </td>
                                    <td class="px-6 py-4 font-medium text-gray-900">
                                        $@booking.Price.ToString("F2")
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="@GetPaymentBadgeClass(booking.PaymentStatus)">
                                            @booking.PaymentStatus
                                        </span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <StatusBadge Status="@booking.Status" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>
