@using Bookify.Client.Models.SupportTicket
@inject ITicketApiService TicketService

<div class="bg-gray-900 rounded-[2rem] p-8 md:p-10 shadow-2xl relative overflow-hidden group h-full">
    <div class="absolute top-0 right-0 w-64 h-64 bg-primary-600/30 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none transition-opacity duration-700 group-hover:opacity-100"></div>
    
    <div class="relative z-10">
        @if (_ticketSubmitted)
        {
            <div class="text-center py-12 animate-fade-in">
                <div class="w-20 h-20 bg-gradient-to-br from-green-400 to-green-500 text-white rounded-full flex items-center justify-center mx-auto mb-6 text-4xl shadow-lg shadow-green-500/30 ring-8 ring-green-900/20">
                    ✓
                </div>
                <h3 class="text-2xl font-bold text-white mb-3">Ticket Submitted!</h3>
                <p class="text-gray-400 mb-8 max-w-sm mx-auto">
                    We've received your request. Our support champions will review it and get back to you shortly.
                </p>
                <button @onclick="ResetForm"
                        class="px-8 py-3 bg-white text-gray-900 hover:bg-gray-100 rounded-xl font-bold transition-all hover:-translate-y-0.5 transform">
                    Submit another ticket
                </button>
            </div>
        }
        else
        {
            <h2 class="text-2xl font-bold text-white mb-6">Support Ticket</h2>
            <EditForm Model="_ticketModel" OnValidSubmit="HandleSubmit" class="space-y-5">
                <DataAnnotationsValidator />
                
                <div class="space-y-1.5">
                    <label class="block text-sm font-medium text-gray-400 ml-1">Email Address</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-500">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <InputText @bind-Value="_ticketModel.Email" 
                                   class="w-full pl-11 pr-4 py-3 bg-gray-800 border-0 rounded-xl focus:ring-2 focus:ring-primary-500 text-white placeholder-gray-500 transition-all font-medium"
                                   placeholder="your@email.com" />
                    </div>
                    <ValidationMessage For="@(() => _ticketModel.Email)" class="text-red-400 text-xs mt-1 ml-1" />
                </div>

                <div class="space-y-1.5">
                    <label class="block text-sm font-medium text-gray-400 ml-1">Subject</label>
                    <InputText @bind-Value="_ticketModel.Subject" 
                               class="w-full px-4 py-3 bg-gray-800 border-0 rounded-xl focus:ring-2 focus:ring-primary-500 text-white placeholder-gray-500 transition-all font-medium"
                               placeholder="Brief summary of your issue" />
                    <ValidationMessage For="@(() => _ticketModel.Subject)" class="text-red-400 text-xs mt-1 ml-1" />
                </div>

                <div class="space-y-1.5">
                    <label class="block text-sm font-medium text-gray-400 ml-1">Description</label>
                    <InputTextArea @bind-Value="_ticketModel.Description" rows="4"
                                   class="w-full px-4 py-3 bg-gray-800 border-0 rounded-xl focus:ring-2 focus:ring-primary-500 text-white placeholder-gray-500 transition-all resize-none font-medium"
                                   placeholder="How can we help you today?" />
                    <ValidationMessage For="@(() => _ticketModel.Description)" class="text-red-400 text-xs mt-1 ml-1" />
                </div>

                <div class="pt-2">
                    <button type="submit" disabled="@_submitting"
                            class="w-full py-4 px-6 bg-primary-600 hover:bg-primary-500 text-white rounded-xl font-bold shadow-lg hover:shadow-primary-500/25 transition-all outline-none flex items-center justify-center gap-2 group disabled:opacity-70">
                        @if (_submitting)
                        {
                            <div class="animate-spin h-5 w-5 border-2 border-white border-t-transparent rounded-full"></div>
                            <span>Sending...</span>
                        }
                        else
                        {
                            <span>Submit Ticket</span>
                            <i class="fas fa-paper-plane text-sm group-hover:translate-x-1 transition-transform"></i>
                        }
                    </button>
                </div>
                
                <p class="text-center text-gray-500 text-xs mt-4">
                    Limit 1 ticket / email / day. Your request is secure.
                </p>
            </EditForm>
        }
    </div>
</div>

@code {
    private TicketModel _ticketModel = new();
    private bool _submitting = false;
    private bool _ticketSubmitted = false;

    private async Task HandleSubmit()
    {
        _submitting = true;
        
        var result = await TicketService.SubmitAsync(_ticketModel);
        
        if (result.Success)
        {
            _ticketSubmitted = true;
        }
        
        _submitting = false;
    }

    private void ResetForm()
    {
        _ticketModel = new();
        _ticketSubmitted = false;
    }
}
