@page "/"
@inject ICategoryService   CategoryService
@inject IServiceApiService ServiceService
<PageTitle>Bookify — Book Services Online</PageTitle>
<div class="w-full">

    <!-- ================= HERO SECTION ================= -->
    <section class="relative bg-gradient-to-br from-primary-50 via-white to-blue-50 overflow-hidden">
        <!-- Background Decorative Blobs -->
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 bg-primary-200 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob"></div>
        <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-72 h-72 bg-indigo-200 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob animation-delay-2000"></div>

        <div class="relative z-10 max-w-7xl mx-auto px-6 py-20 lg:py-32 grid md:grid-cols-2 gap-12 items-center">
            <div class="animate-fadeIn">
                <h1 class="outline-none text-5xl lg:text-6xl font-extrabold text-slate-800 leading-tight tracking-tight">
                    Publish Your Services.<br />
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-indigo-600">Get Booked Instantly.</span>
                </h1>

                <p class="mt-6 text-lg text-slate-500 max-w-lg">
                    Our platform connects professional service providers with clients looking for trusted solutions.
                    Manage bookings, grow your business, and reach more customers effortlessly.
                </p>

                <div class="mt-10 flex flex-wrap gap-4">
                    <a href="/register"
                       class="px-8 py-4 bg-gradient-to-r from-primary-600 to-indigo-600 text-white font-bold rounded-2xl shadow-lg shadow-primary-500/30 hover:shadow-primary-500/50 transition-all hover-lift">
                        Join as Provider
                    </a>

                    <a href="/services"
                       class="px-8 py-4 bg-white text-slate-700 font-semibold rounded-2xl border border-slate-200 hover:bg-slate-50 hover:border-slate-300 transition-all shadow-sm">
                        Browse Services
                    </a>
                </div>
            </div>

            <div class="relative hover-lift">
                <div class="absolute inset-0 bg-gradient-to-tr from-primary-400 to-indigo-400 rounded-3xl transform rotate-3 scale-105 opacity-20 -z-10 blur-lg"></div>
                <img src="images/hero3.png" class="rounded-3xl shadow-2xl border border-white/50 relative z-10 w-full object-cover">
            </div>
        </div>
    </section>
    <!-- ================= HOW IT WORKS ================= -->
    <section class="bg-slate-50 border-y border-slate-100 py-24">
        <div class="max-w-7xl mx-auto px-6 text-center">

            <h2 class="text-3xl lg:text-4xl font-extrabold text-slate-800">
                Booking Made <span class="text-primary-600">Simple</span>
            </h2>
            <p class="text-slate-500 mt-4 max-w-2xl mx-auto">Three easy steps to secure your appointment without the hassle.</p>

            <div class="mt-16 grid md:grid-cols-3 gap-8">
                <!-- Step 1 -->
                <div class="glass p-8 rounded-3xl hover-lift text-left relative overflow-hidden group">
                    <div class="absolute -right-6 -top-6 w-24 h-24 bg-primary-50 rounded-full group-hover:scale-150 transition-transform duration-500 ease-in-out"></div>
                    <div class="relative z-10">
                        <div class="w-14 h-14 bg-white rounded-2xl shadow-sm border border-gray-100 flex items-center justify-center text-2xl text-primary-600 mb-6 font-bold">
                            1
                        </div>
                        <h3 class="text-xl font-bold text-slate-800">Providers Publish</h3>
                        <p class="mt-3 text-slate-500 leading-relaxed">
                            Create your service profile, set pricing, availability and start reaching clients instantly.
                        </p>
                    </div>
                </div>

                <!-- Step 2 -->
                <div class="glass p-8 rounded-3xl hover-lift text-left relative overflow-hidden group md:translate-y-4">
                    <div class="absolute -right-6 -top-6 w-24 h-24 bg-indigo-50 rounded-full group-hover:scale-150 transition-transform duration-500 ease-in-out"></div>
                    <div class="relative z-10">
                        <div class="w-14 h-14 bg-white rounded-2xl shadow-sm border border-gray-100 flex items-center justify-center text-2xl text-indigo-600 mb-6 font-bold">
                            2
                        </div>
                        <h3 class="text-xl font-bold text-slate-800">Clients Book</h3>
                        <p class="mt-3 text-slate-500 leading-relaxed">
                            Browse categories, compare providers, read reviews and book online in seconds.
                        </p>
                    </div>
                </div>

                <!-- Step 3 -->
                <div class="glass p-8 rounded-3xl hover-lift text-left relative overflow-hidden group md:translate-y-8">
                    <div class="absolute -right-6 -top-6 w-24 h-24 bg-blue-50 rounded-full group-hover:scale-150 transition-transform duration-500 ease-in-out"></div>
                    <div class="relative z-10">
                        <div class="w-14 h-14 bg-white rounded-2xl shadow-sm border border-gray-100 flex items-center justify-center text-2xl text-blue-600 mb-6 font-bold">
                            3
                        </div>
                        <h3 class="text-xl font-bold text-slate-800">Admin Manages</h3>
                        <p class="mt-3 text-slate-500 leading-relaxed">
                            Access a full control panel to seamlessly manage users, bookings, and track performance.
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </section>
    <!-- ================= FOR PROVIDERS ================= -->
    <section class="py-24 max-w-7xl mx-auto px-6">
        <div class="bg-gradient-to-br from-slate-900 to-slate-800 rounded-3xl p-10 lg:p-16 flex flex-col md:flex-row items-center gap-12 shadow-2xl relative overflow-hidden">
            <!-- Decorative circle -->
            <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary-500 rounded-full mix-blend-overlay filter blur-3xl opacity-30"></div>

            <div class="w-full md:w-1/2 rounded-2xl overflow-hidden shadow-2xl z-10 border border-slate-700 hover-lift relative">
                 <div class="absolute inset-0 bg-gradient-to-tr from-primary-500 to-indigo-500 mix-blend-overlay opacity-20"></div>
                 <img src="images/hero2.jpg" class="w-full object-cover">
            </div>

            <div class="flex-1 z-10 text-center md:text-left">
                <h2 class="text-3xl lg:text-4xl font-extrabold text-white">
                    Grow Your Business With Us
                </h2>

                <ul class="mt-8 space-y-4 text-slate-300">
                    <li class="flex items-center gap-3 justify-center md:justify-start">
                        <i class="fa-solid fa-circle-check text-emerald-400"></i> Publish unlimited services
                    </li>
                    <li class="flex items-center gap-3 justify-center md:justify-start">
                        <i class="fa-solid fa-circle-check text-emerald-400"></i> Manage bookings in one dashboard
                    </li>
                    <li class="flex items-center gap-3 justify-center md:justify-start">
                        <i class="fa-solid fa-circle-check text-emerald-400"></i> Increase your online visibility
                    </li>
                    <li class="flex items-center gap-3 justify-center md:justify-start">
                        <i class="fa-solid fa-circle-check text-emerald-400"></i> Track revenue and performance analytics
                    </li>
                </ul>

                <div class="mt-10">
                    <a href="/register"
                       class="inline-block px-8 py-4 bg-gradient-to-r from-primary-500 to-indigo-500 text-white font-bold rounded-2xl shadow-lg hover:shadow-primary-500/50 transition-all hover-lift">
                        Become a Provider
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- ================= TRUST SECTION ================= -->
    <section class="bg-slate-50 border-t border-slate-100 py-24">
        <div class="max-w-6xl mx-auto px-6 text-center">

            <h2 class="text-3xl lg:text-4xl font-extrabold text-slate-800">Why Clients <span class="text-primary-600">Trust Us</span></h2>
            <p class="text-slate-500 mt-4 max-w-2xl mx-auto">We prioritize safety, convenience, and quality in every booking.</p>

            <div class="mt-16 grid md:grid-cols-3 gap-8">
                <div class="p-8 bg-white rounded-3xl shadow-soft hover-lift transition">
                    <div class="w-16 h-16 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center text-3xl mx-auto mb-6">
                        <i class="fa-solid fa-shield-halved"></i>
                    </div>
                    <h4 class="text-xl font-bold text-slate-800">Verified Providers</h4>
                    <p class="mt-3 text-slate-500">Every service professional is thoroughly reviewed and approved before joining.</p>
                </div>

                <div class="p-8 bg-white rounded-3xl shadow-soft hover-lift transition">
                    <div class="w-16 h-16 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center text-3xl mx-auto mb-6">
                        <i class="fa-solid fa-lock"></i>
                    </div>
                    <h4 class="text-xl font-bold text-slate-800">Secure Booking</h4>
                    <p class="mt-3 text-slate-500">Your data and appointments are handled with bank-level security and privacy.</p>
                </div>

                <div class="p-8 bg-white rounded-3xl shadow-soft hover-lift transition">
                    <div class="w-16 h-16 bg-purple-50 text-purple-600 rounded-full flex items-center justify-center text-3xl mx-auto mb-6">
                        <i class="fa-regular fa-comments"></i>
                    </div>
                    <h4 class="text-xl font-bold text-slate-800">Easy Communication</h4>
                    <p class="mt-3 text-slate-500">Connect directly with professionals to discuss your unique needs and preferences.</p>
                </div>
            </div>
        </div>
    </section>
    <!-- ── Categories ─────────────────────────────────────────────────────────── -->
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-10">
                <h2 class="text-3xl font-bold text-gray-900">Browse by Category</h2>
                <p class="text-gray-400 mt-2">Find the service that fits your needs</p>
            </div>

            @if (_loadingCategories)
            {
                <LoadingSpinner Message="Loading categories..." />
            }
            else if (_categories.Count == 0)
            {
                <EmptyState Icon="🗂️" Title="No categories yet" Message="Check back soon." />
            }
            else
            {
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
                    @foreach (var cat in _categories)
                    {
                        <CategoryCard Category="cat"
                                      IsSelected="_selectedCategoryId == cat.Id"
                                      OnClick="() => SelectCategory(cat.Id)" />
                    }
                </div>
            }
        </div>
    </section>

    <!-- ================= FINAL CTA ================= -->
    <section class="bg-sky-600 text-white py-20 text-center">
        <div class="max-w-4xl mx-auto px-6">

            <h2 class="text-4xl font-bold">
                Start Growing or Start Booking Today
            </h2>

            <p class="mt-6 text-lg text-sky-100">
                Join our professional service booking platform and become part of a trusted network.
            </p>

            <div class="mt-8 flex justify-center gap-6 flex-wrap">
                <a href="/register"
                   class="px-8 py-4 bg-white text-sky-600 font-semibold rounded-xl shadow hover:bg-gray-100 transition">
                    Create Account
                </a>

                <a href="/contact"
                   class="px-8 py-4 border border-white rounded-xl hover:bg-sky-700 transition">
                    Contact Us
                </a>
            </div>
        </div>
    </section>
</div>

<!-- ── Featured Services ──────────────────────────────────────────────────── -->
<section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-10">
            <div>
                <h2 class="text-3xl font-bold text-gray-900">Featured Services</h2>
                <p class="text-gray-400 mt-1">Popular services available right now</p>
            </div>
            <a href="/services"
               class="text-primary-600 hover:text-primary-700 font-semibold text-sm flex items-center gap-1">
                View all
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </a>
        </div>

        @if (_loadingServices)
        {
            <LoadingSpinner />
        }
        else if (_services.Count == 0)
        {
            <EmptyState Icon="🛎️" Title="No services yet" Message="Services will appear here soon." />
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                @foreach (var svc in _services.Where(x=>!x.IsDeleted).Take(8))
                {
                    <ServiceCard Service="svc" />
                }
            </div>
        }
    </div>
</section>



@code {
    private List<CategoryModel> _categories        = [];
    private List<ServiceModel>  _allServices       = [];
    private bool                _loadingCategories = true;
    private bool                _loadingServices   = true;
    private Guid?               _selectedCategoryId;

    private List<ServiceModel> _services => _selectedCategoryId.HasValue
        ? _allServices.Where(s => s.CategoryId == _selectedCategoryId.Value && !s.IsDeleted).ToList()
        : _allServices.Where(s => !s.IsDeleted).ToList();

    private readonly (string Icon, string Title, string Desc)[] _features =
    [
        ("📅", "Easy Scheduling",      "Book appointments in just a few clicks with real-time availability."),
        ("🔔", "Instant Confirmation", "Get immediate booking confirmations right after you book."),
        ("💼", "Professional Staff",   "All staff are vetted professionals in their fields."),
        ("🔒", "Secure & Private",     "Your data is encrypted and protected at all times."),
        ("📊", "Booking Management",   "Track, reschedule, or cancel your bookings with ease."),
        ("⭐", "Quality Guaranteed",   "We ensure all services meet our high-quality standards."),
    ];

    protected override async Task OnInitializedAsync()
    {
        var catTask = CategoryService.GetAllAsync();
        var svcTask = ServiceService.GetAllAsync();

        var catResult = await catTask;
        _categories = catResult.Data ?? [];
        _loadingCategories = false;

        var svcResult = await svcTask;
        _allServices = svcResult.Data ?? [];
        _loadingServices = false;
    }

    private void SelectCategory(Guid id)
    {
        _selectedCategoryId = _selectedCategoryId == id ? null : id;
    }
}
