@page "/booking/service-bookings"
@attribute [Authorize(Roles = "Staff")]
@inject IBookingService BookingService
@inject IAuthService AuthService
@inject NavigationManager Nav

<PageTitle>Booking History — Bookify Staff</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Service Bookings</h1>
    </div>

    @if (_loading)
    {
        <LoadingSpinner Message="Loading your bookings..." />
    }
    else if (_bookings == null || !_bookings.Any())
    {
        <EmptyState Icon="📅" Title="No bookings found"
                    Message="You haven't received any service bookings yet." />
    }
    else
    {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-50 border-b border-gray-100 text-gray-500 text-sm font-medium uppercase tracking-wider">
                            <th class="px-6 py-4">Service</th>
                            <th class="px-6 py-4">Client Name</th>
                            <th class="px-6 py-4">Date & Time</th>
                            <th class="px-6 py-4">Duration</th>
                            <th class="px-6 py-4">Price</th>
                            <th class="px-6 py-4">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var booking in _bookings)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-5">
                                    <div class="font-semibold text-gray-900">@booking.ServiceName</div>
                                </td>
                                <td class="px-6 py-5 text-gray-600">
                                    <div class="flex items-center gap-2">
                                        <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs">
                                            @GetInitials(booking.ClientName)
                                        </div>
                                        <span>@booking.ClientName</span>
                                    </div>
                                </td>
                                <td class="px-6 py-5">
                                    <div class="text-gray-900 font-medium">@booking.Date.ToString("MMM dd, yyyy")</div>
                                    <div class="text-gray-500 text-sm">@booking.Time.ToString(@"hh\:mm")</div>
                                </td>
                                <td class="px-6 py-5 text-gray-600">
                                    @booking.DurationMinutes min
                                </td>
                                <td class="px-6 py-5 font-medium text-gray-900">
                                    $@booking.Price.ToString("F2")
                                </td>
                                <td class="px-6 py-5">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold
                                        @(booking.Status.Equals("Confirmed", StringComparison.OrdinalIgnoreCase) ? "bg-green-100 text-green-800" :
                                          booking.Status.Equals("Pending", StringComparison.OrdinalIgnoreCase) ? "bg-yellow-100 text-yellow-800" :
                                          booking.Status.Equals("Cancelled", StringComparison.OrdinalIgnoreCase) ? "bg-red-100 text-red-800" :
                                          "bg-gray-100 text-gray-800")">
                                        @booking.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<BookingModel>? _bookings;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var staffId = await AuthService.GetUserIdAsync();
        if (staffId.HasValue)
        {
            var result = await BookingService.GetStaffBookingsAsync(staffId.Value);
            _bookings = result.Data?.OrderByDescending(b => b.Date).ThenByDescending(b => b.Time).ToList();
        }
        
        _loading = false;
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }
}
