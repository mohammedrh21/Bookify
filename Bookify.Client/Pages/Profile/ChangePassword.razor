@page "/profile/change-password"
@using Bookify.Client.Models.Profile
@attribute [Authorize]

<PageTitle>Change Password — Bookify</PageTitle>

<div class="fixed inset-0 z-[-1] pointer-events-none bg-gray-50/50">
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-amber-600/5 blur-[120px]"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-orange-600/5 blur-[120px]"></div>
</div>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    
    <!-- Header -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-amber-100 text-amber-700 text-xs font-bold uppercase tracking-wider mb-3">
                <i class="fas fa-shield-alt"></i> Security
            </div>
            <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">Change Password</h1>
            <p class="text-gray-500 mt-2 text-lg">Update your security credentials to protect your account.</p>
        </div>
    </div>

    @if (_loading)
    {
        <div class="bg-white/80 backdrop-blur-xl rounded-[2.5rem] border border-gray-100 shadow-xl p-10 flex flex-col items-center justify-center min-h-[400px] animate-pulse">
            <div class="w-16 h-16 bg-amber-100 rounded-full mb-4"></div>
            <div class="h-4 w-48 bg-gray-100 rounded mb-2"></div>
            <div class="h-3 w-32 bg-gray-50 rounded"></div>
        </div>
    }
    else
    {
        <div class="bg-white/80 backdrop-blur-xl rounded-[2.5rem] border border-gray-100 shadow-xl shadow-gray-200/40 p-8 md:p-12 relative overflow-hidden transition-all duration-500 hover:shadow-2xl hover:shadow-amber-500/10 group">
            <!-- Decorative Glow -->
            <div class="absolute top-0 right-0 w-64 h-64 bg-amber-500/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3 group-hover:scale-110 transition-transform duration-700"></div>
            
            <div class="flex items-center gap-5 mb-10 relative z-10">
                <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-amber-100 to-orange-100 flex items-center justify-center text-amber-600 text-2xl shadow-inner group-hover:rotate-12 transition-transform">
                    <i class="fas fa-key"></i>
                </div>
                <div>
                    <h2 class="text-2xl font-black text-gray-900">Security Credentials</h2>
                    <p class="text-sm text-gray-500 font-medium">Please enter your current and new password below.</p>
                </div>
            </div>

            <div class="space-y-8 relative z-10">
                <!-- Current Password -->
                <div class="relative group/field">
                    <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2.5 ml-1 group-focus-within/field:text-amber-500 transition-colors">Current Password</label>
                    <div class="relative flex items-center">
                        <div class="absolute left-5 text-gray-400 group-focus-within/field:text-amber-500 transition-colors pointer-events-none">
                            <i class="fas fa-lock text-lg"></i>
                        </div>
                        <input type=@(_showCurrent ? "text" : "password") @bind="_pwd.CurrentPassword"
                               class="w-full pl-14 pr-14 py-4 bg-gray-50/50 rounded-2xl border-2 border-transparent focus:bg-white focus:border-amber-500 focus:ring-8 focus:ring-amber-500/5 outline-none transition-all text-gray-900 font-bold placeholder-gray-400 text-lg shadow-sm" placeholder="••••••••" />
                        <button type="button" @onclick="() => _showCurrent = !_showCurrent" 
                                class="absolute right-5 text-gray-400 hover:text-amber-600 transition-colors w-8 h-8 flex items-center justify-center rounded-xl hover:bg-amber-50">
                            <i class="fas @(_showCurrent ? "fa-eye-slash" : "fa-eye")"></i>
                        </button>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-4">
                    <!-- New Password -->
                    <div class="relative group/field">
                        <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2.5 ml-1 group-focus-within/field:text-amber-500 transition-colors">New Password</label>
                        <div class="relative flex items-center">
                            <div class="absolute left-5 text-gray-400 group-focus-within/field:text-amber-500 transition-colors pointer-events-none">
                                <i class="fas fa-shield-alt text-lg"></i>
                            </div>
                            <input type=@(_showNew ? "text" : "password") @bind="_pwd.NewPassword"
                                   class="w-full pl-14 pr-14 py-4 bg-gray-50/50 rounded-2xl border-2 border-transparent focus:bg-white focus:border-amber-500 focus:ring-8 focus:ring-amber-500/5 outline-none transition-all text-gray-900 font-bold placeholder-gray-400 text-lg shadow-sm" placeholder="••••••••" />
                            <button type="button" @onclick="() => _showNew = !_showNew" 
                                    class="absolute right-5 text-gray-400 hover:text-amber-600 transition-colors w-8 h-8 flex items-center justify-center rounded-xl hover:bg-amber-50">
                                <i class="fas @(_showNew ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div class="relative group/field">
                        <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2.5 ml-1 group-focus-within/field:text-amber-500 transition-colors">Confirm Password</label>
                        <div class="relative flex items-center">
                            <div class="absolute left-5 text-gray-400 group-focus-within/field:text-amber-500 transition-colors pointer-events-none">
                                <i class="fas fa-check-double text-lg"></i>
                            </div>
                            <input type=@(_showConfirm ? "text" : "password") @bind="_pwd.ConfirmPassword"
                                   class="w-full pl-14 pr-14 py-4 bg-gray-50/50 rounded-2xl border-2 border-transparent focus:bg-white focus:border-amber-500 focus:ring-8 focus:ring-amber-500/5 outline-none transition-all text-gray-900 font-bold placeholder-gray-400 text-lg shadow-sm" placeholder="••••••••" />
                            <button type="button" @onclick="() => _showConfirm = !_showConfirm" 
                                    class="absolute right-5 text-gray-400 hover:text-amber-600 transition-colors w-8 h-8 flex items-center justify-center rounded-xl hover:bg-amber-50">
                                <i class="fas @(_showConfirm ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_pwdError))
                {
                    <div class="p-5 rounded-2xl bg-red-50 border-2 border-red-100 flex items-start gap-4 text-red-600 shadow-sm animate-shake">
                        <div class="w-10 h-10 bg-red-100 rounded-xl flex items-center justify-center shrink-0">
                            <i class="fas fa-exclamation-triangle text-lg"></i>
                        </div>
                        <p class="text-sm font-bold leading-relaxed pt-2">@_pwdError</p>
                    </div>
                }

                <div class="pt-6 flex flex-col sm:flex-row gap-4 justify-end">
                    <button @onclick="ChangePasswordAsync" disabled="@_changingPwd"
                            class="w-full sm:w-auto px-10 py-4.5 bg-gray-900 text-white font-black text-lg rounded-2xl hover:bg-black transition-all shadow-xl shadow-gray-900/20 hover:-translate-y-1 hover:shadow-gray-900/40 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0 relative overflow-hidden group/btn">
                        <div class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover/btn:translate-x-full transition-transform duration-1000 ease-in-out"></div>
                        <div class="relative flex items-center justify-center gap-3">
                            @if (_changingPwd)
                            {
                                <i class="fas fa-circle-notch animate-spin"></i>
                                <span>Updating...</span>
                            }
                            else
                            {
                                <i class="fas fa-lock text-amber-400"></i>
                                <span>Update Password</span>
                            }
                        </div>
                    </button>
                    
                    <button @onclick="GoBack" type="button"
                            class="w-full sm:w-auto px-8 py-4.5 bg-white text-gray-500 font-bold rounded-2xl hover:bg-gray-50 border border-gray-100 transition-all">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Safety Note -->
        <div class="mt-8 flex items-center gap-3 justify-center text-gray-400">
            <i class="fas fa-info-circle"></i>
            <p class="text-xs font-semibold uppercase tracking-widest">End-to-end encrypted security</p>
        </div>
    }
</div>
