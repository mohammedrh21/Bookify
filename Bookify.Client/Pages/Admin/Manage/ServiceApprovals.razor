@page "/admin/service-approvals"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Service Approvals — Bookify</PageTitle>

<div class="max-w-[1600px] mx-auto px-3 py-8">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Service Approvals</h1>
            <p class="text-gray-500 mt-1">Review and manage service proposals from staff members</p>
        </div>
    </div>

    @* Top Bar: Search & Pagination *@
    <div class="bg-white border rounded-2xl shadow-sm mb-6 p-4 flex flex-wrap items-center justify-between gap-4">
        <div class="relative flex-1 min-w-[300px]">
             <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                <i class="fa-solid fa-magnifying-glass"></i>
            </span>
            <input type="text" 
                   class="block w-full pl-10 pr-3 py-2.5 border border-gray-200 rounded-xl leading-5 bg-gray-50 placeholder-gray-400 focus:outline-none focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all sm:text-sm" 
                   placeholder="Search by staff or service name..."
                   value="@_searchText"
                   @oninput="OnSearchInput" />
        </div>
        
        <div class="flex items-center gap-4">
            <Pagination CurrentPage="_currentPage" 
                        TotalPages="TotalPages" 
                        TotalCount="TotalCount" 
                        OnPageChanged="HandlePageChanged" />
        </div>
    </div>

    @if (_loading)
    {
        <LoadingSpinner Message="Fetching requests..." />
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-10 gap-6 h-[calc(100vh-280px)] min-h-[600px]">
            @* Left Sidebar (30%) *@
            <div class="lg:col-span-3 flex flex-col bg-white border border-gray-100 rounded-3xl shadow-sm overflow-hidden">
                <div class="p-4 border-b border-gray-50 bg-gray-50/50">
                    <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest">Pending Requests (@TotalCount)</h3>
                </div>
                
                <div class="flex-1 overflow-y-auto custom-scrollbar">
                    @if (!PagedRequests.Any())
                    {
                        <div class="flex flex-col items-center justify-center p-8 text-center h-full opacity-60">
                            <i class="fa-solid fa-inbox text-4xl mb-3 text-gray-300"></i>
                            @if (!string.IsNullOrWhiteSpace(_searchText))
                            {
                                <p class="text-sm font-medium text-gray-500">No requests match "@_searchText"</p>
                                <button @onclick='() => _searchText = ""' class="mt-2 text-blue-600 text-xs font-bold hover:underline">Clear Search</button>
                            }
                            else
                            {
                                <p class="text-sm font-medium text-gray-500">No pending requests found</p>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="divide-y divide-gray-50">
                            @foreach (var req in PagedRequests)
                            {
                                <button @onclick="() => SelectRequest(req)" 
                                        disabled="@_isProcessing"
                                        class="@($"w-full text-left p-5 transition-all outline-none border-l-4 {( _selectedRequest?.Id == req.Id ? "bg-blue-50/50 border-blue-600" : "hover:bg-gray-50 border-transparent")}")">
                                    <div class="flex items-start justify-between gap-2 mb-2">
                                        <span class="@($"px-2 py-0.5 text-[10px] font-bold uppercase rounded-full {(req.Type == ApprovalRequestType.Create ? "bg-green-100 text-green-700" : "bg-blue-100 text-blue-700")}")">
                                            @req.Type
                                        </span>
                                        <span class="text-[10px] text-gray-400 font-medium">@req.CreatedAt.ToString("MMM dd, HH:mm")</span>
                                    </div>
                                    <h4 class="font-bold text-gray-900 truncate mb-1">@req.ProposedDetails.Name</h4>
                                    <div class="flex items-center gap-1.5 text-xs text-gray-500">
                                        <i class="fa-solid fa-user-tie text-[10px]"></i>
                                        <span class="truncate italic">@req.StaffName</span>
                                    </div>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            @* Right Content Panel (70%) *@
            <div class="lg:col-span-7 bg-white border border-gray-100 rounded-3xl shadow-sm flex flex-col overflow-hidden">
                @if (_selectedRequest != null)
                {
                    <div class="p-6 border-b border-gray-50 flex items-center justify-between bg-gray-50/30">
                        <div class="flex items-center gap-4">
                             <div class="w-12 h-12 rounded-2xl bg-white border border-gray-200 flex items-center justify-center text-blue-600 shadow-sm">
                                <i class="@( _selectedRequest.Type == ApprovalRequestType.Create ? "fa-solid fa-plus-circle text-xl" : "fa-solid fa-pen-to-square text-xl")"></i>
                            </div>
                            <div>
                                <h2 class="text-xl font-black text-gray-900">@_selectedRequest.ProposedDetails.Name</h2>
                                <p class="text-sm text-gray-500 flex items-center gap-1">
                                    Submitted by <span class="font-bold text-gray-700">@_selectedRequest.StaffName</span>
                                </p>
                            </div>
                        </div>
                        <div class="flex gap-2">
                            <button @onclick="() => ApproveAsync(_selectedRequest.Id)" 
                                    disabled="@_isProcessing"
                                    class="px-5 py-2.5 bg-green-600 text-white font-bold rounded-xl hover:bg-green-700 transition-all shadow-lg shadow-green-500/20 text-sm flex items-center gap-2 disabled:opacity-50">
                                @if (_isProcessing) { <i class="fa-solid fa-spinner fa-spin"></i> }
                                else { <i class="fa-solid fa-check"></i> }
                                Approve
                            </button>
                            <button @onclick="() => OpenRejectModal(_selectedRequest.Id)" 
                                    disabled="@_isProcessing"
                                    class="px-5 py-2.5 bg-red-50 text-red-600 border border-red-100 font-bold rounded-xl hover:bg-red-100 transition-all text-sm flex items-center gap-2 disabled:opacity-50">
                                <i class="fa-solid fa-xmark"></i> Reject
                            </button>
                        </div>
                    </div>

                    <div class="flex-1 overflow-y-auto p-8 custom-scrollbar">
                        @if (_selectedRequest.Type == ApprovalRequestType.Create)
                        {
                            <div class="max-w-2xl">
                                <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest mb-6 flex items-center gap-2">
                                    <span class="w-8 h-[2px] bg-gray-100"></span> Proposed Details
                                </h3>
                                <div class="space-y-6">
                                    <div class="grid grid-cols-2 gap-4">
                                        <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100">
                                            <p class="text-[10px] font-black text-gray-400 uppercase mb-1">Service Name</p>
                                            <p class="font-bold">@_selectedRequest.ProposedDetails.Name</p>
                                        </div>
                                        <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100">
                                            <p class="text-[10px] font-black text-gray-400 uppercase mb-1">Category</p>
                                            <p class="font-bold">@_selectedRequest.ProposedDetails.CategoryName</p>
                                        </div>
                                    </div>
                                    
                                    <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100">
                                        <p class="text-[10px] font-black text-gray-400 uppercase mb-1">Description</p>
                                        <p class="text-sm text-gray-600 leading-relaxed">@_selectedRequest.ProposedDetails.Description</p>
                                    </div>

                                    <div class="grid grid-cols-3 gap-4">
                                        <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100 text-center">
                                            <p class="text-[10px] font-black text-gray-400 uppercase mb-1">Price</p>
                                            <p class="text-lg font-black text-blue-600">$@_selectedRequest.ProposedDetails.Price</p>
                                        </div>
                                        <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100 text-center">
                                            <p class="text-[10px] font-black text-gray-400 uppercase mb-1">Duration</p>
                                            <p class="text-lg font-black">@_selectedRequest.ProposedDetails.Duration <span class="text-xs font-medium">min</span></p>
                                        </div>
                                         <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100 text-center">
                                            <p class="text-[10px] font-black text-gray-400 uppercase mb-1">Hours</p>
                                            <p class="text-sm font-bold truncate">@FormatTime(_selectedRequest.ProposedDetails.TimeStart) - @FormatTime(_selectedRequest.ProposedDetails.TimeEnd)</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else if (_selectedRequest.Type == ApprovalRequestType.Update && _selectedRequest.CurrentDetails != null)
                        {
                            <div class="space-y-10">
                                <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">
                                    @* Current Details *@
                                    <div>
                                        <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest mb-6 flex items-center gap-2">
                                            <span class="w-8 h-[2px] bg-gray-100"></span> Current Details
                                        </h3>
                                        <div class="bg-gray-50 border border-gray-200 rounded-3xl p-6 space-y-4">
                                            <div class="pb-4 border-b border-gray-200/50">
                                                <p class="text-[10px] font-black text-gray-400 uppercase">Name</p>
                                                <p class="font-bold text-gray-700">@_selectedRequest.CurrentDetails.Name</p>
                                            </div>
                                            <div class="pb-4 border-b border-gray-200/50">
                                                <p class="text-[10px] font-black text-gray-400 uppercase">Price & Duration</p>
                                                <p class="font-bold text-gray-700">$@_selectedRequest.CurrentDetails.Price / @_selectedRequest.CurrentDetails.Duration min</p>
                                            </div>
                                             <div class="pb-4 border-b border-gray-200/50">
                                                <p class="text-[10px] font-black text-gray-400 uppercase">Availability</p>
                                                <p class="font-bold text-gray-700">@FormatTime(_selectedRequest.CurrentDetails.TimeStart) - @FormatTime(_selectedRequest.CurrentDetails.TimeEnd)</p>
                                            </div>
                                            <div>
                                                <p class="text-[10px] font-black text-gray-400 uppercase">Description</p>
                                                <p class="text-xs text-gray-500 line-clamp-4">@_selectedRequest.CurrentDetails.Description</p>
                                            </div>
                                        </div>
                                    </div>

                                    @* Proposed Changes *@
                                    <div>
                                        <h3 class="text-sm font-black text-blue-400 uppercase tracking-widest mb-6 flex items-center gap-2">
                                            <span class="w-8 h-[2px] bg-blue-100"></span> Proposed Changes
                                        </h3>
                                        <div class="bg-blue-50/30 border border-blue-100 rounded-3xl p-6 space-y-4">
                                            <div class="pb-4 border-b border-blue-100/50">
                                                <p class="text-[10px] font-black text-blue-400 uppercase">Name & Category</p>
                                                <div class="flex flex-col gap-1">
                                                    <span class="@GetDiffClass(_selectedRequest.CurrentDetails.Name, _selectedRequest.ProposedDetails.Name)">@_selectedRequest.ProposedDetails.Name</span>
                                                    <span class="@($"{GetDiffClass(_selectedRequest.CurrentDetails.CategoryName, _selectedRequest.ProposedDetails.CategoryName)} text-[10px] uppercase font-black")">@_selectedRequest.ProposedDetails.CategoryName</span>
                                                </div>
                                            </div>
                                            <div class="pb-4 border-b border-blue-100/50">
                                                <p class="text-[10px] font-black text-blue-400 uppercase">Price & Duration</p>
                                                <div class="flex gap-2">
                                                    <span class="@GetDiffClass(_selectedRequest.CurrentDetails.Price, _selectedRequest.ProposedDetails.Price)">$@_selectedRequest.ProposedDetails.Price</span>
                                                    <span class="text-gray-300">/</span>
                                                    <span class="@GetDiffClass(_selectedRequest.CurrentDetails.Duration, _selectedRequest.ProposedDetails.Duration)">@_selectedRequest.ProposedDetails.Duration min</span>
                                                </div>
                                            </div>
                                             <div class="pb-4 border-b border-blue-100/50">
                                                <p class="text-[10px] font-black text-blue-400 uppercase">Availability</p>
                                                 <span class="@GetDiffClass(_selectedRequest.CurrentDetails.TimeStart, _selectedRequest.ProposedDetails.TimeStart)">@FormatTime(_selectedRequest.ProposedDetails.TimeStart)</span>
                                                 <span class="text-gray-300">-</span>
                                                 <span class="@GetDiffClass(_selectedRequest.CurrentDetails.TimeEnd, _selectedRequest.ProposedDetails.TimeEnd)">@FormatTime(_selectedRequest.ProposedDetails.TimeEnd)</span>
                                            </div>
                                            <div>
                                                <p class="text-[10px] font-black text-blue-400 uppercase">Description</p>
                                                <p class="@($"{GetDiffClass(_selectedRequest.CurrentDetails.Description, _selectedRequest.ProposedDetails.Description)} text-xs line-clamp-4")">@_selectedRequest.ProposedDetails.Description</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="flex-1 flex flex-col items-center justify-center p-12 text-center text-gray-400">
                        <div class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mb-6">
                            <i class="fa-solid fa-magnifying-glass-chart text-4xl text-gray-200"></i>
                        </div>
                        <h2 class="text-xl font-bold text-gray-900 mb-2">No Selection</h2>
                        <p class="max-w-xs mx-auto">Select a service request from the sidebar to view its details and take action.</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

@* Reject Modal *@
@if (_showRejectModal)
{
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 p-4 animate-in fade-in duration-200">
        <div class="bg-white w-full max-w-md rounded-[2.5rem] p-8 shadow-2xl animate-in zoom-in-95 duration-200 outline-none">
            <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 bg-red-100 text-red-600 rounded-2xl flex items-center justify-center text-xl">
                    <i class="fa-solid fa-circle-exclamation"></i>
                </div>
                <div>
                    <h3 class="text-2xl font-black text-gray-900">Reject Request</h3>
                    <p class="text-sm text-gray-500 italic">Please provide a reason for rejection</p>
                </div>
            </div>

            <div class="space-y-4">
                <textarea @bind="_rejectComment" 
                          class="w-full border-2 border-gray-100 rounded-3xl p-4 text-sm focus:ring-4 focus:ring-red-500/10 focus:border-red-500 transition-all outline-none resize-none" 
                          rows="4" 
                          placeholder="Why is this request being rejected?"></textarea>
                
                <div class="flex flex-col sm:flex-row gap-3">
                     <button @onclick="ConfirmReject" 
                            disabled="@(string.IsNullOrWhiteSpace(_rejectComment))"
                            class="flex-1 px-6 py-3.5 bg-red-600 text-white font-bold rounded-2xl hover:bg-red-700 transition-all shadow-lg shadow-red-500/20 disabled:opacity-50 disabled:shadow-none text-sm">
                        Confirm Rejection
                    </button>
                    <button @onclick="CancelReject" 
                            class="flex-1 px-6 py-3.5 bg-gray-100 text-gray-700 font-bold rounded-2xl hover:bg-gray-200 transition-all text-sm">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #f1f1f1;
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #e1e1e1;
    }
</style>



        
