@page "/admin/staff"
@attribute [Authorize(Roles = "Admin")]
<PageTitle>Manage Staff — Bookify Admin</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Staff Management</h1>
            <p class="text-gray-500 mt-1">Monitor staff performance and manage access</p>
        </div>
    </div>

    @if (_loading)
    {
        <LoadingSpinner Message="Fetching staff details..." />
    }
    else
    {
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-gray-50 border-b border-gray-100">
                        <tr>
                            <th class="px-8 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Staff Member</th>
                            <th class="px-8 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Service</th>
                            <th class="px-8 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider text-center">Bookings</th>
                            <th class="px-8 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Status</th>
                            <th class="px-8 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        @foreach (var staff in _staffList)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-8 py-6">
                                    <div class="flex items-center gap-3">
                                        @if (!string.IsNullOrEmpty(staff.ImagePath))
                                        {
                                            <img src="@staff.ImagePath" class="w-10 h-10 rounded-full object-cover shadow-sm border border-gray-100" alt="@staff.FullName" />
                                        }
                                        else
                                        {
                                            <div class="w-10 h-10 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center font-bold">
                                                @staff.FullName[0]
                                            </div>
                                        }
                                        <div>
                                            <p class="font-bold text-gray-900">@staff.FullName</p>
                                            <p class="text-xs text-gray-400">@staff.Phone</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-8 py-6">
                                    <span class="text-sm font-medium text-gray-600">@staff.ServiceName</span>
                                </td>
                                <td class="px-8 py-6 text-center">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-blue-50 text-blue-700">
                                        @staff.BookingCount
                                    </span>
                                </td>
                                <td class="px-8 py-6">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider @(staff.IsActive ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                                        @(staff.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="px-8 py-6 text-right">
                                    <button @onclick="() => ToggleActive(staff)" 
                                            class="px-4 py-2 text-xs font-bold rounded-xl border transition-all @(staff.IsActive ? "border-red-100 text-red-600 hover:bg-red-50" : "border-green-100 text-green-600 hover:bg-green-50")">
                                        @(staff.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <Pagination CurrentPage="_currentPage" TotalPages="_totalPages" TotalCount="_totalCount" OnPageChanged="OnPageChanged" />
        </div>
    }
</div>



