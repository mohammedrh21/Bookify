<a href="/service/@Service.Id" class="block bg-white rounded-3xl border border-gray-100 overflow-hidden shadow-sm hover-lift flex flex-col group relative">
    @if (!string.IsNullOrEmpty(Service.ImagePath))
    {
        <div class="h-40 w-full relative overflow-hidden">
            <img src="@Service.ImagePath" alt="@Service.Name" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
        </div>
    }
    else
    {
        <!-- Top color band fallback -->
        <div class="h-2 bg-gradient-to-r from-primary-400 via-blue-500 to-indigo-600"></div>
    }

    <div class="p-5 flex flex-col flex-1">

        <!-- Title + Price -->
        <div class="flex items-start justify-between mb-3">
            <h3 class="font-bold text-gray-900 text-lg leading-snug flex-1 pr-2 group-hover:text-primary-600 transition-colors">
                @Service.Name
            </h3>

            <span class="text-lg font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-indigo-600 whitespace-nowrap">
                $@Service.Price.ToString("F0")
            </span>
        </div>

        <!-- Rating -->
        <div class="flex items-center gap-1.5 mb-3">
            <div class="flex items-center text-amber-400 text-xs">
                @for (int i = 1; i <= 5; i++)
                {
                    if (i <= Math.Round(Service.Rating))
                    {
                        <i class="fas fa-star"></i>
                    }
                    else
                    {
                        <i class="far fa-star"></i>
                    }
                }
            </div>
            <span class="text-xs font-bold text-gray-900">@Service.Rating.ToString("F1")</span>
            <span class="text-xs text-gray-400">(@Service.ReviewCount)</span>
        </div>

        <!-- Description -->
        <p class="text-gray-400 text-sm mb-4 flex-1">
            @(string.IsNullOrEmpty(Service.Description) ? "" : (Service.Description.Length > 20 ? Service.Description.Substring(0, 20) + ".." : Service.Description))
        </p>

        <!-- Info Row -->
        <div class="space-y-3 mb-6 flex-1 text-sm text-gray-500">
            <!-- Duration -->
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-blue-50 flex items-center justify-center text-primary-500">
                        <i class="fa-regular fa-clock text-xs"></i>
                    </div>
                    <span>Duration</span>
                </div>
                <span class="font-semibold text-gray-800">@Service.Duration min</span>
            </div>

            <!-- Staff -->
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-purple-50 flex items-center justify-center text-purple-500">
                        <i class="fa-regular fa-user text-xs"></i>
                    </div>
                    <span>Staff</span>
                </div>
                <span class="font-semibold text-gray-800">@Service.StaffName</span>
            </div>
        </div>

        <!-- Button -->
        <div class="block w-full text-center py-3.5 bg-gradient-to-r from-primary-600 to-indigo-600 group-hover:from-primary-700 group-hover:to-indigo-700 text-white font-bold rounded-2xl text-sm transition-all shadow-md shadow-primary-500/20 group-hover:shadow-lg group-hover:shadow-primary-500/40">
            View Details
        </div>

    </div>
</a>

@code {
    [Parameter] public ServiceModel Service { get; set; } = default!;
}