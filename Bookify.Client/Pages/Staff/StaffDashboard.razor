@page "/staff/dashboard"
@attribute [Authorize(Roles = "Staff")]

<PageTitle>Staff Dashboard — Bookify</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-8">
    
    <!-- 1. Header with Personalized Greeting + Period Filter -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 bg-white p-8 rounded-3xl border border-gray-100 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary-50 rounded-full blur-3xl -mr-20 -mt-20 opacity-50"></div>
        <div class="relative z-10">
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Business Overview, @_staffName</h1>
            <p class="text-gray-500 mt-2 font-medium">Track your performance, revenue, and client satisfaction.</p>
        </div>
        <div class="relative z-10 flex flex-wrap items-center gap-3">
            <!-- Period filter -->
            <div class="flex items-center gap-1 bg-gray-50 p-1.5 rounded-2xl border border-gray-100 shadow-inner">
                <button @onclick='() => SetPeriod("day")'   class="@PeriodBtnClass("day")">Day</button>
                <button @onclick='() => SetPeriod("week")'  class="@PeriodBtnClass("week")">Week</button>
                <button @onclick='() => SetPeriod("month")' class="@PeriodBtnClass("month")">Month</button>
                <button @onclick='() => SetPeriod("year")'  class="@PeriodBtnClass("year")">Year</button>
            </div>
            <a href="/booking/service-bookings" class="px-6 py-3 bg-primary-600 font-bold text-white rounded-xl shadow-lg shadow-primary-200 hover:bg-primary-700 transition-all hover:-translate-y-0.5 ml-2">
                <i class="fa-regular fa-calendar-check mr-2"></i> Schedule
            </a>
        </div>
    </div>

    @if (_loading)
    {
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
            @for(int i=0; i<4; i++) {
                <div class="h-32 bg-white rounded-3xl animate-pulse border border-gray-100"></div>
            }
        </div>
        <div class="h-96 bg-white rounded-3xl animate-pulse border border-gray-100"></div>
    }
    else
    {
        <!-- 2. KPI Cards (4 metrics) -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            
            <!-- Revenue -->
            <div class="bg-gray-900 p-6 rounded-3xl relative overflow-hidden shadow-xl shadow-gray-900/20 group hover:-translate-y-1 transition-transform">
                <div class="absolute -right-6 -top-6 w-32 h-32 bg-primary-500 rounded-full blur-3xl opacity-30 group-hover:opacity-50 transition-opacity"></div>
                <div class="relative z-10">
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center text-green-400">
                            <i class="fa-solid fa-sack-dollar text-xl"></i>
                        </div>
                        <span class="px-2.5 py-1 rounded-full text-xs font-bold @(_stats.TotalRevenueTrend >= 0 ? "bg-green-500/20 text-green-400" : "bg-red-500/20 text-red-400")">
                            <i class="fa-solid @(_stats.TotalRevenueTrend >= 0 ? "fa-arrow-trend-up" : "fa-arrow-trend-down") mr-1"></i>
                            @Math.Abs(_stats.TotalRevenueTrend).ToString("F1")%
                        </span>
                    </div>
                    <p class="text-sm font-medium text-gray-400 mb-1">Period Revenue</p>
                    <h3 class="text-3xl font-extrabold text-white">$@_stats.TotalRevenue.ToString("N0")</h3>
                </div>
            </div>

            <!-- Total Bookings -->
            <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm relative overflow-hidden group hover:border-primary-200 transition-colors">
                <div class="relative z-10">
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600">
                            <i class="fa-solid fa-book-open text-xl"></i>
                        </div>
                        <span class="px-2.5 py-1 rounded-full text-xs font-bold @(_stats.TotalBookingsTrend >= 0 ? "bg-green-50 text-green-700" : "bg-red-50 text-red-700")">
                            <i class="fa-solid @(_stats.TotalBookingsTrend >= 0 ? "fa-arrow-trend-up" : "fa-arrow-trend-down") mr-1"></i>
                            @Math.Abs(_stats.TotalBookingsTrend).ToString("F1")%
                        </span>
                    </div>
                    <p class="text-sm font-medium text-gray-500 mb-1">Total Bookings</p>
                    <h3 class="text-3xl font-extrabold text-gray-900">@_stats.TotalBookings</h3>
                </div>
            </div>

            <!-- Completion Rate -->
            <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm relative overflow-hidden group hover:border-primary-200 transition-colors">
                <div class="relative z-10">
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600">
                            <i class="fa-solid fa-check-double text-xl"></i>
                        </div>
                        <div class="text-xs font-bold text-gray-400 bg-gray-50 px-2 py-1 rounded-lg">Success Rate</div>
                    </div>
                    <p class="text-sm font-medium text-gray-500 mb-1">Completion Rate</p>
                    <h3 class="text-3xl font-extrabold text-gray-900">@_stats.CompletionRate%</h3>
                </div>
                <!-- Progress bar bg -->
                <div class="absolute bottom-0 left-0 w-full h-1 bg-gray-100">
                    <div class="h-full bg-emerald-500" style="width: @_stats.CompletionRate%"></div>
                </div>
            </div>

            <!-- Active Clients -->
            <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm relative overflow-hidden group hover:border-primary-200 transition-colors">
                <div class="relative z-10">
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-10 h-10 rounded-xl bg-purple-50 flex items-center justify-center text-purple-600">
                            <i class="fa-solid fa-users text-xl"></i>
                        </div>
                        <div class="text-xs font-bold text-gray-400 bg-gray-50 px-2 py-1 rounded-lg">Unique</div>
                    </div>
                    <p class="text-sm font-medium text-gray-500 mb-1">Active Clients</p>
                    <h3 class="text-3xl font-extrabold text-gray-900">@_stats.ActiveClients</h3>
                </div>
            </div>

        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- LEFT COLUMN (Span 2): Performance Chart + Recent Bookings -->
            <div class="lg:col-span-2 flex flex-col gap-8">
                
                <!-- Performance Chart (Custom CSS Bar Chart) -->
                <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
                    <div class="flex justify-between items-center mb-8">
                        <div>
                            <h2 class="text-lg font-bold text-gray-900">Booking Trends</h2>
                            <p class="text-sm text-gray-500">Activity over the selected period</p>
                        </div>
                        <div class="text-right">
                            <p class="text-3xl font-extrabold text-primary-600">@_stats.BookingTrends.Sum(t => t.Value)</p>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Appointments</p>
                        </div>
                    </div>

                    @if (!_stats.BookingTrends.Any() || _stats.BookingTrends.All(t => t.Value == 0))
                    {
                        <div class="h-48 flex items-center justify-center text-gray-400 text-sm font-medium bg-gray-50 rounded-2xl border border-dashed border-gray-200">
                            No booking data to display for this period.
                        </div>
                    }
                    else
                    {
                        var maxVal = _stats.BookingTrends.Max(t => t.Value);
                        if (maxVal == 0) maxVal = 1; // Prevent division by zero
                        
                        <div class="h-56 flex items-end justify-between gap-2 pt-6 border-b border-gray-100 pb-2">
                            @foreach (var point in _stats.BookingTrends)
                            {
                                var heightPercentage = (point.Value / (double)maxVal) * 100;
                                // Minimum height 4px to show a blip if value is 0 but others are not, or 0 if truly 0
                                var actualHeight = point.Value == 0 ? 0 : Math.Max(heightPercentage, 2); 
                                
                                <div class="flex-1 flex flex-col items-center gap-3 group relative h-full justify-end">
                                    <!-- Tooltip -->
                                    <div class="opacity-0 group-hover:opacity-100 absolute -top-10 bg-gray-900 text-white text-xs font-bold py-1 px-3 rounded-lg pointer-events-none transition-opacity whitespace-nowrap z-20 shadow-lg">
                                        @point.Value bookings
                                        <!-- pointer arrow -->
                                        <div class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-2 h-2 bg-gray-900 rotate-45"></div>
                                    </div>
                                    
                                    <!-- Bar -->
                                    <div class="w-full max-w-[40px] bg-primary-100 rounded-t-lg relative overflow-hidden group-hover:bg-primary-200 transition-colors" style="height: @actualHeight%">
                                        <div class="absolute bottom-0 w-full bg-gradient-to-t from-primary-600 to-primary-400 rounded-t-lg transition-all duration-700 ease-out" style="height: 100%"></div>
                                    </div>
                                    
                                    <!-- Label -->
                                    <span class="absolute -bottom-7 text-[10px] font-bold text-gray-400 md:text-xs">@point.Label</span>
                                </div>
                            }
                        </div>
                        <div class="mt-8"></div>
                    }
                </div>

                <!-- Recent & Upcoming list -->
                <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden flex-1 group hover:border-primary-200 transition-colors">
                    <div class="p-6 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                        <h2 class="text-lg font-bold text-gray-900">Upcoming Schedule</h2>
                        <a href="/booking/service-bookings" class="text-sm font-bold text-primary-600 hover:text-primary-700">View All →</a>
                    </div>
                    
                    <div class="p-0">
                        @if (!_stats.RecentBookings.Any(b => b.Status == "Pending" || b.Status == "Approved"))
                        {
                            <div class="text-center py-12 text-gray-500 text-sm">
                                <i class="fa-regular fa-calendar-xmark text-3xl mb-3 text-gray-300"></i>
                                <p>No upcoming appointments found.</p>
                            </div>
                        }
                        else
                        {
                            <ul class="divide-y divide-gray-50">
                                @foreach (var booking in _stats.RecentBookings.Where(b => b.Status == "Pending" || b.Status == "Approved").Take(5))
                                {
                                    <li class="p-4 sm:px-6 hover:bg-gray-50 transition-colors flex items-center justify-between gap-4">
                                        <div class="flex items-center gap-4">
                                            <div class="w-14 h-14 rounded-2xl bg-primary-50 text-primary-600 flex flex-col items-center justify-center shrink-0 border border-primary-100/50 shadow-inner">
                                                <span class="text-[10px] font-bold uppercase tracking-wider mb-0.5">@booking.Date.ToString("MMM")</span>
                                                <span class="text-xl font-extrabold leading-none">@booking.Date.ToString("dd")</span>
                                            </div>
                                            <div>
                                                <p class="font-bold text-gray-900 text-sm line-clamp-1">@booking.ClientName</p>
                                                <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mt-1">
                                                    <span class="text-xs text-gray-500 font-medium">
                                                        <i class="fa-regular fa-clock mr-1 text-gray-400"></i> @booking.Time.ToString(@"hh\:mm")
                                                    </span>
                                                    <span class="hidden sm:inline text-gray-300">•</span>
                                                    <span class="text-xs text-gray-500 line-clamp-1">@booking.ServiceName</span>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="shrink-0 flex flex-col items-end gap-2">
                                            <span class="px-2.5 py-1 rounded-full text-[10px] font-bold tracking-wide border @GetStatusColor(booking.Status)">
                                                @booking.Status
                                            </span>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>

            </div>

            <!-- RIGHT COLUMN: Alerts and Reviews -->
            <div class="lg:col-span-1 flex flex-col gap-8">
                
                <!-- Action Required -->
                @if (_stats.PendingBookings > 0)
                {
                    <div class="bg-gradient-to-br from-amber-500 to-orange-500 p-6 rounded-3xl text-white relative overflow-hidden shadow-lg shadow-amber-500/20 group hover:-translate-y-1 transition-transform">
                        <div class="absolute -right-4 -top-4 text-white/20 group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-bell text-7xl"></i>
                        </div>
                        <div class="relative z-10">
                            <h3 class="text-lg font-bold mb-1">Attention Needed</h3>
                            <p class="text-amber-100 text-sm mb-4">You have pending requests.</p>
                            
                            <div class="flex items-center justify-between bg-black/10 rounded-2xl p-4 backdrop-blur-sm shadow-inner cursor-pointer hover:bg-black/20 transition-colors" onclick="window.location.href='/booking/service-bookings'">
                                <div class="text-3xl font-extrabold">@_stats.PendingBookings</div>
                                <span class="px-4 py-2 bg-white text-amber-600 text-sm font-bold rounded-xl shadow-sm">
                                    Review
                                </span>
                            </div>
                        </div>
                    </div>
                }

                <!-- Ratings Overview -->
                <div class="bg-white rounded-3xl border border-gray-100 shadow-sm flex-1 flex flex-col group hover:border-primary-200 transition-colors">
                    <div class="p-6 border-b border-gray-50">
                        <h2 class="text-lg font-bold text-gray-900">Client Satisfaction</h2>
                        <div class="flex items-end gap-3 mt-4">
                            <h3 class="text-5xl font-extrabold text-gray-900 tracking-tighter">@_stats.AverageRating.ToString("F1")</h3>
                            <div class="pb-1.5">
                                <div class="flex text-yellow-400 gap-0.5 text-sm mb-1">
                                    @for(int i=1; i<=5; i++) {
                                        <i class="fa-solid fa-star @(i <= Math.Round(_stats.AverageRating) ? "" : "text-gray-200")"></i>
                                    }
                                </div>
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wide">Based on @_stats.TotalReviews reviews</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="p-6 flex-1 bg-gray-50/30">
                        @if (!_stats.RecentReviews.Any())
                        {
                            <div class="text-center py-6 text-gray-400 text-sm">No recent reviews.</div>
                        }
                        else
                        {
                            <div class="space-y-4">
                                @foreach(var review in _stats.RecentReviews.Take(3))
                                {
                                    <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
                                        <div class="flex justify-between items-start mb-2">
                                            <span class="font-bold text-gray-800 text-xs">@review.ClientName</span>
                                            <div class="flex gap-0.5 text-yellow-400">
                                                @for(int i=1; i<=5; i++) {
                                                    <i class="fa-solid fa-star text-[8px] @(i <= review.Rating ? "" : "text-gray-200")"></i>
                                                }
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(review.Comment))
                                        {
                                            <p class="text-xs text-gray-500 italic line-clamp-2">"@review.Comment"</p>
                                        }
                                        <p class="text-[10px] text-gray-400 mt-2">@review.CreatedAt.ToString("MMM dd, yyyy")</p>
                                    </div>
                                }
                            </div>
                            @if(_stats.TotalReviews > 3)
                            {
                                <div class="mt-4 text-center">
                                    <a href="/staff/reviews" class="text-xs font-bold text-primary-600 hover:underline">See all reviews →</a>
                                </div>
                            }
                        }
                    </div>
                </div>

            </div>
        </div>
    }

</div>
