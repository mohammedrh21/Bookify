@page "/admin/profile"
@using Bookify.Client.Models.Profile
@attribute [Authorize(Policy = "AdminOnly")]
@inject IProfileApiService ProfileService
@inject ToastService ToastService

<PageTitle>Admin Profile — Bookify</PageTitle>

<AuthorizeView Policy="AdminOnly" Context="adminContext">
    <Authorized>
        <!-- Background decoration -->
        <div class="fixed inset-0 z-[-1] pointer-events-none bg-gray-50/50">
            <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-purple-600/5 blur-[120px]"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-indigo-600/5 blur-[120px]"></div>
        </div>

        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            
            <!-- Header -->
            <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4">
                <div>
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-purple-100 text-purple-700 text-xs font-bold uppercase tracking-wider mb-3">
                        <i class="fas fa-shield-alt"></i> Administration
                    </div>
                    <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">My Profile</h1>
                    <p class="text-gray-500 mt-2 text-lg">Manage your admin details and security preferences.</p>
                </div>
            </div>

            @if (_loading)
            {
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <div class="h-80 bg-white rounded-[2rem] border border-gray-100 shadow-sm animate-pulse"></div>
                    <div class="lg:col-span-2 h-[30rem] bg-white rounded-[2rem] border border-gray-100 shadow-sm animate-pulse"></div>
                </div>
            }
            else if (_profile is null)
            {
                <div class="flex flex-col items-center justify-center py-20 bg-white/50 backdrop-blur-xl rounded-[2.5rem] border border-gray-100 shadow-xl">
                    <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mb-6">
                        <i class="fas fa-user-slash text-4xl text-gray-400"></i>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-900 mb-2">Profile Unavailable</h2>
                    <p class="text-gray-500">Could not load your profile details. Please try refreshing the page.</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    
                    <!-- Avatar Card -->
                    <div class="bg-white/80 backdrop-blur-xl rounded-[2rem] border border-gray-100 shadow-xl shadow-gray-200/40 p-8 flex flex-col items-center text-center gap-5 relative overflow-hidden group">
                        <div class="absolute top-0 left-0 w-full h-32 bg-gradient-to-br from-purple-600/10 to-indigo-600/10 -z-10 group-hover:h-full transition-all duration-500"></div>
                        
                        <div class="relative">
                            <div class="absolute inset-0 bg-purple-600 rounded-full blur-xl opacity-20 group-hover:opacity-40 transition-opacity duration-300"></div>
                            <div class="w-28 h-28 rounded-full bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center shadow-2xl shadow-purple-500/30 ring-4 ring-white relative z-10 transform group-hover:scale-105 transition-transform duration-300">
                                <span class="text-white text-5xl font-black shadow-sm">@GetInitial()</span>
                            </div>
                        </div>

                        <div class="mt-2">
                            <h3 class="text-2xl font-black text-gray-900 tracking-tight">@_profile.FullName</h3>
                            <p class="text-gray-500 font-medium flex items-center justify-center gap-2 mt-1">
                                <i class="fas fa-envelope text-gray-400"></i> @_profile.Email
                            </p>
                        </div>

                        <div class="w-full h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent my-2"></div>

                        <div class="px-5 py-2 rounded-2xl bg-gradient-to-r from-purple-50 to-indigo-50 border border-purple-100 text-purple-700 font-bold text-sm shadow-sm flex items-center gap-2">
                            <i class="fas fa-star text-purple-500"></i> Super Administrator
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="lg:col-span-2 flex flex-col gap-8">

                        <!-- Personal Info Form -->
                        <div class="bg-white/80 backdrop-blur-xl rounded-[2rem] border border-gray-100 shadow-xl shadow-gray-200/40 p-8 md:p-10 relative overflow-hidden">
                            <div class="absolute top-0 right-0 w-64 h-64 bg-purple-600/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
                            
                            <div class="flex items-center gap-4 mb-8 relative z-10">
                                <div class="w-12 h-12 rounded-2xl bg-purple-100 flex items-center justify-center text-purple-600 text-xl shadow-inner">
                                    <i class="fas fa-id-card"></i>
                                </div>
                                <div>
                                    <h2 class="text-xl font-extrabold text-gray-900">Personal Details</h2>
                                    <p class="text-sm text-gray-500 font-medium">Update your contact information.</p>
                                </div>
                            </div>

                            <div class="space-y-6 relative z-10">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="relative group">
                                        <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Full Name</label>
                                        <div class="relative flex items-center">
                                            <div class="absolute left-4 text-gray-400 group-focus-within:text-purple-500 transition-colors">
                                                <i class="fas fa-user-edit"></i>
                                            </div>
                                            <input type="text" @bind="_edit.FullName"
                                                   class="w-full pl-11 pr-4 py-3.5 bg-gray-50 rounded-2xl border-2 border-transparent focus:bg-white focus:border-purple-500 focus:ring-4 focus:ring-purple-500/10 outline-none transition-all text-gray-900 font-bold placeholder-gray-400" placeholder="Enter your full name" />
                                        </div>
                                    </div>

                                    <div class="relative group">
                                        <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Phone Number</label>
                                        <div class="relative flex items-center">
                                            <div class="absolute left-4 text-gray-400 group-focus-within:text-purple-500 transition-colors">
                                                <i class="fas fa-phone-alt"></i>
                                            </div>
                                            <input type="tel" @bind="_edit.Phone"
                                                   class="w-full pl-11 pr-4 py-3.5 bg-gray-50 rounded-2xl border-2 border-transparent focus:bg-white focus:border-purple-500 focus:ring-4 focus:ring-purple-500/10 outline-none transition-all text-gray-900 font-bold placeholder-gray-400" placeholder="Phone number" />
                                        </div>
                                    </div>
                                </div>

                                <div class="relative group">
                                    <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Email Address</label>
                                    <div class="relative flex items-center">
                                        <div class="absolute left-4 text-gray-400">
                                            <i class="fas fa-envelope"></i>
                                        </div>
                                        <input type="email" value="@_profile.Email" readonly
                                               class="w-full pl-11 pr-4 py-3.5 bg-gray-100 rounded-2xl border-2 border-transparent text-gray-500 font-bold cursor-not-allowed opacity-70" />
                                        <div class="absolute right-4 text-xs font-bold text-gray-400 uppercase bg-gray-200 px-2 py-1 rounded-md">Read Only</div>
                                    </div>
                                </div>

                                <div class="pt-4 flex justify-end">
                                    <button @onclick="SaveProfileAsync" disabled="@_saving"
                                            class="w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-purple-600 to-indigo-600 text-white font-extrabold rounded-2xl hover:from-purple-700 hover:to-indigo-700 transition-all shadow-xl shadow-purple-500/30 hover:-translate-y-1 hover:shadow-purple-500/50 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0 relative overflow-hidden group/btn">
                                        <div class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover/btn:translate-x-full transition-transform duration-1000 ease-in-out"></div>
                                        <div class="relative flex items-center justify-center gap-2">
                                            @if (_saving)
                                            {
                                                <i class="fas fa-circle-notch animate-spin"></i>
                                                <span>Saving Changes...</span>
                                            }
                                            else
                                            {
                                                <i class="fas fa-check-circle"></i>
                                                <span>Save Profile</span>
                                            }
                                        </div>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Change Password Form -->
                        <div class="bg-white/80 backdrop-blur-xl rounded-[2rem] border border-gray-100 shadow-xl shadow-gray-200/40 p-8 md:p-10 relative overflow-hidden">
                            <div class="absolute top-0 left-0 w-64 h-64 bg-amber-500/5 rounded-full blur-3xl -translate-y-1/2 -translate-x-1/3"></div>

                            <div class="flex items-center gap-4 mb-8 relative z-10">
                                <div class="w-12 h-12 rounded-2xl bg-amber-100 flex items-center justify-center text-amber-600 text-xl shadow-inner">
                                    <i class="fas fa-key"></i>
                                </div>
                                <div>
                                    <h2 class="text-xl font-extrabold text-gray-900">Security</h2>
                                    <p class="text-sm text-gray-500 font-medium">Update your password regularly to keep your account safe.</p>
                                </div>
                            </div>

                            <div class="space-y-6 relative z-10">
                                <div class="relative group">
                                    <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Current Password</label>
                                    <div class="relative flex items-center">
                                        <div class="absolute left-4 text-gray-400 group-focus-within:text-amber-500 transition-colors">
                                            <i class="fas fa-lock"></i>
                                        </div>
                                        <input type=@(_showCurrent ? "text" : "password") @bind="_pwd.CurrentPassword"
                                               class="w-full pl-11 pr-12 py-3.5 bg-gray-50 rounded-2xl border-2 border-transparent focus:bg-white focus:border-amber-500 focus:ring-4 focus:ring-amber-500/10 outline-none transition-all text-gray-900 font-bold placeholder-gray-400" placeholder="••••••••" />
                                        <button type="button" @onclick="() => _showCurrent = !_showCurrent" class="absolute right-4 text-gray-400 hover:text-gray-700 transition-colors w-6 h-6 flex items-center justify-center">
                                            <i class="fas @(_showCurrent ? "fa-eye-slash" : "fa-eye")"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="relative group">
                                        <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">New Password</label>
                                        <div class="relative flex items-center">
                                            <div class="absolute left-4 text-gray-400 group-focus-within:text-amber-500 transition-colors">
                                                <i class="fas fa-shield-alt"></i>
                                            </div>
                                            <input type=@(_showNew ? "text" : "password") @bind="_pwd.NewPassword"
                                                   class="w-full pl-11 pr-12 py-3.5 bg-gray-50 rounded-2xl border-2 border-transparent focus:bg-white focus:border-amber-500 focus:ring-4 focus:ring-amber-500/10 outline-none transition-all text-gray-900 font-bold placeholder-gray-400" placeholder="••••••••" />
                                            <button type="button" @onclick="() => _showNew = !_showNew" class="absolute right-4 text-gray-400 hover:text-gray-700 transition-colors w-6 h-6 flex items-center justify-center">
                                                <i class="fas @(_showNew ? "fa-eye-slash" : "fa-eye")"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="relative group">
                                        <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Confirm Password</label>
                                        <div class="relative flex items-center">
                                            <div class="absolute left-4 text-gray-400 group-focus-within:text-amber-500 transition-colors">
                                                <i class="fas fa-check-double"></i>
                                            </div>
                                            <input type=@(_showConfirm ? "text" : "password") @bind="_pwd.ConfirmPassword"
                                                   class="w-full pl-11 pr-12 py-3.5 bg-gray-50 rounded-2xl border-2 border-transparent focus:bg-white focus:border-amber-500 focus:ring-4 focus:ring-amber-500/10 outline-none transition-all text-gray-900 font-bold placeholder-gray-400" placeholder="••••••••" />
                                            <button type="button" @onclick="() => _showConfirm = !_showConfirm" class="absolute right-4 text-gray-400 hover:text-gray-700 transition-colors w-6 h-6 flex items-center justify-center">
                                                <i class="fas @(_showConfirm ? "fa-eye-slash" : "fa-eye")"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(_pwdError))
                                {
                                    <div class="p-4 rounded-xl bg-red-50 border border-red-100 flex items-start gap-3 text-red-600">
                                        <i class="fas fa-exclamation-circle mt-0.5"></i>
                                        <p class="text-sm font-bold">@_pwdError</p>
                                    </div>
                                }

                                <div class="pt-4 flex justify-end">
                                    <button @onclick="ChangePasswordAsync" disabled="@_changingPwd"
                                            class="w-full sm:w-auto px-8 py-4 bg-gray-900 text-white font-extrabold rounded-2xl hover:bg-black transition-all shadow-xl shadow-gray-900/20 hover:-translate-y-1 hover:shadow-gray-900/40 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0 relative overflow-hidden group/btn">
                                        <div class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover/btn:translate-x-full transition-transform duration-1000 ease-in-out"></div>
                                        <div class="relative flex items-center justify-center gap-2">
                                            @if (_changingPwd)
                                            {
                                                <i class="fas fa-circle-notch animate-spin"></i>
                                                <span>Updating...</span>
                                            }
                                            else
                                            {
                                                <i class="fas fa-lock text-amber-400"></i>
                                                <span>Update Password</span>
                                            }
                                        </div>
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    </Authorized>
</AuthorizeView>

@code {
    private AdminProfileModel? _profile;
    private UpdateAdminProfileModel _edit = new();
    private ChangePasswordModel _pwd = new();
    private bool _loading = true;
    private bool _saving = false;
    private bool _changingPwd = false;
    private string _pwdError = string.Empty;

    private bool _showCurrent;
    private bool _showNew;
    private bool _showConfirm;

    protected override async Task OnInitializedAsync()
    {
        var result = await ProfileService.GetAdminProfileAsync();
        if (result.Success && result.Data is not null)
        {
            _profile = result.Data;
            _edit = new UpdateAdminProfileModel
            {
                FullName = _profile.FullName,
                Phone = _profile.Phone
            };
        }
        _loading = false;
    }

    private async Task SaveProfileAsync()
    {
        if (_profile is null) return;

        _saving = true;
        var result = await ProfileService.UpdateAdminProfileAsync(_edit);
        if (result.Success)
        {
            _profile.FullName = _edit.FullName;
            _profile.Phone = _edit.Phone;
        }
        _saving = false;
    }

    private async Task ChangePasswordAsync()
    {
        _pwdError = string.Empty;
        if (string.IsNullOrWhiteSpace(_pwd.CurrentPassword) || string.IsNullOrWhiteSpace(_pwd.NewPassword) || string.IsNullOrWhiteSpace(_pwd.ConfirmPassword))
        {
            _pwdError = "All password fields are required."; return;
        }
        if (_pwd.NewPassword.Length < 6)
        {
            _pwdError = "New password must be at least 6 characters."; return;
        }
        if (_pwd.NewPassword != _pwd.ConfirmPassword)
        {
            _pwdError = "New password and confirmation do not match."; return;
        }

        _changingPwd = true;
        var result = await ProfileService.ChangeAdminPasswordAsync(_pwd);
        if (result.Success)
        {
            _pwd = new();
        }
        else
        {
            _pwdError = result.Message ?? "Failed to change password.";
        }
        _changingPwd = false;
    }

    private string GetInitial() => _profile?.FullName is { Length: > 0 } name ? name[0].ToString().ToUpper() : "A";
}
