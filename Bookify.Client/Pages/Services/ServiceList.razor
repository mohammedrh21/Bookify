@page "/services"

<PageTitle>Services — Bookify</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Header -->
    <div class="mb-10 text-center md:text-left">
        <h1 class="text-4xl md:text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-indigo-600 tracking-tight">
            All Services
        </h1>
        <p class="text-gray-500 mt-3 text-lg">Browse and book from our range of top-tier professional services</p>
    </div>

    <!-- Search + Filter Row -->
    <div class="flex flex-col sm:flex-row gap-4 mb-8">
        <div class="relative flex-1 group">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-400 group-focus-within:text-primary-500 transition-colors">
                <i class="fa-solid fa-magnifying-glass"></i>
            </div>
            <input @bind="_search" @oninput="OnSearchChanged" type="text"
                   placeholder="Search services by name or description..."
                   class="w-full pl-11 pr-4 py-4 rounded-2xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-transparent text-sm shadow-sm transition-all" />
        </div>
    </div>

    <!-- Category Pills -->
    @if (_categories.Count > 0)
    {
        <div class="flex gap-3 flex-wrap mb-10">
            <button @onclick="() => SelectCategory(null)"
                    class="px-5 py-2.5 rounded-full text-sm font-semibold transition-all hover-lift
                           @(_selectedCategoryId == null ? "bg-gradient-to-r from-primary-600 to-indigo-600 text-white shadow-md shadow-primary-500/30" : "bg-white border border-gray-200 text-gray-600 hover:bg-gray-50")">
                All
            </button>
            @foreach (var cat in _categories)
            {
                <button @onclick="() => SelectCategory(cat.Id)"
                        class="px-5 py-2.5 rounded-full text-sm font-semibold transition-all hover-lift
                               @(_selectedCategoryId == cat.Id ? "bg-gradient-to-r from-primary-600 to-indigo-600 text-white shadow-md shadow-primary-500/30" : "bg-white border border-gray-200 text-gray-600 hover:bg-gray-50")">
                    @cat.Name
                </button>
            }
        </div>
    }

    <!-- Grid -->
    @if (_loading)
    {
        <LoadingSpinner Message="Loading services..." />
    }
    else if (_services.Count == 0)
    {
        <EmptyState Icon="🔍" Title="No services found"
                    Message="Try adjusting your search or category filter." />
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            @foreach (var svc in _services)
            {
                <ServiceCard Service="svc" />
            }
        </div>
        <Pagination CurrentPage="_currentPage" TotalPages="_totalPages" TotalCount="_totalCount" OnPageChanged="OnPageChanged" />
    }
</div>
