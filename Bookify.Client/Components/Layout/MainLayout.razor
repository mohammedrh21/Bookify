@inherits LayoutComponentBase
@using Bookify.Client.Components.Layout
@using Bookify.Client.Components.Shared

<AuthorizeView>
    <Authorized>
        @if (context.User.IsInRole("Admin") || context.User.IsInRole("Staff"))
        {
            <ManagementLayout>
                @Body
            </ManagementLayout>
        }
        else
        {
            <ClientLayout>
                @Body
            </ClientLayout>
        }
    </Authorized>
    <NotAuthorized>
        <ClientLayout>
            @Body
        </ClientLayout>
    </NotAuthorized>
</AuthorizeView>

<ToastContainer />
