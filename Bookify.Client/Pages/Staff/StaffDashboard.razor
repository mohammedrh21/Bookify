@page "/staff/dashboard"
@attribute [Authorize(Roles = "Staff")]


<PageTitle>Staff Dashboard — Bookify</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-8">
    
    <!-- 1. Header with Personalized Greeting -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 bg-white p-8 rounded-3xl border border-gray-100 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary-50 rounded-full blur-3xl -mr-20 -mt-20 opacity-50"></div>
        <div class="relative z-10">
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Welcome back, @_staffName!</h1>
            <p class="text-gray-500 mt-2 font-medium">Here's an overview of your schedule and performance.</p>
        </div>
        <div class="relative z-10 flex gap-4">
            <a href="/booking/service-bookings" class="px-6 py-3 bg-primary-600 font-bold text-white rounded-2xl shadow-lg shadow-primary-200 hover:bg-primary-700 transition-all hover:-translate-y-0.5">
                <i class="fa-regular fa-calendar-check mr-2"></i> Manage Bookings
            </a>
        </div>
    </div>

    @if (_loading)
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 h-96 bg-white rounded-3xl animate-pulse border border-gray-100"></div>
            <div class="h-96 bg-white rounded-3xl animate-pulse border border-gray-100"></div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            
            <!-- LEFT COLUMN: Schedule & Timeline (col-span-7) -->
            <div class="lg:col-span-7 flex flex-col gap-8">
                
                <!-- Action Cards -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="bg-gradient-to-br from-amber-50 to-orange-50 p-6 rounded-3xl border border-amber-100/50 relative overflow-hidden group hover:shadow-md transition-shadow">
                        <div class="absolute top-4 right-4 text-amber-500/20 group-hover:scale-110 group-hover:text-amber-500/30 transition-transform">
                            <i class="fa-solid fa-clock text-6xl"></i>
                        </div>
                        <div class="relative z-10">
                            <p class="text-sm font-bold text-amber-700/80 uppercase tracking-wider mb-2">Needs Action</p>
                            <div class="flex items-baseline gap-2">
                                <span class="text-4xl font-extrabold text-amber-600">@_stats.PendingBookings</span>
                                <span class="text-amber-800 font-medium text-sm">Pending</span>
                            </div>
                            <a href="/booking/service-bookings" class="inline-block mt-4 text-sm font-bold text-amber-700 hover:text-amber-800">Review requests →</a>
                        </div>
                    </div>

                    <div class="bg-gradient-to-br from-blue-50 to-indigo-50 p-6 rounded-3xl border border-blue-100/50 relative overflow-hidden group hover:shadow-md transition-shadow">
                        <div class="absolute top-4 right-4 text-blue-500/20 group-hover:scale-110 group-hover:text-blue-500/30 transition-transform">
                            <i class="fa-solid fa-calendar-check text-6xl"></i>
                        </div>
                        <div class="relative z-10">
                            <p class="text-sm font-bold text-blue-700/80 uppercase tracking-wider mb-2">Confirmed</p>
                            <div class="flex items-baseline gap-2">
                                <span class="text-4xl font-extrabold text-blue-600">@_stats.ApprovedBookings</span>
                                <span class="text-blue-800 font-medium text-sm">Appointments</span>
                            </div>
                            <span class="inline-block mt-4 text-sm font-bold text-blue-700 opacity-0 group-hover:opacity-100 transition-opacity">Ready for service</span>
                        </div>
                    </div>
                </div>

                <!-- My Day Timeline -->
                <div class="bg-white rounded-3xl border border-gray-100 shadow-sm flex-1">
                    <div class="p-6 border-b border-gray-50 flex items-center justify-between">
                        <div>
                            <h2 class="text-xl font-bold text-gray-900">Recent & Upcoming</h2>
                            <p class="text-xs text-gray-500 mt-1">Your schedule overview</p>
                        </div>
                        <i class="fa-regular fa-clock text-gray-300 text-2xl"></i>
                    </div>
                    
                    <div class="p-6">
                        @if (!_stats.RecentBookings.Any())
                        {
                            <div class="text-center py-12">
                                <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4 text-gray-300">
                                    <i class="fa-solid fa-mug-hot text-2xl"></i>
                                </div>
                                <h3 class="text-gray-900 font-bold mb-1">Schedule Clear</h3>
                                <p class="text-gray-500 text-sm">You have no upcoming appointments.</p>
                            </div>
                        }
                        else
                        {
                            <div class="space-y-6 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-gray-200 before:to-transparent">
                                @foreach (var booking in _stats.RecentBookings.OrderBy(b => b.Date).ThenBy(b => b.Time).Take(6))
                                {
                                    <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group">
                                        <!-- Timeline dot -->
                                        <div class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-white bg-primary-100 text-primary-600 shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 z-10 transition-transform group-hover:scale-110">
                                            @if(booking.Status == "Pending") { <i class="fa-solid fa-hourglass-half text-xs"></i> }
                                            else if (booking.Status == "Approved") { <i class="fa-solid fa-check text-xs"></i> }
                                            else if (booking.Status == "Completed") { <i class="fa-solid fa-flag-checkered text-xs"></i> }
                                            else { <i class="fa-solid fa-calendar-day text-xs"></i> }
                                        </div>
                                        
                                        <!-- Card -->
                                        <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] bg-white p-4 rounded-2xl border border-gray-100 shadow-sm group-hover:border-primary-200 transition-colors group-hover:shadow-md">
                                            <div class="flex items-center justify-between mb-2">
                                                <span class="text-xs font-bold text-gray-400">@booking.Date.ToString("MMM dd") at @booking.Time.ToString(@"hh\:mm")</span>
                                                <span class="px-2.5 py-1 rounded-full text-[10px] font-bold tracking-wide @GetStatusColor(booking.Status)">
                                                    @booking.Status
                                                </span>
                                            </div>
                                            <p class="font-bold text-gray-900 line-clamp-1">@booking.ClientName</p>
                                            <p class="text-sm text-gray-500 mt-1 line-clamp-1">@booking.ServiceName</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- RIGHT COLUMN: Performance & Popularity (col-span-5) -->
            <div class="lg:col-span-5 flex flex-col gap-8">
                
                <!-- Earnings Card -->
                <div class="bg-gray-900 text-white p-8 rounded-3xl relative overflow-hidden shadow-xl shadow-gray-900/20">
                    <div class="absolute -right-6 -top-6 w-32 h-32 bg-primary-500 rounded-full blur-3xl opacity-30"></div>
                    <div class="relative z-10">
                        <p class="text-gray-400 font-medium text-sm mb-1 uppercase tracking-widest">Period Revenue</p>
                        <h3 class="text-4xl font-extrabold text-white mb-6">$@_stats.TotalRevenue.ToString("N0")</h3>
                        
                        <div class="grid grid-cols-2 gap-4 border-t border-gray-700/50 pt-6">
                            <div>
                                <p class="text-xs text-gray-400 mb-1">TOTAL BOOKINGS</p>
                                <p class="text-xl font-bold">@_stats.TotalBookings</p>
                            </div>
                            <div>
                                <p class="text-xs text-gray-400 mb-1 uppercase">Avg Rating</p>
                                <div class="flex items-center gap-1.5">
                                    <p class="text-xl font-bold">@_stats.AverageRating.ToString("F1")</p>
                                    <i class="fa-solid fa-star text-yellow-400 text-sm pb-0.5"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Client Reviews -->
                <div class="bg-white rounded-3xl border border-gray-100 shadow-sm flex-1 flex flex-col">
                    <div class="p-6 border-b border-gray-50 flex justify-between items-center">
                        <div>
                            <h2 class="text-lg font-bold text-gray-900">Recent Reviews</h2>
                            <p class="text-xs text-gray-500 mt-1">What clients say about you</p>
                        </div>
                        <div class="text-right">
                             <p class="text-xs text-gray-400 uppercase font-bold tracking-wider">Total</p>
                             <p class="text-lg font-extrabold text-primary-600">@_stats.TotalReviews</p>
                        </div>
                    </div>
                    <div class="p-6 space-y-6 flex-1">
                        @if (!_stats.RecentReviews.Any())
                        {
                            <div class="flex flex-col items-center justify-center h-full text-center space-y-3 opacity-60 py-8">
                                <i class="fa-regular fa-comment-dots text-4xl text-gray-300"></i>
                                <p class="text-gray-500 text-sm font-medium">No reviews received yet.</p>
                            </div>
                        }
                        else
                        {
                            @foreach(var review in _stats.RecentReviews.Take(4))
                            {
                                <div class="group">
                                    <div class="flex items-start justify-between mb-1.5">
                                        <div class="flex items-center gap-2">
                                            <div class="w-7 h-7 rounded-full bg-primary-50 flex items-center justify-center text-primary-700 font-bold text-xs">
                                                @(review.ClientName.FirstOrDefault().ToString().ToUpper())
                                            </div>
                                            <span class="font-bold text-gray-800 text-sm">@review.ClientName</span>
                                        </div>
                                        <div class="flex items-center">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fa-solid fa-star text-[10px] @(i <= review.Rating ? "text-yellow-400" : "text-gray-200")"></i>
                                            }
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(review.Comment))
                                    {
                                        <p class="text-xs text-gray-500 italic line-clamp-2 pl-9">"@review.Comment"</p>
                                    }
                                </div>
                            }
                        }
                    </div>
                    <div class="p-4 border-t border-gray-50 text-center">
                        <a href="/staff/reviews" class="text-xs font-bold text-primary-600 hover:text-primary-700 hover:underline">View all @(_stats.TotalReviews) reviews →</a>
                    </div>
                </div>

                <!-- Live Feed / Activity -->
                @if (_stats.RecentActivities.Any())
                {
                    <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6">
                        <h2 class="text-lg font-bold text-gray-900 mb-4">Live Activity</h2>
                        <div class="space-y-4">
                            @foreach(var act in _stats.RecentActivities.Take(3))
                            {
                                <div class="flex items-start gap-3">
                                    <div class="w-2 h-2 mt-2 rounded-full shrink-0 @(act.Type == "Warning" ? "bg-amber-400" : "bg-green-400")"></div>
                                    <div>
                                        <p class="text-sm font-bold text-gray-800">@act.Title</p>
                                        <p class="text-xs text-gray-500 mt-0.5">@act.Description</p>
                                        <p class="text-[10px] text-gray-400 mt-1 uppercase font-semibold">@act.CreatedAt.ToLocalTime().ToString("g")</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

            </div>
        </div>
    }
</div>




