@page "/support"
@inject IFAQApiService FAQService
@inject ITicketApiService TicketService

<PageTitle>Support & FAQs — Bookify</PageTitle>

<div class="bg-gradient-to-br from-primary-50 via-white to-blue-50 py-16 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h1 class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight mb-4">
                How can we <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-indigo-600">help you?</span>
            </h1>
            <p class="text-lg text-gray-500">
                Browse our frequently asked questions or submit a ticket to our support team.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
            
            <!-- FAQs Section -->
            <div class="bg-white rounded-3xl p-8 shadow-xl shadow-gray-200/50 border border-gray-100">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-12 h-12 rounded-2xl bg-primary-100 text-primary-600 flex items-center justify-center text-2xl shadow-inner">
                        ❓
                    </div>
                    <h2 class="text-2xl font-bold text-gray-900">Frequently Asked Questions</h2>
                </div>

                @if (_loadingFaqs)
                {
                    <LoadingSpinner Message="Loading FAQs..." />
                }
                else if (_faqs.Count == 0)
                {
                    <EmptyState Icon="📭" Title="No FAQs found" Message="Check back later." />
                }
                else
                {
                    <div class="space-y-4">
                        @foreach (var faq in _faqs)
                        {
                            <div class="border border-gray-100 rounded-2xl overflow-hidden shadow-sm transition-all duration-200 hover:border-primary-200">
                                <button class="w-full text-left px-6 py-4 flex items-center justify-between bg-gray-50 hover:bg-white transition-colors focus:outline-none"
                                        @onclick="() => ToggleFaq(faq.Id)">
                                    <span class="font-semibold text-gray-800 pr-8">@faq.Question</span>
                                    <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center shadow-sm text-gray-400 group-hover:text-primary-600 transition-colors shrink-0">
                                        <svg class="w-5 h-5 transform transition-transform duration-300 @(IsExpanded(faq.Id) ? "rotate-180" : "")" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                        </svg>
                                    </div>
                                </button>
                                
                                @if (IsExpanded(faq.Id))
                                {
                                    <div class="px-6 py-5 bg-white border-t border-gray-50 text-gray-600 leading-relaxed text-sm animate-fade-in">
                                        @faq.Answer
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Submit Ticket Section -->
            <div class="bg-white rounded-3xl p-8 shadow-xl shadow-gray-200/50 border border-gray-100 relative overflow-hidden group">
                <div class="absolute top-0 right-0 w-64 h-64 bg-primary-50 rounded-full blur-3xl opacity-50 -translate-y-1/2 translate-x-1/2 group-hover:opacity-100 transition-opacity duration-700"></div>
                
                <div class="relative z-10">
                    <div class="flex items-center gap-4 mb-8">
                        <div class="w-12 h-12 rounded-2xl bg-indigo-100 text-indigo-600 flex items-center justify-center text-2xl shadow-inner">
                            ✉️
                        </div>
                        <h2 class="text-2xl font-bold text-gray-900">Submit a Ticket</h2>
                    </div>

                    @if (_ticketSubmitted)
                    {
                        <div class="text-center py-10 animate-fade-in">
                            <div class="w-20 h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-6 text-4xl shadow-inner">
                                ✓
                            </div>
                            <h3 class="text-2xl font-bold text-gray-900 mb-2">Ticket Submitted!</h3>
                            <p class="text-gray-500 mb-8 max-w-sm mx-auto">
                                We've received your request and our support team will get back to you shortly.
                            </p>
                            <button @onclick="ResetForm"
                                    class="px-6 py-3 bg-gray-100 text-gray-700 rounded-xl font-semibold hover:bg-gray-200 transition-colors">
                                Submit another ticket
                            </button>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="_ticketModel" OnValidSubmit="HandleSubmit" class="space-y-5">
                            <DataAnnotationsValidator />
                            
                            <!-- Email -->
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Email Address</label>
                                <InputText @bind-Value="_ticketModel.Email" 
                                           class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 focus:bg-white transition-all outline-none"
                                           placeholder="your@email.com" />
                                <ValidationMessage For="@(() => _ticketModel.Email)" class="text-red-500 text-xs mt-1 ml-1" />
                            </div>

                            <!-- Subject -->
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Subject</label>
                                <InputText @bind-Value="_ticketModel.Subject" 
                                           class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 focus:bg-white transition-all outline-none"
                                           placeholder="Brief summary of your issue" />
                                <ValidationMessage For="@(() => _ticketModel.Subject)" class="text-red-500 text-xs mt-1 ml-1" />
                            </div>

                            <!-- Description -->
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Description</label>
                                <InputTextArea @bind-Value="_ticketModel.Description" rows="5"
                                               class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 focus:bg-white transition-all outline-none resize-none"
                                               placeholder="Please describe your issue in detail..." />
                                <ValidationMessage For="@(() => _ticketModel.Description)" class="text-red-500 text-xs mt-1 ml-1" />
                            </div>

                            <button type="submit" disabled="@_submitting"
                                    class="w-full py-4 px-6 bg-gradient-to-r from-primary-600 to-indigo-600 hover:from-primary-700 hover:to-indigo-700 text-white rounded-xl font-bold shadow-lg shadow-primary-500/30 hover:shadow-primary-500/50 transition-all disabled:opacity-70 disabled:cursor-not-allowed flex items-center justify-center gap-2">
                                @if (_submitting)
                                {
                                    <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                    </svg>
                                    <span>Submitting...</span>
                                }
                                else
                                {
                                    <span>Submit Ticket</span>
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                    </svg>
                                }
                            </button>
                            <p class="text-xs text-center text-gray-400 mt-4">
                                Limit 1 ticket per email per day.
                            </p>
                        </EditForm>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@code {
    private List<Bookify.Client.Models.FAQ.FaqModel> _faqs = new();
    private bool _loadingFaqs = true;
    private HashSet<Guid> _expandedFaqs = new();

    private Bookify.Client.Models.SupportTicket.TicketModel _ticketModel = new();
    private bool _submitting = false;
    private bool _ticketSubmitted = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadFaqsAsync();
    }

    private async Task LoadFaqsAsync()
    {
        _loadingFaqs = true;
        var result = await FAQService.GetAllAsync();
        if (result.Success)
        {
            _faqs = result.Data ?? new();
        }
        _loadingFaqs = false;
    }

    private void ToggleFaq(Guid id)
    {
        if (_expandedFaqs.Contains(id)) _expandedFaqs.Remove(id);
        else _expandedFaqs.Add(id);
    }

    private bool IsExpanded(Guid id) => _expandedFaqs.Contains(id);

    private async Task HandleSubmit()
    {
        _submitting = true;
        
        var result = await TicketService.SubmitAsync(_ticketModel);
        
        if (result.Success)
        {
            _ticketSubmitted = true;
        }
        
        _submitting = false;
    }

    private void ResetForm()
    {
        _ticketModel = new();
        _ticketSubmitted = false;
    }
}
