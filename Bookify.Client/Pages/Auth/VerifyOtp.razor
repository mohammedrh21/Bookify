@page "/verify-otp"
<PageTitle>Verify OTP — Bookify</PageTitle>

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-primary-50 to-blue-100 py-12 px-4">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 p-8">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-primary-600 rounded-2xl shadow-lg mb-3">
                    <i class="fa-solid fa-shield-halved text-white text-2xl"></i>
                </div>
                <h1 class="text-2xl font-bold text-gray-900">Verify OTP</h1>
                <p class="text-gray-400 text-sm mt-1">Enter the 6-digit code sent to @Email</p>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-100 flex items-start gap-3 text-red-700 animate-fade-in shadow-sm">
                    <i class="fa-solid fa-circle-exclamation text-red-500 mt-1"></i>
                    <p class="text-sm font-medium">@_error</p>
                </div>
            }

            <EditForm Model="_model" OnValidSubmit="HandleSubmit" class="space-y-5">
                <DataAnnotationsValidator />

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5 ml-1">OTP Code</label>
                    <div class="relative">
                        <i class="fa-solid fa-lock-open absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        <InputText @bind-Value="_model.Otp" type="text" maxlength="6"
                                   class="w-full pl-11 pr-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-300 focus:border-primary-400 text-sm tracking-widest text-center font-bold transition-all"
                                   placeholder="123456" />
                    </div>
                </div>

                <button type="submit" disabled="@_loading"
                        class="w-full py-4 bg-primary-600 hover:bg-primary-700 disabled:opacity-60 text-white font-bold rounded-xl text-sm transition-all shadow-md flex items-center justify-center gap-2 mt-2">
                    @if (_loading)
                    {
                        <div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
                        <span>Verifying...</span>
                    }
                    else
                    {
                        <span>Verify OTP</span>
                        <i class="fa-solid fa-check ml-1"></i>
                    }
                </button>
            </EditForm>
        </div>
    </div>
</div>

