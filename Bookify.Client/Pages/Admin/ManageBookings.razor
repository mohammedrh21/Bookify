@page "/admin/bookings"
@attribute [Authorize(Roles = "Admin")]


<PageTitle>Manage Bookings — Bookify Admin</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Manage Bookings</h1>
    </div>

    <!-- ── Filter Panel ─────────────────────────────────────────── -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-6 space-y-4">

        <!-- Row 1: Search + Status -->
        <div class="flex flex-col sm:flex-row gap-3">
            <div class="relative flex-1">
                <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
                <input value="@_search" @oninput="OnSearchChanged"
                       placeholder="Search by service, client or staff name..."
                       class="w-full pl-9 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-300" />
            </div>

            <select @bind="_statusFilter" @bind:after="ApplyFilters"
                    class="px-4 py-2.5 rounded-xl border border-gray-200 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-300 min-w-[155px]">
                <option value="">All Statuses</option>
                <option value="Pending">Pending</option>
                <option value="Approved">Approved</option>
                <option value="Completed">Completed</option>
                <option value="Cancelled">Cancelled</option>
            </select>
        </div>

        <!-- Row 2: Date Range + Staff Name + Category -->
        <div class="flex flex-col sm:flex-row gap-3 flex-wrap">
            <div class="flex items-center gap-2 flex-1 min-w-[220px]">
                <label class="text-xs font-semibold text-gray-500 whitespace-nowrap">From</label>
                <input @bind="_dateFrom" @bind:after="ApplyFilters" type="date"
                       class="flex-1 px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-300" />
            </div>
            <div class="flex items-center gap-2 flex-1 min-w-[220px]">
                <label class="text-xs font-semibold text-gray-500 whitespace-nowrap">To</label>
                <input @bind="_dateTo" @bind:after="ApplyFilters" type="date"
                       class="flex-1 px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-300" />
            </div>
            <input value="@_staffNameFilter" @oninput="OnStaffNameChanged"
                   placeholder="Filter by staff name..."
                   class="flex-1 min-w-[175px] px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-300" />

            <select @bind="_categoryFilter" @bind:after="ApplyFilters"
                    class="flex-1 min-w-[175px] px-4 py-2.5 rounded-xl border border-gray-200 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-300">
                <option value="">All Categories</option>
                @foreach (var cat in _categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>

            <button @onclick="ResetFilters"
                    class="px-5 py-2.5 text-sm font-medium text-gray-500 bg-gray-100 hover:bg-gray-200 rounded-xl transition-colors whitespace-nowrap">
                <i class="fa-solid fa-rotate-right mr-1"></i> Reset
            </button>
        </div>
    </div>

    @if (_loading)
    {
        <LoadingSpinner />
    }
    else if (_bookings.Count == 0)
    {
        <EmptyState Icon="📭" Title="No bookings found" Message="No bookings match your current supervision filters." />
    }
    else
    {
        <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-sm">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 border-b border-gray-100">
                        <tr>
                            @foreach (var h in new[] { "Service", "Client", "Staff", "Date & Time", "Price", "Status" })
                            {
                                <th class="text-left px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider whitespace-nowrap">
                                    @h
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        @foreach (var b in _bookings)
                        {
                            <tr class="hover:bg-gray-50/80 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="text-sm font-semibold text-gray-900">@b.ServiceName</div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm text-gray-800 font-medium flex items-center gap-2">
                                        <div class="w-6 h-6 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center text-[10px] font-bold">
                                            @GetInitials(b.ClientName)
                                        </div>
                                        @b.ClientName
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">@b.StaffName</td>
                                <td class="px-6 py-4 text-sm text-gray-600 whitespace-nowrap">
                                    <div class="font-medium text-gray-900">@b.Date.ToString("MMM dd, yyyy")</div>
                                    <div class="text-gray-400 text-xs">@b.Time.ToString(@"hh\:mm")</div>
                                </td>
                                <td class="px-6 py-4 text-sm font-bold text-gray-900">
                                    $@b.Price.ToString("F2")
                                </td>
                                <td class="px-6 py-4">
                                    <StatusBadge Status="@b.Status" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <Pagination CurrentPage="_currentPage" TotalPages="_totalPages" TotalCount="_totalCount" OnPageChanged="OnPageChanged" />
        </div>
    }
</div>

