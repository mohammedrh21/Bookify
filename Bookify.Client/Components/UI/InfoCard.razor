<div class="bg-white border border-gray-200 p-6 rounded-2xl shadow-sm hover:shadow-md transition">

    <div class="flex items-center gap-4">

        <div class="w-12 h-12 flex items-center justify-center
                    bg-blue-100 text-blue-600 rounded-xl">
            <i class="fas @Icon text-lg"></i>
        </div>

        <div>
            <p class="text-sm text-gray-500">@Title</p>
            <p class="text-lg font-semibold text-gray-800">@Value</p>
        </div>

    </div>

</div>

@code {

    [Parameter, EditorRequired]
    public string Title { get; set; } = default!;

    [Parameter, EditorRequired]
    public string Value { get; set; } = default!;

    [Parameter]
    public string Icon { get; set; } = "fa-circle";
}