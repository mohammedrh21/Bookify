@page "/"
@using Bookify.Client.Components.UI.Home
<PageTitle>Bookify — Book Services Online</PageTitle>
<div class="w-full">

    <HomeHero />
    <HowItWorks />
    <ProviderHighlights />
    <TrustSection />
    <!-- ── Categories ─────────────────────────────────────────────────────────── -->
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-10">
                <h2 class="text-3xl font-bold text-gray-900">Browse by Category</h2>
                <p class="text-gray-400 mt-2">Find the service that fits your needs</p>
            </div>

            @if (_loadingCategories)
            {
                <LoadingSpinner Message="Loading categories..." />
            }
            else if (_categories.Count == 0)
            {
                <EmptyState Icon="🗂️" Title="No categories yet" Message="Check back soon." />
            }
            else
            {
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
                    @foreach (var cat in _categories)
                    {
                        <CategoryCard Category="cat"
                                      IsSelected="_selectedCategoryId == cat.Id"
                                      OnClick="() => SelectCategory(cat.Id)" />
                    }
                </div>
            }
        </div>
    </section>

    <FinalCTA />
</div>

<!-- ── Featured Services ──────────────────────────────────────────────────── -->
<section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-10">
            <div>
                <h2 class="text-3xl font-bold text-gray-900">Featured Services</h2>
                <p class="text-gray-400 mt-1">Popular services available right now</p>
            </div>
            <a href="/services"
               class="text-primary-600 hover:text-primary-700 font-semibold text-sm flex items-center gap-1">
                View all
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </a>
        </div>

        @if (_loadingServices)
        {
            <LoadingSpinner />
        }
        else if (_services.Count == 0)
        {
            <EmptyState Icon="🛎️" Title="No services yet" Message="Services will appear here soon." />
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                @foreach (var svc in _services.Where(x=>!x.IsDeleted).Take(8))
                {
                    <ServiceCard Service="svc" />
                }
            </div>
        }
    </div>
</section>



