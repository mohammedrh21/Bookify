@page "/booking/service-bookings"
@attribute [Authorize(Roles = "Staff")]

<PageTitle>Service Bookings — Bookify Staff</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Service Bookings</h1>
    </div>

    @* ── Filter Panel ──────────────────────────────────────────── *@
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-6 space-y-4">

        @* Row 1: Search + Status + Date Preset *@
        <div class="flex flex-col sm:flex-row gap-3">
            <div class="relative flex-1">
                <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
                <input value="@_search" @oninput="OnSearchChanged"
                       placeholder="Search by client name..."
                       class="w-full pl-9 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-300" />
            </div>

            <select @bind="_statusFilter" @bind:after="ApplyFilters"
                    class="px-4 py-2.5 rounded-xl border border-gray-200 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-300 min-w-[155px]">
                <option value="">All Statuses</option>
                <option value="Pending">Pending</option>
                <option value="Approved">Approved</option>
                <option value="Completed">Completed</option>
                <option value="Cancelled">Cancelled</option>
            </select>

            <select @bind="_datePreset" @bind:after="OnDatePresetChanged"
                    class="px-4 py-2.5 rounded-xl border border-gray-200 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-300 min-w-[155px]">
                <option value="">All Dates</option>
                <option value="Today">Today</option>
                <option value="ThisWeek">This Week</option>
                <option value="ThisMonth">This Month</option>
                <option value="Custom">Custom Range</option>
            </select>
        </div>

        @* Row 2: Custom date range (shown only when "Custom" is selected) + Sort + Reset *@
        <div class="flex flex-col sm:flex-row gap-3 flex-wrap">
            @if (_datePreset == "Custom")
            {
                <div class="flex items-center gap-2 flex-1 min-w-[220px]">
                    <label class="text-xs font-semibold text-gray-500 whitespace-nowrap">From</label>
                    <input @bind="_dateFrom" @bind:after="ApplyFilters" type="date"
                           class="flex-1 px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-300" />
                </div>
                <div class="flex items-center gap-2 flex-1 min-w-[220px]">
                    <label class="text-xs font-semibold text-gray-500 whitespace-nowrap">To</label>
                    <input @bind="_dateTo" @bind:after="ApplyFilters" type="date"
                           class="flex-1 px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-300" />
                </div>
            }

            <button @onclick="ToggleSort"
                    class="px-4 py-2.5 rounded-xl border border-gray-200 text-sm font-medium hover:bg-gray-50 transition-colors whitespace-nowrap flex items-center gap-1.5"
                    title="Sort by appointment date">
                <i class="fa-solid fa-calendar-days text-gray-500"></i>
                Date
                @if (_sortAscending)
                {
                    <i class="fa-solid fa-arrow-up text-blue-600"></i>
                }
                else
                {
                    <i class="fa-solid fa-arrow-down text-blue-600"></i>
                }
            </button>

            <button @onclick="ResetFilters"
                    class="px-5 py-2.5 text-sm font-medium text-gray-500 bg-gray-100 hover:bg-gray-200 rounded-xl transition-colors whitespace-nowrap">
                <i class="fa-solid fa-rotate-right mr-1"></i> Reset
            </button>
        </div>
    </div>

    @* ── Content ───────────────────────────────────────────────── *@
    @if (_loading)
    {
        <LoadingSpinner Message="Loading your bookings..." />
    }
    else if (_bookings == null || !_bookings.Any())
    {
        <EmptyState Icon="📅" Title="No bookings found"
                    Message="No bookings match your current filters." />
    }
    else
    {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-50 border-b border-gray-100 text-gray-500 text-sm font-medium uppercase tracking-wider">
                            <th class="px-6 py-4">Service</th>
                            <th class="px-6 py-4">Client Name</th>
                            <th class="px-6 py-4">Date & Time</th>
                            <th class="px-6 py-4">Duration</th>
                            <th class="px-6 py-4">Price</th>
                            <th class="px-6 py-4">Status</th>
                            <th class="px-6 py-4 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var booking in _bookings)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-5">
                                    <div class="font-semibold text-gray-900">@booking.ServiceName</div>
                                </td>
                                <td class="px-6 py-5 text-gray-600">
                                    <div class="flex items-center gap-2">
                                        <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs">
                                            @GetInitials(booking.ClientName)
                                        </div>
                                        <span>@booking.ClientName</span>
                                    </div>
                                </td>
                                <td class="px-6 py-5">
                                    <div class="text-gray-900 font-medium">@booking.Date.ToString("MMM dd, yyyy")</div>
                                    <div class="text-gray-500 text-sm">@booking.Time.ToString(@"hh\:mm")</div>
                                </td>
                                <td class="px-6 py-5 text-gray-600">
                                    @booking.DurationMinutes min
                                </td>
                                <td class="px-6 py-5 font-medium text-gray-900">
                                    $@booking.Price.ToString("F2")
                                </td>
                                <td class="px-6 py-5">
                                    <StatusBadge Status="@booking.Status" />
                                </td>
                                <td class="px-6 py-5">
                                    <div class="flex items-center justify-center gap-2">
                                        @if (booking.Status.Equals("Pending", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <button @onclick="() => Approve(booking.Id)"
                                                    class="p-2 text-green-600 hover:bg-green-50 rounded-lg transition-colors"
                                                    title="Approve">
                                                <i class="fa-solid fa-check"></i>
                                            </button>
                                            <button @onclick="() => Reject(booking.Id)"
                                                    class="p-2 text-orange-600 hover:bg-orange-50 rounded-lg transition-colors"
                                                    title="Reject">
                                                <i class="fa-solid fa-times"></i>
                                            </button>
                                        }
                                        else if (booking.Status.Equals("Approved", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <button @onclick="() => Complete(booking.Id)"
                                                    class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors"
                                                    title="Mark as Completed">
                                                <i class="fa-solid fa-calendar-check"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <Pagination CurrentPage="_currentPage" TotalPages="_totalPages" TotalCount="_totalCount" OnPageChanged="OnPageChanged" />
        </div>
    }
</div>



