<div class="bg-white rounded-3xl border border-gray-100 overflow-hidden shadow-sm hover-lift flex flex-col group relative">
    <!-- Top color band -->
    <div class="h-2 bg-gradient-to-r from-primary-400 via-blue-500 to-indigo-600"></div>

    <div class="p-5 flex flex-col flex-1">

        <!-- Title + Price -->
        <div class="flex items-start justify-between mb-3">
            <h3 class="font-bold text-gray-900 text-lg leading-snug flex-1 pr-2 group-hover:text-primary-600 transition-colors">
                @Service.Name
            </h3>

            <span class="text-lg font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-indigo-600 whitespace-nowrap">
                $@Service.Price.ToString("F0")
            </span>
        </div>

        <!-- Description -->
        <p class="text-gray-400 text-sm mb-4 line-clamp-2 flex-1">
            @Service.Description
        </p>

        <!-- Info Row -->
        <div class="space-y-3 mb-6 flex-1 text-sm text-gray-500">
            <!-- Duration -->
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-blue-50 flex items-center justify-center text-primary-500">
                        <i class="fa-regular fa-clock text-xs"></i>
                    </div>
                    <span>Duration</span>
                </div>
                <span class="font-semibold text-gray-800">@Service.Duration min</span>
            </div>

            <!-- Availability -->
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-500">
                        <i class="fa-regular fa-calendar-check text-xs"></i>
                    </div>
                    <span>Available</span>
                </div>
                <span class="font-semibold text-gray-800">
                    @DateTime.Today.Add(Service.TimeStart).ToString("hh:mm tt") - @DateTime.Today.Add(Service.TimeEnd).ToString("hh:mm tt")
                </span>
            </div>

            <!-- Staff -->
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-purple-50 flex items-center justify-center text-purple-500">
                        <i class="fa-regular fa-user text-xs"></i>
                    </div>
                    <span>Staff</span>
                </div>
                <span class="font-semibold text-gray-800">@Service.StaffName</span>
            </div>
        </div>

        <!-- Button -->
        <a href="/book/@Service.Id"
           class="block w-full text-center py-3.5 bg-gradient-to-r from-primary-600 to-indigo-600 hover:from-primary-700 hover:to-indigo-700 text-white font-bold rounded-2xl text-sm transition-all shadow-md shadow-primary-500/20 hover:shadow-lg hover:shadow-primary-500/40">
            Book Now
        </a>

    </div>
</div>

@code {
    [Parameter] public ServiceModel Service { get; set; } = default!;
}