@page "/admin/dashboard"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Dashboard — Bookify Admin</PageTitle>

<div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
    
    <!-- 1. Dashboard Header (Top Bar) -->
    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6 bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Executive Dashboard</h1>
            <p class="text-gray-500 mt-1">Real-time platform analytics and business intelligence</p>
        </div>
        
        <div class="flex flex-wrap items-center gap-4">
            <!-- Date Range Picker (Simplified for demo, usually looks like a dropdown or two inputs) -->
            <div class="flex items-center gap-2 bg-gray-50 p-1.5 rounded-2xl border border-gray-100">
                <input type="date" @bind="_startDate" @bind:event="onchange" class="bg-transparent border-none text-sm font-medium focus:ring-0 px-3 py-1 cursor-pointer" />
                <span class="text-gray-400">→</span>
                <input type="date" @bind="_endDate" @bind:event="onchange" class="bg-transparent border-none text-sm font-medium focus:ring-0 px-3 py-1 cursor-pointer" />
            </div>

            <!-- Quick Filters -->
            <div class="flex items-center gap-2 bg-gray-50 p-1 rounded-2xl border border-gray-100">
                <button @onclick='() => SetRange("week")' class="px-4 py-1.5 text-xs font-bold rounded-xl transition-all @(CurrentRange == "week" ? "bg-white text-primary-600 shadow-sm" : "text-gray-500 hover:text-gray-700")">WEEK</button>
                <button @onclick='() => SetRange("month")' class="px-4 py-1.5 text-xs font-bold rounded-xl transition-all @(CurrentRange == "month" ? "bg-white text-primary-600 shadow-sm" : "text-gray-500 hover:text-gray-700")">MONTH</button>
                <button @onclick='() => SetRange("year")' class="px-4 py-1.5 text-xs font-bold rounded-xl transition-all @(CurrentRange == "year" ? "bg-white text-primary-600 shadow-sm" : "text-gray-500 hover:text-gray-700")">YEAR</button>
            </div>

            <button @onclick="LoadDashboardAsync" class="p-2.5 bg-primary-600 text-white rounded-2xl hover:bg-primary-700 transition-colors shadow-lg shadow-primary-100">
                <i class="fas fa-sync-alt @(_loading ? "animate-spin" : "")"></i>
            </button>
        </div>
    </div>

    @if (_loading)
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            @for (int i = 0; i < 4; i++) { <div class="h-32 bg-white rounded-3xl border border-gray-100 animate-pulse"></div> }
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 h-96 bg-white rounded-3xl border border-gray-100 animate-pulse"></div>
            <div class="h-96 bg-white rounded-3xl border border-gray-100 animate-pulse"></div>
        </div>
    }
    else
    {
        <!-- 2. KPI Cards Section -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <KPICard Title="Total Bookings" Value="@_stats.TotalBookings.ToString("N0")" Trend="@_stats.TotalBookingsTrend" Icon="fa-calendar-alt" Color="blue" />
            <KPICard Title="Pending Approval" Value="@_stats.PendingBookings.ToString("N0")" Trend="@_stats.PendingBookingsTrend" Icon="fa-clock" Color="amber" />
            <KPICard Title="Total Revenue" Value=@_stats.TotalRevenue.ToString("N0") Trend="@_stats.TotalRevenueTrend" Icon="fa-dollar-sign" Color="green" />
            <KPICard Title="Active Services" Value="@_stats.TotalServices.ToString("N0")" Trend="@_stats.TotalServicesTrend" Icon="fa-concierge-bell" Color="purple" />
        </div>

        <!-- 3. Main Analytics Section -->
        <div class="grid grid-cols-1 lg:grid-cols-10 gap-8">
            <!-- Left (60%) – Booking Trend Chart -->
            <div class="lg:col-span-6 bg-white p-8 rounded-3xl border border-gray-100 shadow-sm overflow-hidden flex flex-col h-full">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h2 class="text-xl font-bold text-gray-900">Booking Velocity</h2>
                        <p class="text-xs text-gray-400 mt-1">Aggregated booking trends over time</p>
                    </div>
                    <div class="flex items-center gap-2">
                         <span class="flex items-center gap-1.5 text-xs font-semibold text-gray-500">
                            <span class="w-2.5 h-2.5 bg-primary-500 rounded-full"></span> Bookings
                         </span>
                    </div>
                </div>
                <div class="flex-1 min-h-[350px] relative">
                    @if (!_stats.BookingTrends.Any())
                    {
                        <div class="absolute inset-0 flex flex-col items-center justify-center text-gray-400">
                            <i class="fas fa-chart-line text-4xl mb-3 opacity-20"></i>
                            <p>No trend data available for this range</p>
                        </div>
                    }
                    <canvas id="bookingsChart"></canvas>
                </div>
            </div>

            <!-- Right (40%) – Category Distribution -->
            <div class="lg:col-span-4 bg-white p-8 rounded-3xl border border-gray-100 shadow-sm flex flex-col h-full">
                <h2 class="text-xl font-bold text-gray-900 mb-2">Demand Portfolio</h2>
                <p class="text-xs text-gray-400 mb-8">Service distribution across categories</p>
                <div class="flex-1 min-h-[350px] relative items-center justify-center flex">
                    @if (!_stats.CategoryDistribution.Any())
                    {
                        <div class="absolute inset-0 flex flex-col items-center justify-center text-gray-400">
                            <i class="fas fa-chart-pie text-4xl mb-3 opacity-20"></i>
                            <p>No distribution data</p>
                        </div>
                    }
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>

        <!-- 4. Insights Section (Smart Analytics) -->
        @if (_stats.Insights.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                @foreach (var insight in _stats.Insights)
                {
                    <div class="bg-white p-6 rounded-3xl border border-s-4 border-gray-100 shadow-sm hover:shadow-md transition-shadow flex items-start gap-4 @GetInsightBorderColor(insight.Color)">
                        <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-xl shrink-0 @GetInsightIconBg(insight.Color)">
                            <i class="fas fa-@insight.Icon"></i>
                        </div>
                        <div>
                            <h3 class="font-bold text-gray-900">@insight.Title</h3>
                            <p class="text-sm text-gray-500 mt-1">@insight.Description</p>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- 5. Performance Section -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Left – Top Staff -->
            <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="px-8 py-6 border-b border-gray-50 flex items-center justify-between">
                    <h2 class="text-xl font-bold text-gray-900">Elite Performance</h2>
                    <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">TOP STAFF</span>
                </div>
                <div class="p-4 overflow-x-auto">
                    <table class="w-full">
                        <thead class="text-left text-xs text-gray-400 uppercase">
                            <tr>
                                <th class="px-4 py-3">Staff Member</th>
                                <th class="px-4 py-3 text-center">Bookings</th>
                                <th class="px-4 py-3 text-right">Revenue</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50">
                            @foreach (var staff in _stats.TopStaff)
                            {
                                <tr class="group hover:bg-gray-50 transition-colors">
                                    <td class="px-4 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-primary-100 text-primary-600 rounded-full flex items-center justify-center font-bold text-sm">
                                                @staff.StaffName[0]
                                            </div>
                                            <div>
                                                <p class="font-bold text-gray-900 group-hover:text-primary-600 transition-colors">@staff.StaffName</p>
                                                <div class="flex items-center gap-1 text-xs text-yellow-500">
                                                    <i class="fas fa-star"></i>
                                                    <span class="text-gray-400">@staff.Rating</span>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-4 py-4 text-center font-bold text-gray-700">@staff.CompletedBookings</td>
                                    <td class="px-4 py-4 text-right">
                                        <span class="px-3 py-1 bg-green-50 text-green-600 rounded-lg font-bold text-sm">
                                            $@staff.Revenue.ToString("N0")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Right – Most Booked Services -->
            <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="px-8 py-6 border-b border-gray-50 flex items-center justify-between">
                    <h2 class="text-xl font-bold text-gray-900">Popular Services</h2>
                    <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">TRENDING</span>
                </div>
                <div class="p-8 space-y-6">
                    @foreach (var svc in _stats.MostBookedServices)
                    {
                        <div>
                            <div class="flex items-center justify-between mb-2">
                                <span class="font-bold text-gray-900">@svc.ServiceName</span>
                                <span class="text-sm font-medium text-gray-400">@svc.BookingCount Bookings</span>
                            </div>
                            <div class="w-full bg-gray-100 h-2.5 rounded-full overflow-hidden">
                                <div class="bg-primary-500 h-full rounded-full" style="width: @(CalculateWidth(svc.BookingCount))%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- 6. Operational Monitoring Section -->
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-8 py-6 border-b border-gray-50 flex items-center justify-between">
                <h2 class="text-xl font-bold text-gray-900">Recent Operations</h2>
                <div class="flex items-center gap-2">
                    <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                    <span class="text-xs font-bold text-gray-400 uppercase">Live Feed</span>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50/50 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">
                        <tr>
                            <th class="px-8 py-4">Client</th>
                            <th class="px-8 py-4">Service</th>
                            <th class="px-8 py-4">Professional</th>
                            <th class="px-8 py-4">Scheduled</th>
                            <th class="px-8 py-4 text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @if (!_stats.RecentBookings.Any())
                        {
                            <tr>
                                <td colspan="5" class="px-8 py-10 text-center text-gray-400">
                                    <div class="flex flex-col items-center">
                                        <i class="fas fa-folder-open text-3xl mb-2 opacity-20"></i>
                                        <p>No recent bookings recorded</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        @foreach (var b in _stats.RecentBookings)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-8 py-4 font-bold text-gray-900">@b.ClientName</td>
                                <td class="px-8 py-4 text-gray-600">@b.ServiceName</td>
                                <td class="px-8 py-4 text-gray-600">@b.StaffName</td>
                                <td class="px-8 py-4">
                                    <div class="text-gray-900 font-medium">@b.Date.ToShortDateString()</div>
                                    <div class="text-xs text-gray-400">@b.Time.ToString(@"hh\:mm")</div>
                                </td>
                                <td class="px-8 py-4 text-center">
                                    <div class="flex flex-col gap-1 items-center">
                                        <span class="px-3 py-1 rounded-full text-xs font-bold @GetPaymentStatusBadgeClass(b.PaymentStatus)">
                                            @b.PaymentStatus
                                        </span>
                                        <span class="px-3 py-1 rounded-full text-[10px] font-bold @GetStatusBadgeClass(b.Status)">
                                            @b.Status
                                        </span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

