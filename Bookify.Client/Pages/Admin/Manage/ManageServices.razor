@page "/admin/services"
@attribute [Authorize(Roles = "Admin")]


<PageTitle>Services — Bookify Admin</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Services</h1>
        <p class="text-gray-400 mt-1">Review services on the platform.</p>
    </div>

    <!-- ── Filter Bar ─────────────────────────────────────────────── -->
    <div class="flex flex-col sm:flex-row gap-3 mb-6">
        <!-- Search -->
        <div class="relative flex-1">
            <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <input @bind="_search" @oninput="OnSearchChanged"
                   placeholder="Search by service name or staff name..."
                   class="w-full pl-11 pr-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-300 transition-all shadow-sm" />
        </div>
        <!-- Category Filter -->
        <select @bind="_categoryFilter" @bind:after="OnCategoryChanged"
                class="px-4 py-3 rounded-xl border border-gray-200 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-300 min-w-[175px] shadow-sm">
            <option value="">All Categories</option>
            @foreach (var cat in _categories)
            {
                <option value="@cat.Id">@cat.Name</option>
            }
        </select>
    </div>

    @if (_loading)
    {
        <LoadingSpinner />
    }
    else if (_services.Count == 0)
    {
        <EmptyState Icon="🛎️" Title="No services found" Message="No services match your filters." />
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            @foreach (var svc in _services)
            {
                <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col h-full">
                    @if (!string.IsNullOrEmpty(svc.ImagePath))
                    {
                        <div class="w-full h-32 relative overflow-hidden shrink-0">
                            <img src="@svc.ImagePath" class="w-full h-full object-cover" />
                        </div>
                    }
                    else
                    {
                        <div class="h-1 bg-gradient-to-r from-primary-400 to-primary-600 shrink-0"></div>
                    }
                    
                    <div class="p-5 flex-1 flex flex-col">
                        <!-- Header -->
                        <div class="flex items-start justify-between mb-2">
                            <h3 class="font-semibold text-gray-900 flex-1 pr-2 truncate">@svc.Name</h3>
                            <span class="text-primary-600 font-bold text-sm shrink-0">$@svc.Price.ToString("F0")</span>
                        </div>

                        @if (!string.IsNullOrEmpty(svc.CategoryName))
                        {
                            <span class="inline-block text-[10px] px-2 py-0.5 rounded-full bg-indigo-50 text-indigo-600 font-semibold mb-2">
                                @svc.CategoryName
                            </span>
                        }

                        <p class="text-gray-400 text-xs mb-3">@(string.IsNullOrEmpty(svc.Description) ? "" : (svc.Description.Length > 20 ? svc.Description.Substring(0, 20) + ".." : svc.Description))</p>

                        <div class="flex items-center justify-between text-xs text-gray-400 mb-4">
                            <span>&#9203; @svc.Duration min</span>
                            <span>&#128100; @svc.StaffName</span>
                        </div>

                        <!-- Supervisor Actions: View details + Delete only -->
                        <div class="flex gap-2 mt-auto pt-3">
                            <a href="/service/@svc.Id"
                               class="flex-1 py-2 text-xs font-bold text-center text-primary-600 bg-primary-50 hover:bg-primary-100 rounded-lg transition-colors">
                                View Details
                            </a>
                            <button @onclick="() => DeleteService(svc.Id)"
                                    class="flex-1 py-2 text-xs font-bold text-red-500 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                                Delete
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        <Pagination CurrentPage="_currentPage" TotalPages="_totalPages" TotalCount="_totalCount" OnPageChanged="OnPageChanged" />
    }
</div>



