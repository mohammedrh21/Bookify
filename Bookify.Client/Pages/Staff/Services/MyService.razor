@page "/services/my-service"
@attribute [Authorize(Roles = "Staff")]

<PageTitle>My Service — Bookify</PageTitle>

<div class="max-w-4xl mx-auto px-4 py-10">

    <h1 class="text-3xl font-bold text-gray-900 mb-8">My Service</h1>

    @if (_loading)
    {
        <LoadingSpinner Message="Loading your service..." />
    }
    else if (_loadError)
    {
        <div class="bg-red-50 border-l-4 border-red-400 p-6 rounded-xl">
            <p class="text-red-800 font-semibold mb-2">Failed to load your service</p>
            <p class="text-red-700 text-sm">Please try refreshing the page.</p>
            <button @onclick="ReloadAsync"
                    class="mt-4 px-5 py-2 bg-red-600 text-white rounded-xl hover:bg-red-700 transition">
                Retry
            </button>
        </div>
    }

    @if (!_hasPendingRequest && _showRejectedBanner && _rejectedRequest != null)
    {
        <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl mb-6 flex items-center justify-between">
            <div>
                <p class="text-red-800 font-semibold mb-1">Your previous @_rejectedRequest.Type.ToString().ToLower() request was rejected.</p>
                <p class="text-red-700 text-sm">Reason: <strong>@_rejectedRequest.AdminComment</strong></p>
            </div>
            <button @onclick="DismissRejection" class="px-3 py-1 bg-red-100 text-red-600 rounded-lg hover:bg-red-200 text-xs font-semibold">Dismiss</button>
        </div>
    }

    @if (_service == null)
    {
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 rounded-xl">
            <p class="text-yellow-800">You currently have no service created.</p>
            <button @onclick="GoToCreate"
                    class="mt-4 px-5 py-2 bg-blue-600 text-white rounded-xl hover:bg-blue-700 transition">
                Create Your Service
            </button>
        </div>
    }
    else if (_service.IsDeleted)
    {
        var daysLeft = DaysUntilCanRecreate();
        if (daysLeft > 0)
        {
            <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded-xl">
                <p class="text-red-800 font-semibold mb-1">Your service was deleted.</p>
                <p class="text-red-700 text-sm">You can create a new service in <strong>@daysLeft</strong> days.</p>
            </div>
        }
        else
        {
            <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 rounded-xl">
                <p class="text-yellow-800 font-semibold">Your previous service was deleted over 14 days ago.</p>
                <button @onclick="GoToCreate"
                        class="mt-4 px-5 py-2 bg-blue-600 text-white rounded-xl hover:bg-blue-700 transition">
                    Create New Service
                </button>
            </div>
        }
    }
    else if (!_service.IsActive)
    {
        <div class="bg-blue-50 border-l-4 border-blue-500 p-6 rounded-xl">
            <p class="text-blue-800 font-semibold">Your service creation request is pending Admin approval.</p>
            <p class="text-blue-700 text-sm mt-1">Please wait for confirmation.</p>
        </div>
    }
    else
    {
        <div class="bg-white border border-slate-100 rounded-3xl shadow-2xl shadow-slate-200/50 overflow-hidden mysvc-glow-hover">

            @if (_hasPendingRequest)
            {
                <div class="bg-blue-50 border-l-4 border-blue-500 p-6 m-8 rounded-2xl">
                    <p class="text-blue-800 font-semibold">An update request for this service is pending Admin approval.</p>
                    <p class="text-blue-700 text-sm">You cannot submit further updates until it is processed.</p>
                </div>
            }

            @* ─── Image Banner ────────────────────────────────────────────── *@
            <div class="relative h-64 mysvc-gradient-bg overflow-hidden group/img">
                @if (!string.IsNullOrEmpty(_service.ImagePath))
                {
                    <img src="@_service.ImagePath" class="w-full h-full object-cover transition-transform duration-700 group-hover/img:scale-105" alt="Service Image" />
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/30 to-transparent"></div>
                }

                @* Upload overlay *@
                @if (!_hasPendingRequest)
                {
                    <div class="absolute inset-0 bg-black/0 group-hover/img:bg-black/30 transition-all duration-300 z-10 flex">
                        <label for="serviceImg" class="flex-1 flex flex-col items-center justify-center cursor-pointer">
                            <span class="opacity-0 group-hover/img:opacity-100 transition-all duration-300 transform group-hover/img:translate-y-0 translate-y-4 flex flex-col items-center gap-2">
                                <span class="w-12 h-12 bg-white/20 backdrop-blur-md rounded-xl flex items-center justify-center border border-white/30 shadow-lg">
                                    <i class="fas fa-camera text-white text-xl"></i>
                                </span>
                                <span class="text-white text-xs font-bold uppercase tracking-wider bg-black/40 px-3 py-1 rounded-full backdrop-blur-sm">
                                    @(string.IsNullOrEmpty(_service.ImagePath) ? "Add Cover Photo" : "Change Cover Photo")
                                </span>
                            </span>
                            <InputFile id="serviceImg" OnChange="HandleFileSelected" class="hidden" accept=".jpg,.jpeg,.png" />
                        </label>

                        @if (!string.IsNullOrEmpty(_service.ImagePath))
                        {
                            <button @onclick="RemoveImage"
                                    class="absolute top-4 right-4 bg-white/10 hover:bg-red-500/80 backdrop-blur-md
                                                   text-white w-10 h-10 rounded-xl opacity-0
                                                   group-hover/img:opacity-100 transition-all duration-300 border border-white/20 shadow-lg
                                                   flex items-center justify-center transform hover:scale-110"
                                    title="Remove Photo">
                                <i class="fas fa-trash text-sm"></i>
                            </button>
                        }
                    </div>
                }

                @if (_uploading)
                {
                    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center z-20">
                        <i class="fas fa-circle-notch animate-spin text-white text-3xl"></i>
                    </div>
                }

                @* Service name overlay *@
                @if (!_isEditing)
                {
                    <div class="absolute bottom-0 left-0 right-0 p-8 z-20 pointer-events-none">
                        <span class="inline-block px-3 py-1 bg-white/10 backdrop-blur-md border border-white/10 rounded-full text-white text-xs font-semibold tracking-wider mb-2">
                            @_service.CategoryName
                        </span>
                        <h2 class="text-3xl font-bold text-white tracking-tight drop-shadow-sm">@_service.Name</h2>
                    </div>
                }
            </div>


            @* ─── Action Bar ────────────────────────────────────────────── *@
            @if (!_isEditing)
            {
                <div class="mysvc-glass-overlay px-8 py-4 flex justify-between items-center bg-slate-50/50">
                    <p class="text-sm text-slate-500">Manage your service details and schedule.</p>
                    <div class="flex gap-3">
                        <button @onclick="EnterEditMode"
                                disabled="@_hasPendingRequest"
                                class="bg-indigo-600 text-white px-5 py-2.5 rounded-xl font-semibold text-sm hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed transition duration-300 shadow-lg shadow-indigo-600/20 flex items-center gap-2 transform hover:-translate-y-0.5">
                            <i class="fas fa-pen text-xs"></i> @(_hasPendingRequest ? "Update Pending" : "Edit Service")
                        </button>

                        <button @onclick="OpenDeleteModal"
                                class="bg-red-50 text-red-600 border border-red-100 px-5 py-2.5 rounded-xl font-semibold text-sm hover:bg-red-100 transition duration-300 flex items-center gap-2">
                            <i class="fas fa-trash text-xs"></i> Delete
                        </button>
                    </div>
                </div>
            }


            @* ─── Body: View or Edit ──────────────────────────────────────── *@
            <div class="p-8">
                @if (_isEditing)
                {
                    @* ── Edit Mode ──────────────────────────────────────────── *@
                    <div class="flex items-center justify-between mb-8 pb-4 border-b border-slate-100">
                        <div>
                            <h2 class="text-2xl font-bold text-slate-900">Edit Service</h2>
                            <p class="text-slate-500 text-sm mt-1">Update your service information, pricing and availability.</p>
                        </div>
                        <button @onclick="CancelEdit" class="w-10 h-10 flex items-center justify-center bg-slate-50 hover:bg-slate-100 rounded-full text-slate-400 hover:text-slate-600 transition">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>

                    <EditForm Model="_service" OnValidSubmit="HandleUpdateSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-red-600 mb-6 bg-red-50 p-4 rounded-xl border border-red-100" />

                        <div class="grid md:grid-cols-2 gap-8">
                            <div class="space-y-6">
                                <div class="flex items-center gap-3 mb-2">
                                    <div class="w-10 h-10 flex items-center justify-center bg-indigo-50 text-indigo-600 rounded-xl">
                                        <i class="fas fa-briefcase"></i>
                                    </div>
                                    <h3 class="text-lg font-bold text-slate-800">Basic Information</h3>
                                </div>

                                <div class="bg-slate-50/50 p-6 rounded-2xl border border-slate-100 space-y-5">
                                    <div>
                                        <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                                            Service Name
                                        </label>
                                        <InputText @bind-Value="_service!.Name"
                                                   class="mysvc-input px-4 py-2.5 rounded-xl"
                                                   placeholder="e.g. Premium Haircut" />
                                        <ValidationMessage For="@(() => _service!.Name)" class="text-red-500 text-xs mt-1" />
                                    </div>

                                    <div>
                                        <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                                            Description
                                        </label>
                                        <InputTextArea @bind-Value="_service!.Description"
                                                       rows="4"
                                                       class="mysvc-input px-4 py-2.5 rounded-xl resize-none"
                                                       placeholder="Describe your service..." />
                                        <ValidationMessage For="@(() => _service!.Description)" class="text-red-500 text-xs mt-1" />
                                    </div>
                                </div>
                            </div>


                            <div class="space-y-6">
                                <div class="bg-slate-50/50 p-6 rounded-2xl border border-slate-100">
                                    <div class="flex items-center gap-3 mb-4">
                                        <div class="w-10 h-10 flex items-center justify-center bg-emerald-50 text-emerald-600 rounded-xl">
                                            <i class="fas fa-dollar-sign"></i>
                                        </div>
                                        <h3 class="text-lg font-bold text-slate-800">Pricing & Duration</h3>
                                    </div>

                                    <div class="grid grid-cols-2 gap-4">

                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-2">Price</label>
                                            <div class="relative">
                                                <span class="absolute left-4 top-3.5 text-gray-400">$</span>
                                                <InputNumber @bind-Value="_service!.Price"
                                                             class="w-full pl-8 pr-4 py-3 border border-gray-300 rounded-xl
                                                                            focus:ring-2 focus:ring-green-500 focus:border-green-500
                                                                            transition shadow-sm" />
                                            </div>
                                            <ValidationMessage For="@(() => _service!.Price)" class="text-red-500 text-sm mt-1" />
                                        </div>

                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-2">Duration (minutes)</label>
                                            <div class="relative">
                                                <span class="absolute left-4 top-3.5 text-gray-400">
                                                    <i class="fas fa-clock"></i>
                                                </span>
                                                <InputNumber @bind-Value="_service!.Duration"
                                                             class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-xl
                                                                            focus:ring-2 focus:ring-green-500 focus:border-green-500
                                                                            transition shadow-sm" />
                                            </div>
                                            <ValidationMessage For="@(() => _service!.Duration)" class="text-red-500 text-sm mt-1" />
                                        </div>
                                    </div>
                                </div>

                                <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-8 space-y-6">
                                    <div class="flex items-center gap-3 mb-4">
                                        <div class="w-10 h-10 flex items-center justify-center bg-purple-100 text-purple-600 rounded-lg">
                                            <i class="fas fa-calendar-alt"></i>
                                        </div>
                                        <h3 class="text-xl font-semibold text-gray-800">Availability</h3>
                                    </div>

                                    <div class="grid md:grid-cols-2 gap-6">
                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-2">Start Time</label>
                                            <InputTimeSpan @bind-Value="_service!.TimeStart"
                                                           CssClass="w-full px-4 py-3 border border-gray-300 rounded-xl
                                                                             focus:ring-2 focus:ring-purple-500 focus:border-purple-500
                                                                             transition shadow-sm" />
                                            <ValidationMessage For="@(() => _service!.TimeStart)" class="text-red-500 text-sm mt-1" />
                                        </div>

                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-2">End Time</label>
                                            <InputTimeSpan @bind-Value="_service!.TimeEnd"
                                                           CssClass="w-full px-4 py-3 border border-gray-300 rounded-xl
                                                                             focus:ring-2 focus:ring-purple-500 focus:border-purple-500
                                                                             transition shadow-sm" />
                                            <ValidationMessage For="@(() => _service!.TimeEnd)" class="text-red-500 text-sm mt-1" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="flex justify-end gap-4 mt-10 pt-6 border-t">
                            <button type="button" @onclick="CancelEdit"
                                    class="px-6 py-2.5 border border-gray-300 rounded-xl font-semibold text-gray-700 hover:bg-gray-50 transition">
                                Cancel
                            </button>
                            <button type="submit" disabled="@_isUpdating"
                                    class="px-8 py-2.5 bg-blue-600 text-white rounded-xl font-semibold hover:bg-blue-700 transition flex items-center gap-2 shadow-lg shadow-blue-200">
                                @if (_isUpdating)
                                {
                                    <i class="fas fa-circle-notch animate-spin"></i>
                                    <span>Updating...</span>
                                }
                                else
                                {
                                    <i class="fas fa-check"></i>
                                    <span>Update Service</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                }
                else
                {
                    @* ── View Mode ──────────────────────────────────────────── *@
                    <div class="space-y-8">
                        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
                            <InfoCard Title="Price" Value="@($"${_service.Price:F2}")" Icon="fa-dollar-sign" />
                            <InfoCard Title="Duration" Value="@($"{_service.Duration} min")" Icon="fa-clock" />
                            <InfoCard Title="Category" Value="@_service.CategoryName" Icon="fa-layer-group" />
                        </div>

                        <div class="bg-gray-50 border p-6 rounded-2xl">
                            <h3 class="text-lg font-semibold mb-6">Availability</h3>

                            <div class="grid sm:grid-cols-2 gap-6">
                                <AvailabilityCard Label="Available From"
                                                  Value="@FormatTime(_service.TimeStart)" />
                                <AvailabilityCard Label="Available To"
                                                  Value="@FormatTime(_service.TimeEnd)" />
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@using Bookify.Client.Components.UI.Modals

@if (_showDeleteModal)
{
    <DeleteConfirmationModal Title="Delete Service?" 
                              Message="Please note that you cannot create a new service until 14 days later." 
                              OnConfirm="ConfirmDelete" 
                              OnCancel="CloseDeleteModal" />
}