                <p class="text-slate-500 leading-relaxed">
                    Check availability, pick your preferred time, and book instantly with our secure encrypted system.
                </p>
            </div>

            <!-- Step 3 -->
            <div class="relative z-10 group">
                <div class="w-20 h-20 bg-white border border-slate-100 shadow-soft rounded-3xl flex items-center justify-center text-3xl text-emerald-600 mb-8 group-hover:scale-110 group-hover:bg-emerald-600 group-hover:text-white transition-all duration-300">
                    <i class="fa-solid fa-bolt"></i>
                </div>
                <div class="absolute -top-4 -left-4 w-10 h-10 bg-slate-50 rounded-full flex items-center justify-center font-black text-slate-200 text-xl pointer-events-none">03</div>
                <h3 class="text-xl font-extrabold text-slate-800 mb-4">Instant Confirmation</h3>
                <p class="text-slate-500 leading-relaxed">
                    Receive immediate confirmation and manage everything from your personal dashboard with ease.
                </p>
            </div>

        </div>
    </div>
</section>

