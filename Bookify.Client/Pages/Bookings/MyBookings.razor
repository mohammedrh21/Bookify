@page "/my-bookings"
@attribute [Authorize]
@implements IDisposable

@using Bookify.Client.Models.Common

<PageTitle>My Bookings — Bookify</PageTitle>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">My Bookings</h1>
            <p class="text-gray-400 mt-1">Track and manage your appointments</p>
        </div>
        <a href="/services"
           class="inline-flex items-center px-5 py-2.5 bg-primary-600 text-white font-semibold rounded-xl text-sm hover:bg-primary-700 transition-colors gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            New Booking
        </a>
    </div>

    <!-- Status Tabs -->
    <div class="flex gap-1 mb-6 bg-gray-100 p-1 rounded-xl w-fit flex-wrap">
        @foreach (var tab in _tabs)
        {
            <button @onclick="() => SetTab(tab)"
                    class="px-4 py-2 rounded-lg text-sm font-medium transition-all whitespace-nowrap
                                   @(_activeTab == tab ? "bg-white text-gray-900 shadow-sm" : "text-gray-500 hover:text-gray-700")">
                @tab
                @if (tab != "All")
                {
                    var count = _bookings.Count(b => b.Status.Equals(tab, StringComparison.OrdinalIgnoreCase));
                    if (count > 0)
                    {
                        <span class="ml-1.5 text-xs bg-primary-100 text-primary-700 px-1.5 py-0.5 rounded-full">@count</span>
                    }
                }
            </button>
        }
    </div>

    <!-- Filters and Search -->
    <div class="flex flex-col sm:flex-row justify-between gap-4 mb-6">
        <div class="relative w-full sm:w-96">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <i class="fas fa-search text-gray-400"></i>
            </div>
            <input type="text"
                   value="@_searchQuery"
                   @oninput="OnSearchChanged"
                   class="block w-full pl-10 pr-3 py-2 border border-gray-200 rounded-xl leading-5 bg-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 sm:text-sm transition-colors"
                   placeholder="Search by service name..." />
        </div>
        <div class="flex items-center gap-2">
            <span class="text-sm text-gray-500 font-medium whitespace-nowrap">Sort by Date:</span>
            <select value="@_sortOrder" @onchange="SetSortOrder"
                    class="block w-40 pl-3 pr-10 py-2 border border-gray-200 bg-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 sm:text-sm rounded-xl transition-colors text-gray-700 font-medium shadow-sm">
                <option value="@BookingSortOrder.NewestFirst">Newest First</option>
                <option value="@BookingSortOrder.OldestFirst">Oldest First</option>
            </select>
        </div>
    </div>

    @if (_loading)
    {
        <LoadingSpinner Message="Loading bookings..." />
    }
    else if (_totalItems == 0)
    {
        <EmptyState Icon="📅" Title="No bookings found"
                    Message="@(_activeTab == "All" ? "You haven't made any bookings yet." : $"No {_activeTab.ToLower()} bookings.")"
                    ActionHref="/services" ActionLabel="Browse Services" />
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
            @foreach (var b in _paginatedBookings)
            {
                <BookingCard Booking="b" OnCancel="() => ShowCancelModal(b.Id)" OnRate="ShowRatingModal" />
            }
        </div>

        @if (_totalPages > 1)
        {
            <div class="flex items-center justify-between border border-gray-200 bg-white px-4 py-3 sm:px-6 rounded-xl shadow-sm">
                <div class="flex flex-1 justify-between sm:hidden">
                    <button @onclick="PreviousPage" disabled="@(_currentPage == 1)"
                            class="relative inline-flex items-center rounded-xl border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 disabled:opacity-50">
                        Previous
                    </button>
                    <button @onclick="NextPage" disabled="@(_currentPage == _totalPages)"
                            class="relative ml-3 inline-flex items-center rounded-xl border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 disabled:opacity-50">
                        Next
                    </button>
                </div>
                <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
                    <div>
                        <p class="text-sm text-gray-700">
                            Showing <span class="font-medium">@(((_currentPage - 1) * PageSize) + 1)</span> to 
                            <span class="font-medium">@Math.Min(_currentPage * PageSize, _totalItems)</span> of 
                            <span class="font-medium">@_totalItems</span> results
                        </p>
                    </div>
                    <div>
                        <nav class="isolate inline-flex -space-x-px rounded-xl shadow-sm" aria-label="Pagination">
                            <button @onclick="PreviousPage" disabled="@(_currentPage == 1)"
                                    class="relative inline-flex items-center rounded-l-xl px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0 disabled:opacity-50">
                                <span class="sr-only">Previous</span>
                                <i class="fas fa-chevron-left w-5 h-5 text-center leading-5"></i>
                            </button>
                            @for (int i = 1; i <= _totalPages; i++)
                            {
                                int pageNum = i;
                                <button @onclick="() => _currentPage = pageNum"
                                        class="relative inline-flex items-center px-4 py-2 text-sm font-semibold @(_currentPage == pageNum ? "bg-primary-600 text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600 z-10" : "text-gray-900 ring-1 ring-inset ring-gray-300 hover:bg-gray-50") focus:z-20 focus:outline-offset-0">
                                    @pageNum
                                </button>
                            }
                            <button @onclick="NextPage" disabled="@(_currentPage == _totalPages)"
                                    class="relative inline-flex items-center rounded-r-xl px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0 disabled:opacity-50">
                                <span class="sr-only">Next</span>
                                <i class="fas fa-chevron-right w-5 h-5 text-center leading-5"></i>
                            </button>
                        </nav>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Cancel Confirmation Modal -->
@if (_cancelModalVisible)
{
    <Bookify.Client.Components.UI.Modals.CancelingModal 
        OnConfirm="ConfirmCancel" 
        OnCancel="CloseCancelModal" />
}

<!-- Rating Modal -->
@if (_ratingModalVisible && _bookingToRate != null)
{
    <div class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50 p-4">
        <div class="bg-white rounded-3xl shadow-2xl max-w-md w-full p-8 relative animate-in fade-in zoom-in duration-300">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-amber-50 text-amber-500 rounded-2xl flex items-center justify-center text-2xl mx-auto mb-4">
                    <i class="fas fa-star"></i>
                </div>
                <h2 class="text-2xl font-bold text-gray-900">Rate Service</h2>
                <p class="text-gray-500 mt-1">How was your experience with @_bookingToRate.ServiceName?</p>
            </div>

            <div class="space-y-6">
                <!-- Stars -->
                <div class="flex justify-center gap-3">
                    @for (int i = 1; i <= 5; i++)
                    {
                        int starIndex = i;
                        <button @onclick="() => _rating = starIndex" 
                                class="text-3xl transition-transform hover:scale-110 @(_rating >= starIndex ? "text-amber-400" : "text-gray-200")">
                            <i class="fas fa-star"></i>
                        </button>
                    }
                </div>

                <!-- Comment -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Your Feedback (Optional)</label>
                    <textarea @bind="_reviewComment" rows="3"
                              class="w-full px-4 py-3 rounded-2xl border border-gray-100 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all resize-none text-sm"
                              placeholder="Tell us what you liked or how we can improve..."></textarea>
                </div>

                <div class="flex gap-3">
                    <button @onclick="SubmitReview" disabled="@(_rating == 0 || _submittingReview)"
                            class="flex-1 py-3.5 bg-gradient-to-r from-primary-600 to-indigo-600 text-white font-bold rounded-2xl text-sm transition-all shadow-lg shadow-primary-500/20 hover:shadow-primary-500/40 disabled:opacity-50 disabled:shadow-none">
                        @if (_submittingReview)
                        {
                            <i class="fas fa-spinner fa-spin mr-2"></i>
                            <span>Submitting...</span>
                        }
                        else
                        {
                            <span>Submit Review</span>
                        }
                    </button>
                    <button @onclick="CloseRatingModal"
                            class="px-6 py-3.5 bg-gray-50 text-gray-700 font-bold rounded-2xl text-sm hover:bg-gray-100 transition-all">
                        Cancel
                    </button>
                </div>
            </div>

            <button @onclick="CloseRatingModal" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors">
                <i class="fas fa-times"></i>
            </button>
        </div>
    </div>
}
