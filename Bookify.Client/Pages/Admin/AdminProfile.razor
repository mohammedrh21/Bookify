@page "/admin/profile"
@attribute [Authorize(Policy = "AdminOnly")]

<PageTitle>Admin Profile — Bookify</PageTitle>

<AuthorizeView Policy="AdminOnly" Context="adminContext">
    <Authorized>
        <!-- Ambient Background -->
        <div class="fixed inset-0 -z-10 pointer-events-none">
            <div class="absolute inset-0 bg-gradient-to-br from-gray-50 via-white to-purple-50/30"></div>
            <div class="absolute top-0 left-1/4 w-96 h-96 bg-purple-400/10 rounded-full blur-3xl"></div>
            <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-indigo-400/10 rounded-full blur-3xl"></div>
        </div>

        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

            <!-- Page Header -->
            <div class="mb-8">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-purple-100 text-purple-700 text-xs font-bold uppercase tracking-wider mb-3">
                    <i class="fas fa-shield-alt text-[10px]"></i> Administration
                </div>
                <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">My Profile</h1>
                <p class="text-gray-500 mt-1">Manage your admin details and security preferences.</p>
            </div>

            @if (_loading)
            {
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <div class="h-72 bg-white/60 rounded-3xl border border-gray-100 shadow-sm animate-pulse"></div>
                    <div class="lg:col-span-2 h-80 bg-white/60 rounded-3xl border border-gray-100 shadow-sm animate-pulse"></div>
                </div>
            }
            else if (_profile is null)
            {
                <div class="flex flex-col items-center justify-center py-24 bg-white/70 backdrop-blur rounded-3xl border border-gray-100 shadow">
                    <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mb-5">
                        <i class="fas fa-user-slash text-3xl text-gray-400"></i>
                    </div>
                    <h2 class="text-xl font-bold text-gray-800 mb-1">Profile Unavailable</h2>
                    <p class="text-gray-500 text-sm">Could not load your profile. Please refresh the page.</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

                    <!-- ── Avatar / Info Card ── -->
                    <div class="bg-white/80 backdrop-blur-xl rounded-3xl border border-gray-100 shadow-lg p-6 flex flex-col items-center text-center gap-4 relative overflow-hidden">
                        <!-- Gradient accent -->
                        <div class="absolute top-0 inset-x-0 h-24 bg-gradient-to-b from-purple-500/10 to-transparent rounded-t-3xl pointer-events-none"></div>

                        <!-- Avatar -->
                        <div class="relative mt-2">
                            <div class="w-24 h-24 rounded-full bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center shadow-lg ring-4 ring-white overflow-hidden">
                                <span class="text-white text-4xl font-black">@GetInitial()</span>
                            </div>
                        </div>

                        <!-- Name / Email -->
                        <div>
                            <h2 class="text-lg font-extrabold text-gray-900">@_profile.FullName</h2>
                            <p class="text-sm text-gray-500 mt-0.5 flex items-center justify-center gap-1.5">
                                <i class="fas fa-envelope text-gray-400 text-xs"></i>
                                @_profile.Email
                            </p>
                        </div>

                        <div class="w-full h-px bg-gray-100"></div>

                        <!-- Role Badge -->
                        <div class="w-full px-4 py-2.5 rounded-2xl bg-gradient-to-r from-purple-50 to-indigo-50 border border-purple-100 text-purple-700 text-sm font-bold flex items-center justify-center gap-2">
                            <i class="fas fa-star text-purple-500 text-xs"></i> Super Administrator
                        </div>
                    </div>

                    <!-- ── Edit Form ── -->
                    <div class="lg:col-span-2">
                        <div class="bg-white/80 backdrop-blur-xl rounded-3xl border border-gray-100 shadow-lg overflow-hidden">

                            <!-- Card Header -->
                            <div class="px-8 pt-7 pb-5 border-b border-gray-100 flex items-center gap-4">
                                <div class="w-10 h-10 rounded-2xl bg-purple-100 flex items-center justify-center text-purple-600 shadow-inner shrink-0">
                                    <i class="fas fa-id-card"></i>
                                </div>
                                <div>
                                    <h2 class="text-base font-extrabold text-gray-900">Personal Details</h2>
                                    <p class="text-xs text-gray-400 font-medium mt-0.5">Update your contact information.</p>
                                </div>
                            </div>

                            <!-- Form Body -->
                            <div class="p-8 space-y-5">

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                    <!-- Full Name -->
                                    <div class="group">
                                        <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-1.5">Full Name</label>
                                        <div class="relative">
                                            <div class="absolute inset-y-0 left-4 flex items-center text-gray-400 group-focus-within:text-purple-500 transition-colors pointer-events-none">
                                                <i class="fas fa-id-card text-sm"></i>
                                            </div>
                                            <input type="text" @bind="_edit.FullName"
                                                   class="w-full pl-10 pr-4 py-3 bg-gray-50 rounded-xl border border-gray-200 focus:bg-white focus:border-purple-400 focus:ring-2 focus:ring-purple-400/20 outline-none transition-all text-gray-900 font-semibold text-sm placeholder-gray-300"
                                                   placeholder="Your full name" />
                                        </div>
                                    </div>

                                    <!-- Phone Number -->
                                    <div class="group">
                                        <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-1.5">Phone Number</label>
                                        <div class="flex items-stretch gap-2">
                                            <Bookify.Client.Components.UI.CountryPicker SelectedCountry="_selectedCountry" OnCountrySelected="HandleCountrySelected" />
                                            <div class="relative flex-1 min-w-0">
                                                <div class="absolute inset-y-0 left-3 flex items-center text-gray-400 pointer-events-none">
                                                    <i class="fas fa-phone-alt text-sm"></i>
                                                </div>
                                                <input type="tel" @bind="_phoneNumber"
                                                       class="w-full pl-9 pr-4 py-3 bg-gray-50 rounded-xl border border-gray-200 focus:bg-white focus:border-purple-400 focus:ring-2 focus:ring-purple-400/20 outline-none transition-all text-gray-900 font-semibold text-sm placeholder-gray-300"
                                                       placeholder="Number" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Email (read-only) -->
                                <div>
                                    <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-1.5">Email Address</label>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-4 flex items-center text-gray-400 pointer-events-none">
                                            <i class="fas fa-envelope text-sm"></i>
                                        </div>
                                        <input type="email" value="@_profile.Email" readonly
                                               class="w-full pl-10 pr-24 py-3 bg-gray-50 rounded-xl border border-gray-200 text-gray-400 font-semibold text-sm cursor-not-allowed" />
                                        <div class="absolute inset-y-0 right-3 flex items-center">
                                            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wide bg-gray-200 px-2 py-1 rounded-md">Read Only</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Save Button -->
                                <div class="pt-2 flex justify-end">
                                    <button @onclick="SaveProfileAsync" disabled="@_saving"
                                            class="inline-flex items-center gap-2 px-7 py-3 bg-gradient-to-r from-purple-500 to-indigo-600 text-white font-bold text-sm rounded-xl shadow-md shadow-purple-500/25 hover:shadow-purple-500/40 hover:-translate-y-0.5 transition-all disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0">
                                        @if (_saving)
                                        {
                                            <i class="fas fa-circle-notch animate-spin"></i>
                                            <span>Saving...</span>
                                        }
                                        else
                                        {
                                            <i class="fas fa-check"></i>
                                            <span>Save Profile</span>
                                        }
                                    </button>
                                </div>

                            </div>
                        </div>
                    </div>

                </div>
            }

        </div>
    </Authorized>
</AuthorizeView>

