@page "/book/{ServiceId:guid}"
@attribute [Authorize]
@using Bookify.Client.Components.UI.Modals

<PageTitle>Book Service — Bookify</PageTitle>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <a href="/service/@ServiceId"
       class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-primary-600 mb-8 transition-colors">
        <i class="fas fa-arrow-left"></i>
        Back to service details
    </a>

    @if (_loading)
    {
        <div class="flex flex-col items-center justify-center py-20">
            <div class="w-12 h-12 border-4 border-primary-200 border-t-primary-600 rounded-full animate-spin mb-4"></div>
            <p class="text-gray-500 font-medium">Loading booking options...</p>
        </div>
    }
    else if (_service is null)
    {
        <div class="text-center py-20 bg-white rounded-3xl border border-gray-100 shadow-sm">
            <div class="text-5xl mb-4">🔍</div>
            <h2 class="text-2xl font-bold text-gray-900">Service Not Found</h2>
            <p class="text-gray-500 mt-2">This service may no longer be available.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 items-start">
            <!-- Left Column: Service Info & Selection Summary -->
            <div class="lg:col-span-2 space-y-6 lg:sticky lg:top-10">
                <div class="bg-white rounded-3xl border border-gray-100 p-8 shadow-sm">
                    <div class="mb-6">
                        <span class="px-3 py-1 bg-primary-50 text-primary-700 text-[10px] font-black rounded-full uppercase tracking-widest">
                            Booking Summary
                        </span>
                        <h1 class="text-3xl font-black text-gray-900 mt-3">@_service.Name</h1>
                        <p class="text-gray-500 text-sm mt-2 leading-relaxed">@_service.Description</p>
                    </div>

                    <div class="space-y-4 pt-6 border-t border-gray-50 mb-8">
                        <div class="flex items-center justify-between text-sm">
                            <span class="text-gray-400 font-medium">Professional</span>
                            <span class="text-gray-900 font-bold">@_service.StaffName</span>
                        </div>
                        <div class="flex items-center justify-between text-sm">
                            <span class="text-gray-400 font-medium">Duration</span>
                            <span class="text-gray-900 font-bold">@_service.Duration min</span>
                        </div>
                        <div class="flex items-center justify-between text-sm">
                            <span class="text-gray-400 font-medium">Price</span>
                            <span class="text-primary-600 font-black text-lg">$@_service.Price.ToString("F2")</span>
                        </div>
                    </div>

                    <div class="bg-primary-50/50 rounded-2xl p-5 mb-8 border border-primary-100/50">
                        <p class="text-[10px] text-primary-400 font-black uppercase tracking-widest mb-2">Selected Time</p>
                        @if (_timeSelected)
                        {
                            <div class="flex items-center gap-3 text-primary-900">
                                <i class="fas fa-calendar-check text-primary-500"></i>
                                <span class="font-bold">@_selectedDate.ToString("MMM dd, yyyy")</span>
                                <span class="w-1 h-1 rounded-full bg-primary-200"></span>
                                <span class="font-bold">@DateTime.Today.Add(_selectedTime).ToString("hh:mm tt")</span>
                            </div>
                        }
                        else
                        {
                            <p class="text-primary-300 text-sm italic">Please select a slot from the calendar</p>
                        }
                    </div>

                    <button @onclick="HandleProceedToPayment" disabled="@(!_timeSelected || _booking)"
                            class="w-full py-5 bg-gradient-to-r from-primary-600 to-indigo-600 hover:from-primary-700 hover:to-indigo-700 disabled:opacity-50 text-white font-extrabold rounded-2xl text-lg transition-all shadow-xl shadow-primary-500/20 hover:shadow-primary-500/40 flex items-center justify-center gap-3">
                        @if (_booking)
                        {
                            <div class="w-5 h-5 border-3 border-white border-t-transparent rounded-full animate-spin"></div>
                            <span>Finalizing...</span>
                        }
                        else
                        {
                            <i class="fas fa-lock"></i>
                            <span>Proceed to Payment</span>
                        }
                    </button>
                    
                    @if (!_timeSelected)
                    {
                        <p class="text-center text-amber-600 text-[10px] mt-4 font-bold uppercase tracking-wider">
                            <i class="fas fa-exclamation-triangle mr-1"></i>
                            Selection Required
                        </p>
                    }
                </div>

                <div class="p-6 bg-gray-50 rounded-3xl border border-gray-100 flex gap-4 items-center">
                    <div class="w-12 h-12 bg-white rounded-2xl shadow-sm flex items-center justify-center text-primary-500">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <div>
                        <h4 class="text-sm font-bold text-gray-900">Secure Appointment</h4>
                        <p class="text-xs text-gray-500 mt-0.5">Your data and payment are protected.</p>
                    </div>
                </div>
            </div>

            <!-- Right Column: Interactive Calendar -->
            <div class="lg:col-span-3">
                <BookingCalendar ServiceId="ServiceId" 
                                 SelectedDate="@_selectedDate"
                                 SelectedTime="@_selectedTime"
                                 StartHour="@_service.TimeStart"
                                 EndHour="@_service.TimeEnd"
                                 IntervalMinutes="@_service.Duration"
                                 OnDateSelected="d => OnDateChanged(d)"
                                 OnTimeSelected="t => { _selectedTime = t; _timeSelected = true; }" />
            </div>
        </div>
    }
</div>
