@page "/services/my-service"
@using System.Net
@attribute [Authorize(Roles = "Staff")]

@inject IServiceApiService ServiceService
@inject IAuthService Auth
@inject NavigationManager Nav

<PageTitle>My Service — Bookify</PageTitle>

<div class="max-w-4xl mx-auto px-4 py-10">

    <h1 class="text-3xl font-bold text-gray-900 mb-8">My Service</h1>

    @if (_loading)
    {
        <LoadingSpinner Message="Loading your service..." />
    }
    else if (_service == null)
    {
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 rounded-xl">
            <p class="text-yellow-800">You currently have no service created.</p>

            <button @onclick="GoToCreate"
                    class="mt-4 px-5 py-2 bg-blue-600 text-white rounded-xl hover:bg-blue-700 transition">
                Create Your Service
            </button>
        </div>
    }
    else
    {
        <div class="bg-white border border-gray-200 rounded-3xl shadow-lg overflow-hidden">

            <!-- Header -->
            <div class="bg-gradient-to-r from-blue-600 to-indigo-600 p-6 text-white flex justify-between items-center">
                <div>
                    <h2 class="text-2xl font-bold">@_service.Name</h2>
                    <p class="text-blue-100 text-sm mt-1">@_service.Description</p>
                </div>

                <div class="flex gap-3">
                    <button @onclick="GoToEdit"
                            class="bg-white text-blue-600 px-4 py-2 rounded-xl font-semibold text-sm hover:scale-105 transition">
                        <i class="fas fa-pen mr-2"></i>Edit
                    </button>

                    <button @onclick="OpenDeleteModal"
                            class="bg-red-600 text-white px-4 py-2 rounded-xl font-semibold text-sm hover:bg-red-700 transition">
                        <i class="fas fa-trash mr-2"></i>Delete
                    </button>
                </div>
            </div>

            <!-- Body -->
            <div class="p-8 space-y-8">

                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    <InfoCard Title="Price" Value="@_service.Price.ToString()" Icon="fa-dollar-sign" />
                    <InfoCard Title="Duration" Value="@($"{_service.Duration} min")" Icon="fa-clock" />
                    <InfoCard Title="Category" Value="@_service.CategoryName" Icon="fa-layer-group" />
                </div>

                <div class="bg-gray-50 border p-6 rounded-2xl">
                    <h3 class="text-lg font-semibold mb-6">Availability</h3>

                    <div class="grid sm:grid-cols-2 gap-6">
                        <AvailabilityCard Label="Available From"
                                          Value="@FormatTime(_service.TimeStart)" />
                        <AvailabilityCard Label="Available To"
                                          Value="@FormatTime(_service.TimeEnd)" />
                    </div>
                </div>

            </div>
        </div>
    }
</div>

@if (_showDeleteModal)
{
    <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-50">
        <div class="bg-white w-full max-w-md rounded-3xl shadow-2xl p-8">

            <h3 class="text-xl font-bold text-center mb-4">
                Delete Service?
            </h3>

            @if (_deleteCountdown > 0)
            {
                <p class="text-center text-red-600 font-semibold mb-4">
                    Please wait @_deleteCountdown seconds...
                </p>
            }

        <div class="flex justify-center gap-4">
            <button @onclick="CloseDeleteModal"
                    class="px-4 py-2 border rounded-xl">
                Cancel
            </button>

            <button @onclick="ConfirmDelete"
                    @attributes=@((_deleteCountdown > 0
                                        ? new Dictionary<string, object> { { "disabled", "disabled" } }:null))
                    class="px-5 py-2 rounded-xl text-white @(_deleteCountdown > 0 ? "bg-red-300 cursor-not-allowed" : "bg-red-600 hover:bg-red-700")">
                Confirm Delete
            </button>
        </div>
    </div>
</div>
}

@code {
    private ServiceModel? _service;
    private bool _loading = true;
    private Guid _staffId;

    private bool _showDeleteModal;
    private int _deleteCountdown = 3;

    protected override async Task OnInitializedAsync()
    {
        var staff = await Auth.GetUserIdAsync();
        if (staff != null)
            _staffId = (Guid)staff;

        var result = await ServiceService.GetByStaffIdAsync(_staffId);
        _service = result.Data;
        _loading = false;
    }

    private void GoToCreate() =>
        Nav.NavigateTo("/services/create-service");

    private void GoToEdit()
    {
        if (_service != null)
            Nav.NavigateTo($"/services/edit-service/{_service.Id}");
    }

    private string FormatTime(TimeSpan ts) =>
        DateTime.Today.Add(ts).ToString("hh:mm tt");

    private async Task OpenDeleteModal()
    {
        _showDeleteModal = true;
        _deleteCountdown = 3;

        while (_deleteCountdown > 0)
        {
            await Task.Delay(1000);
            _deleteCountdown--;
            StateHasChanged();
        }
    }

    private void CloseDeleteModal() => _showDeleteModal = false;

    private async Task ConfirmDelete()
    {
        if (_service == null) return;

        var result = await ServiceService.DeleteAsync(_service.Id);
        if (result.Success)
            _service = null;

        _showDeleteModal = false;
    }
}