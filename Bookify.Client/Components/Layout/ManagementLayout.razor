@using Bookify.Client.Components.Layout
@using Bookify.Client.Components.Shared

<div class="min-h-screen bg-gray-50 flex">
    <SideBar @bind-IsOpen="isSidebarOpen" />

    <div class="flex-1 flex flex-col min-w-0 transition-all duration-300 lg:ml-[18rem] min-h-screen max-w-full relative">
        
        <!-- Mobile Header (Visible only on small screens) -->
        <header class="lg:hidden bg-white shadow-sm border-b border-gray-100 sticky top-0 z-30 flex items-center justify-between px-4 py-3">
            <div class="flex items-center gap-3">
                <button @onclick="ToggleSidebar" class="p-2 -ml-2 text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-xl transition-colors">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
                <div class="flex items-center gap-2 font-bold text-gray-800">
                    <div class="w-8 h-8 bg-gradient-to-br from-primary-500 to-primary-600 rounded-lg flex items-center justify-center">
                        <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    Bookify
                </div>
            </div>
        </header>

        <main class="flex-1 p-4 sm:p-6 lg:p-8 overflow-x-hidden min-h-0 relative bg-gray-50/50">
            <div class="page-fade-in w-full max-w-full">
                @ChildContent
            </div>
        </main>
    </div>
    <NotificationOverlay />
    <FloatingToasts />
</div>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }
    
    private bool isSidebarOpen = false;
    
    private void ToggleSidebar()
    {
        isSidebarOpen = !isSidebarOpen;
    }
}
