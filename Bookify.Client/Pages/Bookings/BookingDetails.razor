@page "/bookings/{Id:guid}"
@attribute [Authorize]
@using Bookify.Client.Models.Booking
@using Bookify.Client.Models.Common

<PageTitle>Booking Details — Bookify</PageTitle>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <button @onclick='() => Nav.NavigateTo(_backUrl)' 
            class="flex items-center gap-2 text-gray-500 hover:text-primary-600 font-semibold mb-8 transition-colors group">
        <i class="fas fa-arrow-left transform group-hover:-translate-x-1 transition-transform"></i>
        <span>@_backLabel</span>
    </button>

    @if (_loading)
    {
        <div class="flex flex-col items-center justify-center py-20">
            <div class="w-12 h-12 border-4 border-primary-200 border-t-primary-600 rounded-full animate-spin mb-4"></div>
            <p class="text-gray-500 font-medium">Loading booking details...</p>
        </div>
    }
    else if (_booking == null)
    {
        <div class="text-center py-20 bg-white rounded-3xl border border-gray-100 shadow-sm">
            <div class="text-5xl mb-4">🔍</div>
            <h2 class="text-2xl font-bold text-gray-900 mb-2">Booking Not Found</h2>
            <p class="text-gray-500 mb-8">The booking you're looking for doesn't exist or you don't have permission to view it.</p>
            <a href="@_backUrl" class="px-6 py-3 bg-primary-600 text-white font-bold rounded-xl hover:bg-primary-700 transition-colors">
                Return to Bookings
            </a>
        </div>
    }
    else
    {
        <div class="bg-white rounded-[2.5rem] shadow-2xl shadow-gray-200/50 border border-gray-100 overflow-hidden">
            <!-- Header Section -->
            <div class="bg-gradient-to-br from-gray-900 to-indigo-900 p-8 md:p-12 text-white relative overflow-hidden">
                <div class="absolute top-0 right-0 w-64 h-64 bg-primary-600/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
                
                <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
                    <div>
                        <div class="flex items-center gap-3 mb-4">
                            <span class="px-3 py-1 bg-white/10 backdrop-blur-md rounded-full text-xs font-bold uppercase tracking-wider">
                                Booking Ref: #@_booking.Id.ToString().Substring(0, 8).ToUpper()
                            </span>
                            <StatusBadge Status="@_booking.Status" />
                        </div>
                        <h1 class="text-3xl md:text-4xl font-extrabold mb-2">@_booking.ServiceName</h1>
                        <p class="text-indigo-200 text-lg flex items-center gap-2">
                            <i class="fas fa-user-tie"></i>
                            Assigned Staff: <span class="text-white font-bold">@_booking.StaffName</span>
                        </p>
                    </div>
                    <div class="text-right">
                        <div class="text-indigo-300 text-sm font-bold uppercase tracking-widest mb-1">Total Paid</div>
                        <div class="text-4xl font-black text-white">$@_booking.Price.ToString("F2")</div>
                    </div>
                </div>
            </div>

            <!-- Content Body -->
            <div class="p-8 md:p-12 space-y-10">
                <!-- Appointment Details Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-6">
                        <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest flex items-center gap-3">
                            <span class="w-8 h-px bg-gray-200"></span>
                            Schedule Information
                        </h3>
                        <div class="space-y-4">
                            <div class="flex items-start gap-4 p-4 rounded-2xl bg-gray-50 border border-transparent hover:border-primary-100 transition-all group">
                                <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-primary-600 text-xl group-hover:scale-110 transition-transform">
                                    <i class="far fa-calendar-alt"></i>
                                </div>
                                <div>
                                    <div class="text-xs font-bold text-gray-400 uppercase mb-0.5">Date</div>
                                    <div class="text-gray-900 font-bold text-lg">@_booking.Date.ToString("dddd, MMMM dd, yyyy")</div>
                                </div>
                            </div>
                            <div class="flex items-start gap-4 p-4 rounded-2xl bg-gray-50 border border-transparent hover:border-primary-100 transition-all group">
                                <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-primary-600 text-xl group-hover:scale-110 transition-transform">
                                    <i class="far fa-clock"></i>
                                </div>
                                <div>
                                    <div class="text-xs font-bold text-gray-400 uppercase mb-0.5">Time</div>
                                    <div class="text-gray-900 font-bold text-lg">@_booking.Time.ToString(@"hh\:mm") (@_booking.DurationMinutes min)</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-6">
                        <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest flex items-center gap-3">
                            <span class="w-8 h-px bg-gray-200"></span>
                            Service Actions
                        </h3>
                        <div class="grid grid-cols-1 gap-3">
                            <a href="/service/@_booking.ServiceId" 
                               class="flex items-center justify-between p-4 rounded-2xl border-2 border-primary-50 hover:border-primary-100 hover:bg-primary-50/30 transition-all group">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-primary-100 text-primary-600 rounded-lg flex items-center justify-center">
                                        <i class="fas fa-info-circle"></i>
                                    </div>
                                    <span class="font-bold text-gray-900">View Service Page</span>
                                </div>
                                <i class="fas fa-chevron-right text-primary-300 group-hover:translate-x-1 transition-transform"></i>
                            </a>

                            @if (_booking.Status == "Completed")
                            {
                                @if (_hasReviewed)
                                {
                                    <div class="flex items-center justify-between p-4 rounded-2xl border-2 border-green-50 bg-green-50/30">
                                        <div class="flex items-center gap-3 text-green-700 font-bold">
                                            <i class="fas fa-check-circle"></i>
                                            <span>Feedback already provided</span>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <button @onclick="OpenRatingModal"
                                            class="flex items-center justify-between p-4 rounded-2xl border-2 border-amber-50 hover:border-amber-100 hover:bg-amber-50/30 transition-all group">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-amber-100 text-amber-600 rounded-lg flex items-center justify-center">
                                                <i class="fas fa-star"></i>
                                            </div>
                                            <span class="font-bold text-gray-900">Provide Feedback</span>
                                        </div>
                                        <i class="fas fa-chevron-right text-amber-300 group-hover:translate-x-1 transition-transform"></i>
                                    </button>
                                }
                            }
                        </div>
                    </div>
                </div>

                <!-- Footer Summary -->
                <div class="pt-8 border-t border-gray-100 flex flex-col sm:flex-row items-center justify-between gap-6">
                    <div class="flex items-center gap-4 text-gray-500 italic text-sm">
                        <i class="fas fa-shield-alt text-green-500"></i>
                        <span>This booking is secured by Bookify Payment Protection</span>
                    </div>
                    
                    @if (_booking.Status == "Pending")
                    {
                        <button class="w-full sm:w-auto px-8 py-3 bg-red-50 text-red-600 hover:bg-red-600 hover:text-white font-bold rounded-xl transition-all shadow-sm">
                            Cancel Appointment
                        </button>
                    }
                </div>
            </div>
        </div>
    }
</div>

@using Bookify.Client.Components.UI.Modals

<!-- Status bar or template continues above... -->
<!-- Line 161 (Rating Modal injection point) -->

@if (_ratingModalVisible && _booking != null)
{
    <RatingModal StaffName="@_booking.StaffName" 
                 IsSubmitting="@_submittingReview" 
                 OnSubmit="HandleSubmitReview" 
                 OnClose="CloseRatingModal" />
}

