@page "/admin/service-approvals"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Service Approvals — Bookify</PageTitle>

<div class="max-w-6xl mx-auto px-4 py-10">

    <h1 class="text-3xl font-bold text-gray-900 mb-8">Service Approvals</h1>

    @if (_loading)
    {
        <LoadingSpinner Message="Loading requests..." />
    }
    else if (_requests == null || !_requests.Any())
    {
        <div class="bg-gray-50 border p-6 rounded-xl text-center">
            <p class="text-gray-600">No pending approval requests found.</p>
        </div>
    }
    else
    {
        <div class="space-y-6">
            @foreach (var req in _requests)
            {
                <div class="bg-white border rounded-2xl shadow-sm p-6">
                    <div class="flex justify-between items-start mb-4 pb-4 border-b">
                        <div>
                            <span class="inline-block px-3 py-1 bg-blue-100 text-blue-800 text-xs font-semibold rounded-full mb-1">
                                @req.Type.ToString() Request
                            </span>
                            <h3 class="text-lg font-bold">Staff: @req.StaffName</h3>
                            <p class="text-xs text-gray-500">Submitted on: @req.CreatedAt.ToString("g")</p>
                        </div>
                        <div class="flex gap-2">
                            <button @onclick="() => ApproveAsync(req.Id)" class="px-4 py-2 bg-green-600 text-white rounded-xl hover:bg-green-700 text-sm font-semibold">
                                Approve
                            </button>
                            <button @onclick="() => OpenRejectModal(req.Id)" class="px-4 py-2 bg-red-50 text-red-600 border border-red-100 rounded-xl hover:bg-red-100 text-sm font-semibold">
                                Reject
                            </button>
                        </div>
                    </div>

                    @* Proposal Details *@
                    @if (req.Type == ApprovalRequestType.Create)
                    {
                        <div class="space-y-2">
                            <p><strong>Name:</strong> @req.ProposedDetails.Name</p>
                            <p><strong>Description:</strong> @req.ProposedDetails.Description</p>
                            <p><strong>Price:</strong> $@req.ProposedDetails.Price</p>
                            <p><strong>Duration:</strong> @req.ProposedDetails.Duration mins</p>
                            <p><strong>Category:</strong> @req.ProposedDetails.CategoryName</p>
                            <p><strong>Available From:</strong> @FormatTime(req.ProposedDetails.TimeStart)</p>
                            <p><strong>Available To:</strong> @FormatTime(req.ProposedDetails.TimeEnd)</p>
                        </div>
                    }
                    else if (req.Type == ApprovalRequestType.Update && req.CurrentDetails != null)
                    {
                        <div class="grid grid-cols-2 gap-6">
                            <div>
                                <h4 class="font-semibold text-gray-700 mb-2">Current Details</h4>
                                <div class="space-y-1.5 text-sm bg-gray-50 p-4 rounded-xl">
                                    <p><strong>Name:</strong> @req.CurrentDetails.Name</p>
                                    <p><strong>Description:</strong> @req.CurrentDetails.Description</p>
                                    <p><strong>Price:</strong> $@req.CurrentDetails.Price</p>
                                    <p><strong>Duration:</strong> @req.CurrentDetails.Duration mins</p>
                                    <p><strong>Category:</strong> @req.CurrentDetails.CategoryName</p>
                                    <p><strong>Available From:</strong> @FormatTime(req.CurrentDetails.TimeStart)</p>
                                    <p><strong>Available To:</strong> @FormatTime(req.CurrentDetails.TimeEnd)</p>
                                </div>
                            </div>
                            <div>
                                <h4 class="font-semibold text-blue-700 mb-2">Proposed Updates</h4>
                                <div class="space-y-1.5 text-sm bg-blue-50 p-4 rounded-xl border border-blue-100">
                                    <p class="@GetDiffClass(req.CurrentDetails.Name, req.ProposedDetails.Name)"><strong>Name:</strong> @req.ProposedDetails.Name</p>
                                    <p class="@GetDiffClass(req.CurrentDetails.Description, req.ProposedDetails.Description)"><strong>Description:</strong> @req.ProposedDetails.Description</p>
                                    <p class="@GetDiffClass(req.CurrentDetails.Price, req.ProposedDetails.Price)"><strong>Price:</strong> $@req.ProposedDetails.Price</p>
                                    <p class="@GetDiffClass(req.CurrentDetails.Duration, req.ProposedDetails.Duration)"><strong>Duration:</strong> @req.ProposedDetails.Duration mins</p>
                                    <p class="@GetDiffClass(req.CurrentDetails.CategoryName, req.ProposedDetails.CategoryName)"><strong>Category:</strong> @req.ProposedDetails.CategoryName</p>
                                    <p class="@GetDiffClass(req.CurrentDetails.TimeStart, req.ProposedDetails.TimeStart)"><strong>Available From:</strong> @FormatTime(req.ProposedDetails.TimeStart)</p>
                                    <p class="@GetDiffClass(req.CurrentDetails.TimeEnd, req.ProposedDetails.TimeEnd)"><strong>Available To:</strong> @FormatTime(req.ProposedDetails.TimeEnd)</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@* Reject Modal *@
@if (_showRejectModal)
{
    <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-50">
        <div class="bg-white w-full max-w-md rounded-2xl p-6 shadow-xl">
            <h3 class="text-lg font-bold mb-4">Reject Request</h3>
            <textarea @bind="_rejectComment" class="w-full border rounded-lg p-2" rows="3" placeholder="Reason for rejection..."></textarea>
            <div class="flex justify-end gap-2 mt-4">
                <button @onclick="CancelReject" class="px-4 py-2 border rounded-lg">Cancel</button>
                <button @onclick="ConfirmReject" class="px-4 py-2 bg-red-600 text-white rounded-lg">Confirm Reject</button>
            </div>
        </div>
    </div>
}



        
